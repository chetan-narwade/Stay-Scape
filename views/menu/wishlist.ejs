<% layout("layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   WISHLIST — StayScape blue/cyan dark system
   Tokens from boilerplate:
     --blue #3B82F6  --cyan #06B6D4  --bg #0A0A0F
     --s1 #111118    --s2 #16161F    --s3 #1E1E28
     --text #F0F4FF  --muted #6B7280 --border rgba(255,255,255,.07)
     --glow-blue rgba(59,130,246,.08)
     --font-heading  --font-body 'Inter'
     --danger #F87171  --success #4ADE80
═══════════════════════════════════════════════════════════ */

/* ── KEYFRAMES ── */
@keyframes wl-fadeUp  { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
@keyframes wl-scaleIn { from{opacity:0;transform:scale(.95)}       to{opacity:1;transform:scale(1)}      }
@keyframes wl-float   { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
@keyframes wl-heartBeat {
  0%  { transform:scale(1);   }
  30% { transform:scale(1.4); }
  60% { transform:scale(.9);  }
  100%{ transform:scale(1);   }
}
@keyframes wl-shimmer {
  0%  { background-position:200% center; }
  100%{ background-position:-200% center; }
}
@keyframes wl-beam {
  0%  { opacity:0; transform:translateX(-100%); }
  20% { opacity:1; }
  80% { opacity:1; }
  100%{ opacity:0; transform:translateX(100%);  }
}

/* ── PAGE SHELL ── */
.wl-page {
  min-height:100vh;
  background:var(--bg);
  padding-bottom:100px;
  position:relative; overflow:hidden;
}

/* decorative glows — mirrors index hero */
.wl-glow {
  position:fixed; border-radius:50%; pointer-events:none; z-index:0;
}
.wl-glow-1 {
  top:-160px; left:-100px;
  width:520px; height:520px;
  background:radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 60%);
}
.wl-glow-2 {
  bottom:-100px; right:-80px;
  width:380px; height:380px;
  background:radial-gradient(circle,rgba(6,182,212,.04) 0%,transparent 60%);
}

/* dot-grid — same as hero */
.wl-grid-tex {
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(59,130,246,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(59,130,246,.025) 1px,transparent 1px);
  background-size:80px 80px;
}

/* ── HERO BAND ── */
.wl-hero {
  position:relative; z-index:1;
  background:rgba(17,17,24,.8);
  border-bottom:1px solid var(--border);
  padding:52px 36px 44px;
  overflow:hidden;
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
}

/* animated beam — mirrors .sl-hero-beam */
.wl-hero::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg,transparent 0%,var(--blue) 45%,var(--cyan) 55%,transparent 100%);
  animation:wl-beam 6s ease-in-out 1s both;
}

/* corner glow inside hero */
.wl-hero::after {
  content:'';
  position:absolute; top:-60px; right:-40px;
  width:220px; height:220px; border-radius:50%;
  background:radial-gradient(circle,rgba(59,130,246,.08) 0%,transparent 65%);
  pointer-events:none;
}

.wl-hero-inner {
  max-width:1160px; margin:0 auto;
  position:relative; z-index:1;
  animation:wl-fadeUp .6s cubic-bezier(.22,1,.36,1) both;
}

/* eyebrow — mirrors .sl-sec-tag */
.wl-eyebrow {
  display:flex; align-items:center; gap:8px;
  font-size:10px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--blue); font-weight:600; margin-bottom:12px;
  font-family:var(--font-body);
}
.wl-eyebrow::before {
  content:''; display:block;
  width:24px; height:1px;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
}

.wl-hero-title {
  font-family:var(--font-heading);
  font-size:clamp(32px,5.5vw,58px);
  font-weight:300; color:var(--text);
  line-height:1.05; margin-bottom:10px;
  letter-spacing:-.02em;
}

/* shimmer italic — mirrors .sl-shimmer */
.wl-hero-title em {
  font-style:italic; font-weight:300;
  background:linear-gradient(105deg,var(--blue) 25%,var(--cyan) 50%,var(--blue) 75%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:wl-shimmer 4s linear infinite;
}

.wl-hero-sub {
  font-size:14px; color:var(--muted);
  font-weight:400; margin-bottom:24px; line-height:1.7;
  font-family:var(--font-body);
}

/* stats row — mirrors .sl-hero-stats pill */
.wl-stats {
  display:flex; align-items:center; gap:0;
  border:1px solid var(--border); border-radius:14px;
  overflow:hidden; background:rgba(17,17,24,.7);
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  width:fit-content;
}
.wl-stat-pill {
  display:inline-flex; align-items:center; gap:8px;
  padding:13px 22px;
  font-size:13px; color:var(--text);
  font-family:var(--font-body);
  border-right:1px solid var(--border);
}
.wl-stat-pill svg { width:14px; height:14px; flex-shrink:0; }
.wl-stat-item {
  display:inline-flex; align-items:center; gap:8px;
  padding:13px 22px;
  font-size:12px; color:var(--muted);
  font-family:var(--font-body);
  border-right:1px solid var(--border);
}
.wl-stat-item:last-child { border-right:none; }
.wl-stat-item svg { width:13px; height:13px; color:var(--cyan); flex-shrink:0; }
/* heart icon in stat-pill — blue gradient */
.wl-heart-icon {
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
}

/* ── CONTENT AREA ── */
.wl-content {
  max-width:1160px; margin:0 auto;
  padding:36px 36px;
  position:relative; z-index:1;
}

/* toolbar — mirrors .sl-grid-meta */
.wl-toolbar {
  display:flex; align-items:center;
  justify-content:space-between;
  margin-bottom:28px; flex-wrap:wrap; gap:12px;
}
.wl-toolbar-left {
  font-size:13px; color:var(--muted); font-family:var(--font-body);
}
.wl-toolbar-left strong { color:var(--text); font-weight:600; }
.wl-toolbar-right { display:flex; align-items:center; gap:8px; }

/* sort buttons — mirrors .sl-cat style */
.wl-sort-btn {
  display:inline-flex; align-items:center; gap:6px;
  padding:8px 16px;
  background:transparent; color:var(--muted);
  border:1px solid var(--border); border-radius:999px;
  font-size:11px; font-weight:500; letter-spacing:.04em;
  font-family:var(--font-body);
  transition:color .2s, background .2s, border-color .2s,
             transform .18s cubic-bezier(.34,1.56,.64,1);
}
.wl-sort-btn svg { width:12px; height:12px; flex-shrink:0; }
.wl-sort-btn:hover {
  color:var(--text);
  background:rgba(255,255,255,.05);
  border-color:rgba(59,130,246,.3);
}
.wl-sort-btn.active {
  color:var(--blue);
  background:rgba(59,130,246,.1);
  border-color:rgba(59,130,246,.35);
  font-weight:600;
}

/* section divider — mirrors .sl-sep */
.wl-sep {
  height:1px;
  background:linear-gradient(90deg,transparent,var(--border) 20%,var(--border) 80%,transparent);
  margin-bottom:28px;
}

/* ── GRID — mirrors .sl-grid ── */
.wl-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

/* ── CARD — mirrors .sl-card exactly ── */
.wl-card {
  background:var(--s2);
  border:1px solid rgba(255,255,255,.04);
  border-radius:18px; overflow:hidden;
  display:flex; flex-direction:column;
  animation:wl-scaleIn .5s cubic-bezier(.22,1,.36,1) both;
  transition:border-color .3s, transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
  color:var(--text);
}
.wl-card:hover {
  border-color:rgba(59,130,246,.3);
  transform:translateY(-6px);
  box-shadow:0 24px 60px rgba(0,0,0,.5), 0 0 0 1px rgba(59,130,246,.1);
}

/* card image — mirrors .sl-card-img */
.wl-img {
  position:relative; height:210px;
  overflow:hidden; background:var(--s3);
}
.wl-img img {
  width:100%; height:100%; object-fit:cover;
  transition:transform .6s cubic-bezier(.25,.46,.45,.94), filter .4s;
}
.wl-card:hover .wl-img img { transform:scale(1.07); filter:brightness(1.04); }

/* gradient overlay */
.wl-img-ov {
  position:absolute; inset:0;
  background:linear-gradient(to top,rgba(22,22,31,.55) 0%,rgba(22,22,31,.1) 40%,transparent 65%);
}

/* category badge — mirrors .sl-badge */
.wl-badge {
  position:absolute; top:12px; left:12px; z-index:2;
  padding:4px 11px;
  background:rgba(22,22,31,.75);
  border:1px solid rgba(59,130,246,.25); border-radius:999px;
  font-size:10px; letter-spacing:.08em; text-transform:capitalize;
  color:var(--blue); font-weight:500;
  backdrop-filter:blur(8px); font-family:var(--font-body);
}

/* remove (heart) button — top-right */
.wl-rm-form {
  position:absolute; top:12px; right:12px; z-index:2; margin:0;
}
.wl-rm-btn {
  width:34px; height:34px; border-radius:50%;
  background:rgba(22,22,31,.78);
  border:1px solid rgba(248,113,113,.3);
  display:flex; align-items:center; justify-content:center;
  backdrop-filter:blur(8px);
  transition:all .22s cubic-bezier(.34,1.56,.64,1);
  cursor:pointer;
}
.wl-rm-btn svg { width:15px; height:15px; }
.wl-rm-btn:hover {
  background:rgba(248,113,113,.15);
  border-color:rgba(248,113,113,.55);
  transform:scale(1.14);
}
.wl-rm-btn:hover svg { animation:wl-heartBeat .35s ease; }

/* star rating strip — mirrors .sl-stars */
.wl-img-rating {
  position:absolute; bottom:10px; left:12px; z-index:2;
  display:flex; align-items:center; gap:5px;
}
.wl-stars { display:flex; gap:2px; }
.wl-stars svg { width:10px; height:10px; }
.wl-rcount { font-size:10px; color:rgba(240,244,255,.7); font-family:var(--font-body); }

/* card body */
.wl-body {
  padding:16px 18px 18px;
  flex:1; display:flex; flex-direction:column;
}

/* location — mirrors .sl-card-loc */
.wl-loc {
  display:flex; align-items:center; gap:5px;
  font-size:10px; letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted); margin-bottom:6px; font-family:var(--font-body);
}
.wl-loc svg { width:10px; height:10px; color:var(--cyan); flex-shrink:0; }

/* title — mirrors .sl-card-title */
.wl-title {
  font-family:var(--font-heading);
  font-size:18px; font-weight:400;
  color:var(--text); line-height:1.25; margin-bottom:10px;
}

/* tags — mirrors .sl-tag */
.wl-tags { display:flex; gap:5px; flex-wrap:wrap; margin-bottom:13px; }
.wl-tag {
  display:inline-flex; align-items:center; gap:3px;
  padding:4px 9px;
  background:rgba(59,130,246,.06);
  border:1px solid rgba(59,130,246,.12); border-radius:7px;
  font-size:10px; color:var(--muted); letter-spacing:.04em;
  font-family:var(--font-body);
  transition:border-color .18s, color .18s;
}
.wl-tag:hover { border-color:rgba(59,130,246,.3); color:var(--blue); }

/* footer — mirrors .sl-card-footer */
.wl-foot {
  display:flex; align-items:flex-end;
  justify-content:space-between;
  margin-top:auto; padding-top:13px;
  border-top:1px solid rgba(255,255,255,.05); gap:8px;
}

/* price — mirrors .sl-price */
.wl-price-row { display:flex; align-items:baseline; gap:2px; }
.wl-pcur { font-size:14px; color:var(--blue); font-weight:500; }
.wl-pval {
  font-family:var(--font-heading);
  font-size:22px; font-weight:300; color:var(--text);
}
.wl-punit { font-size:11px; color:var(--muted); margin-left:2px; font-family:var(--font-body); }
.wl-ptax  { font-size:10px; color:var(--muted); margin-top:2px; font-family:var(--font-body); }

/* "View" button — mirrors .sl-book-btn */
.wl-view {
  display:inline-flex; align-items:center; gap:6px;
  padding:9px 18px;
  background:rgba(59,130,246,.1);
  border:1px solid rgba(59,130,246,.25); border-radius:999px;
  font-size:11px; letter-spacing:.05em;
  color:var(--blue); font-weight:500; white-space:nowrap;
  font-family:var(--font-body);
  transition:background .2s, border-color .2s, color .2s,
             transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
}
.wl-view svg { width:11px; height:11px; }
.wl-view:hover {
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  border-color:transparent; color:#fff;
  transform:scale(1.05);
  box-shadow:0 4px 16px rgba(59,130,246,.35);
}

/* ── EMPTY STATE — mirrors .sl-empty ── */
.wl-empty {
  display:flex; flex-direction:column;
  align-items:center; padding:100px 24px; text-align:center;
  position:relative; z-index:1;
  animation:wl-fadeUp .65s cubic-bezier(.22,1,.36,1) both;
}
.wl-empty-icon {
  width:80px; height:80px; border-radius:50%;
  background:rgba(59,130,246,.08);
  border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  color:var(--blue); margin-bottom:24px;
  animation:wl-float 3.5s ease-in-out infinite;
}
.wl-empty-icon svg { width:34px; height:34px; }
.wl-empty-title {
  font-family:var(--font-heading);
  font-size:clamp(28px,4vw,42px);
  font-weight:300; color:var(--text); margin-bottom:12px;
  letter-spacing:-.02em;
}
/* shimmer italic in empty title */
.wl-empty-title em {
  font-style:italic; font-weight:300;
  background:linear-gradient(105deg,var(--blue) 25%,var(--cyan) 50%,var(--blue) 75%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:wl-shimmer 4s linear infinite;
}
.wl-empty-sub {
  font-size:14px; color:var(--muted);
  max-width:380px; line-height:1.78;
  font-weight:400; margin-bottom:32px;
  font-family:var(--font-body);
}

/* CTA — mirrors .sl-btn-primary */
.wl-empty-cta {
  display:inline-flex; align-items:center; gap:9px;
  padding:14px 34px;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#fff; border:none; border-radius:999px;
  font-size:14px; font-weight:600; font-family:var(--font-body);
  transition:transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.wl-empty-cta:hover {
  color:#fff; transform:translateY(-3px);
  box-shadow:0 10px 30px rgba(59,130,246,.4);
  filter:brightness(1.08);
}
.wl-empty-note {
  margin-top:16px; font-size:11px; color:var(--muted);
  letter-spacing:.05em; font-family:var(--font-body);
}

/* ══ RESPONSIVE ══════════════════════════════════════════
   ≥ 1025px  3-col
   ≤ 1024px  2-col
   ≤ 680px   2-col compact, hero padding reduced
   ≤ 480px   1-col
   ≤ 380px   very small
═══════════════════════════════════════════════════════ */

@media (max-width:1024px) {
  .wl-grid { grid-template-columns:repeat(2,1fr); }
}

@media (max-width:680px) {
  .wl-hero   { padding:36px 18px 30px; }
  .wl-content{ padding:24px 16px; }
  .wl-grid   { grid-template-columns:1fr 1fr; gap:12px; }
  .wl-img    { height:165px; }
  .wl-body   { padding:12px 13px 14px; }
  .wl-title  { font-size:15px; }
  .wl-foot   { flex-direction:column; align-items:flex-start; gap:8px; }
  .wl-view   { width:100%; justify-content:center; }
  .wl-toolbar{ flex-direction:column; align-items:flex-start; }
  /* stats row: allow wrapping */
  .wl-stats  { flex-wrap:wrap; width:100%; border-radius:12px; }
  .wl-stat-pill,
  .wl-stat-item { flex:1; border-bottom:1px solid var(--border); border-right:none; justify-content:center; }
  .wl-stat-item:last-child { border-bottom:none; }
}

@media (max-width:480px) {
  .wl-grid { grid-template-columns:1fr; }
  .wl-img  { height:200px; }
  .wl-card-footer { flex-direction:row; }
}

@media (max-width:380px) {
  .wl-hero-title { font-size:28px; }
  .wl-sort-btn   { font-size:10px; padding:7px 12px; }
}

@media (prefers-reduced-motion:reduce) {
  .wl-empty-icon, .wl-card { animation:none !important; }
  .wl-card-img img { transition:none !important; }
  .wl-hero-title em,
  .wl-empty-title em { animation:none; }
  .wl-hero::before { animation:none; }
}
</style>


<!-- decorative layers -->
<div class="wl-glow wl-glow-1" aria-hidden="true"></div>
<div class="wl-glow wl-glow-2" aria-hidden="true"></div>
<div class="wl-grid-tex"       aria-hidden="true"></div>

<div class="wl-page">

  <!-- ══ HERO BAND ════════════════════════════════════════ -->
  <div class="wl-hero">
    <div class="wl-hero-inner">

      <div class="wl-eyebrow">Your collection</div>
      <h1 class="wl-hero-title">My <em>wishlist</em></h1>
      <p class="wl-hero-sub">Properties you've saved — ready whenever you are.</p>

      <div class="wl-stats">
        <!-- heart count pill -->
        <div class="wl-stat-pill">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)"
               stroke-width="2" stroke-linecap="round" width="14" height="14">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
          <% if (!listings || listings.length === 0) { %>
            0 saved properties
          <% } else { %>
            <%= listings.length %> saved <%= listings.length === 1 ? 'property' : 'properties' %>
          <% } %>
        </div>

        <% if (listings && listings.length > 0) { %>
          <div class="wl-stat-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8"  y1="2" x2="8"  y2="6"/>
              <line x1="3"  y1="10" x2="21" y2="10"/>
            </svg>
            Book any time
          </div>
          <div class="wl-stat-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Verified listings
          </div>
        <% } %>
      </div>

    </div>
  </div>


  <% if (!listings || listings.length === 0) { %>

  <!-- ══ EMPTY STATE ════════════════════════════════════════ -->
  <div class="wl-empty">
    <div class="wl-empty-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.5" stroke-linecap="round">
        <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
      </svg>
    </div>
    <h2 class="wl-empty-title">Nothing saved <em>yet</em></h2>
    <p class="wl-empty-sub">
      Browse our curated collection and tap the heart ♥ on any listing
      to save it here for whenever you're ready to book.
    </p>
    <a href="/listings" class="wl-empty-cta">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" width="15" height="15">
        <circle cx="11" cy="11" r="7"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      Explore stays
    </a>
    <p class="wl-empty-note">12,000+ properties worldwide · Updated daily</p>
  </div>

  <% } else { %>

  <!-- ══ CONTENT ════════════════════════════════════════════ -->
  <div class="wl-content">

    <!-- toolbar -->
    <div class="wl-toolbar">
      <div class="wl-toolbar-left">
        Showing <strong><%= listings.length %></strong>
        saved <%= listings.length === 1 ? 'property' : 'properties' %>
      </div>
      <div class="wl-toolbar-right">
        <button class="wl-sort-btn active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
          Saved
        </button>
        <button class="wl-sort-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
          Price
        </button>
      </div>
    </div>

    <div class="wl-sep"></div>

    <!-- cards grid -->
    <div class="wl-grid">
      <% listings.forEach(function(listing, index) { %>
        <% if (!listing || !listing._id) return; %>

        <div class="wl-card" style="animation-delay:<%= index * 0.06 %>s">

          <!-- image -->
          <div class="wl-img">
            <img
              src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600' %>"
              alt="<%= listing.title %>" loading="lazy">
            <div class="wl-img-ov"></div>

            <!-- category badge -->
            <% if (listing.category) { %>
              <span class="wl-badge"><%= listing.category %></span>
            <% } %>

            <!-- remove from wishlist -->
            <form class="wl-rm-form"
                  action="/menu/wishlist/<%= listing._id %>"
                  method="POST">
              <button type="submit" class="wl-rm-btn"
                      title="Remove from wishlist">
                <svg viewBox="0 0 24 24" fill="#f87171" stroke="#f87171"
                     stroke-width="1" stroke-linecap="round">
                  <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                </svg>
              </button>
            </form>

            <!-- star rating -->
            <% if (listing.reviews && listing.reviews.length > 0) { %>
              <%
                const avg  = listing.reviews.reduce((s,r) => s+(r.rating||0), 0) / listing.reviews.length;
                const full = Math.round(avg);
              %>
              <div class="wl-img-rating">
                <div class="wl-stars">
                  <% for (let s = 0; s < 5; s++) { %>
                    <svg viewBox="0 0 24 24"
                         fill="<%= s < full ? '#3B82F6' : 'rgba(59,130,246,.2)' %>">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  <% } %>
                </div>
                <span class="wl-rcount"><%= avg.toFixed(1) %></span>
              </div>
            <% } %>
          </div>

          <!-- body -->
          <div class="wl-body">

            <div class="wl-loc">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <%= listing.location %>, <%= listing.country %>
            </div>

            <div class="wl-title"><%= listing.title %></div>

            <div class="wl-tags">
              <% if (listing.amenities && listing.amenities.length) { %>
                <% listing.amenities.slice(0,3).forEach(function(a) { %>
                  <span class="wl-tag"><%= a %></span>
                <% }); %>
              <% } else { %>
                <% if (listing.bedrooms)  { %><span class="wl-tag"><%= listing.bedrooms %> beds</span><% } %>
                <% if (listing.bathrooms) { %><span class="wl-tag"><%= listing.bathrooms %> baths</span><% } %>
                <% if (listing.category)  { %><span class="wl-tag"><%= listing.category %></span><% } %>
              <% } %>
            </div>

            <div class="wl-foot">
              <div class="wl-price">
                <div class="wl-price-row">
                  <span class="wl-pcur">₹</span>
                  <span class="wl-pval"><%= listing.price.toLocaleString('en-IN') %></span>
                  <span class="wl-punit">/ night</span>
                </div>
                <div class="wl-ptax">+ 18% GST applicable</div>
              </div>

              <a href="/listings/<%= listing._id %>" class="wl-view">
                View
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>

          </div><!-- /.wl-body -->
        </div><!-- /.wl-card -->

      <% }); %>
    </div><!-- /.wl-grid -->

  </div><!-- /.wl-content -->

  <% } %>

</div><!-- /.wl-page -->
