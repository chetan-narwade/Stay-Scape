<% layout("/layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   MY BOOKINGS — matches StayScape blue/cyan dark system
   Tokens inherited from boilerplate:
     --blue #3B82F6  --cyan #06B6D4  --bg #0A0A0F
     --s1 #111118    --s2 #16161F    --s3 #1E1E28
     --text #F0F4FF  --muted #6B7280 --border rgba(255,255,255,.07)
     --glow-blue rgba(59,130,246,.08)
     --font-heading (display)  --font-body 'Inter'
═══════════════════════════════════════════════════════════ */

/* ── KEYFRAMES ── */
@keyframes bk-fadeUp {
  from { opacity:0; transform:translateY(22px); }
  to   { opacity:1; transform:translateY(0);    }
}
@keyframes bk-scaleIn {
  from { opacity:0; transform:scale(.96); }
  to   { opacity:1; transform:scale(1);   }
}
@keyframes bk-shimmer {
  0%   { background-position:200% center; }
  100% { background-position:-200% center; }
}

/* ── PAGE SHELL ── */
.bk-page {
  min-height:100vh;
  background:var(--bg);
  padding:52px 24px 100px;
  position:relative;
  overflow:hidden;
}

/* decorative glows — mirrors index hero */
.bk-page::before {
  content:'';
  position:fixed; top:-180px; right:-120px;
  width:520px; height:520px; border-radius:50%;
  background:radial-gradient(circle,rgba(59,130,246,.06) 0%,transparent 60%);
  pointer-events:none; z-index:0;
}
.bk-page::after {
  content:'';
  position:fixed; bottom:-80px; left:-60px;
  width:360px; height:360px; border-radius:50%;
  background:radial-gradient(circle,rgba(6,182,212,.04) 0%,transparent 60%);
  pointer-events:none; z-index:0;
}

/* subtle dot-grid — same as hero */
.bk-grid-bg {
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(59,130,246,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(59,130,246,.025) 1px,transparent 1px);
  background-size:80px 80px;
}

.bk-inner {
  max-width:900px;
  margin:0 auto;
  position:relative; z-index:1;
}

/* ── PAGE HEADER ── */
.bk-head {
  margin-bottom:40px;
  animation:bk-fadeUp .6s cubic-bezier(.22,1,.36,1) both;
}

/* eyebrow label — mirrors .sl-sec-tag */
.bk-eyebrow {
  display:flex; align-items:center; gap:8px;
  font-size:10px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--blue); font-weight:600; margin-bottom:12px;
  font-family:var(--font-body);
}
.bk-eyebrow::before {
  content:''; display:block;
  width:24px; height:1px;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
}

.bk-title {
  font-family:var(--font-heading);
  font-size:clamp(32px,5vw,52px);
  font-weight:300; color:var(--text); line-height:1.05;
  letter-spacing:-.02em;
}

/* shimmer italic — mirrors .sl-shimmer */
.bk-title em {
  font-style:italic; font-weight:300;
  background:linear-gradient(105deg,var(--blue) 25%,var(--cyan) 50%,var(--blue) 75%);
  background-size:200% auto;
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:bk-shimmer 4s linear infinite;
}

.bk-sub {
  font-size:15px; color:var(--muted);
  margin-top:10px; font-weight:400; line-height:1.7;
  font-family:var(--font-body);
}

/* ── STATS BAR — mirrors .sl-hero-stats pill row ── */
.bk-stats {
  display:flex; align-items:stretch;
  border:1px solid var(--border);
  border-radius:18px; overflow:hidden;
  background:rgba(17,17,24,.7);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  margin-bottom:44px;
  animation:bk-fadeUp .6s .1s cubic-bezier(.22,1,.36,1) both;
}
.bk-stat {
  flex:1; padding:22px 24px;
  display:flex; flex-direction:column; align-items:center; gap:5px;
  border-right:1px solid var(--border);
  transition:background .25s;
}
.bk-stat:last-child { border-right:none; }
.bk-stat:hover { background:rgba(59,130,246,.06); }
.bk-stat-val {
  font-family:var(--font-heading);
  font-size:28px; font-weight:300; color:var(--text); line-height:1;
}
/* gradient accent on stat numbers */
.bk-stat-val span {
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.bk-stat-lbl {
  font-size:10px; letter-spacing:.14em; text-transform:uppercase;
  color:var(--muted); font-family:var(--font-body); text-align:center;
}

/* ── SECTION HEADER — mirrors .sl-sec-hd ── */
.bk-sec-hd {
  display:flex; align-items:flex-end;
  justify-content:space-between;
  margin-bottom:28px; gap:12px; flex-wrap:wrap;
}
.bk-sec-tag {
  font-size:10px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--blue); font-weight:600; margin-bottom:8px;
  display:flex; align-items:center; gap:8px;
  font-family:var(--font-body);
}
.bk-sec-tag::before {
  content:''; display:block;
  width:24px; height:1px;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
}
.bk-sec-title {
  font-family:var(--font-heading);
  font-size:clamp(22px,3vw,32px);
  font-weight:300; color:var(--text); line-height:1.08;
}
.bk-sec-title em { font-style:italic; color:var(--cyan); }
.bk-count {
  font-size:13px; color:var(--muted); font-family:var(--font-body);
}
.bk-count strong { color:var(--text); font-weight:600; }

/* divider — mirrors .sl-sep */
.bk-sep {
  height:1px;
  background:linear-gradient(90deg,transparent,var(--border) 20%,var(--border) 80%,transparent);
  margin-bottom:32px;
}

/* ── BOOKING LIST ── */
.bk-list { display:flex; flex-direction:column; gap:16px; }

/* ── BOOKING CARD — mirrors .sl-card ── */
.bk-card {
  background:var(--s2);
  border:1px solid rgba(255,255,255,.04);
  border-radius:18px; overflow:hidden;
  display:grid;
  grid-template-columns:220px 1fr;
  animation:bk-scaleIn .5s cubic-bezier(.22,1,.36,1) both;
  transition:border-color .3s, transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
  color:var(--text);
  /* ensure body stretches to image height */
  min-height:220px;
}
.bk-card:hover {
  border-color:rgba(59,130,246,.3);
  transform:translateY(-5px);
  box-shadow:0 24px 60px rgba(0,0,0,.55), 0 0 0 1px rgba(59,130,246,.1);
}

/* ─ Image column ─ */
.bk-card-img {
  position:relative; overflow:hidden;
  background:var(--s3);
}
.bk-card-img img {
  position:absolute; inset:0;
  width:100%; height:100%;
  object-fit:cover;
  transition:transform .6s cubic-bezier(.25,.46,.45,.94), filter .4s;
}
.bk-card:hover .bk-card-img img {
  transform:scale(1.07); filter:brightness(1.04);
}

/* gradient right-to-left on desktop */
.bk-card-img-ov {
  position:absolute; inset:0;
  background:linear-gradient(to right,transparent 45%,rgba(22,22,31,.88));
  pointer-events:none;
}

/* image placeholder */
.bk-img-placeholder {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
}

/* status badge — mirrors .sl-badge */
.bk-status {
  position:absolute; top:12px; left:12px;
  padding:4px 12px; border-radius:999px;
  font-size:10px; letter-spacing:.08em;
  text-transform:uppercase; font-weight:500;
  backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);
  font-family:var(--font-body);
}
.bk-status.paid {
  background:rgba(16,185,129,.12);
  border:1px solid rgba(16,185,129,.3);
  color:#4ade80;
}
.bk-status.pending {
  background:rgba(251,191,36,.10);
  border:1px solid rgba(251,191,36,.3);
  color:#fbbf24;
}
.bk-status.cancelled {
  background:rgba(239,68,68,.10);
  border:1px solid rgba(239,68,68,.28);
  color:#f87171;
}

/* ─ Body column ─ */
.bk-card-body {
  padding:22px 24px;
  display:flex; flex-direction:column;
  /* gaps managed per-child for fine control */
}

.bk-card-listing {
  font-family:var(--font-heading);
  font-size:20px; font-weight:400;
  color:var(--text); line-height:1.2;
  margin-bottom:5px;
}

/* location — mirrors .sl-card-loc */
.bk-card-location {
  display:flex; align-items:center; gap:5px;
  font-size:10px; letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted); margin-bottom:16px;
  font-family:var(--font-body);
}
.bk-card-location svg { width:11px; height:11px; flex-shrink:0; color:var(--cyan); }

/* date strip */
.bk-dates {
  display:flex; align-items:center; gap:10px;
  padding:10px 14px;
  background:var(--s3);
  border:1px solid rgba(59,130,246,.08);
  border-radius:10px;
  margin-bottom:16px;
}
.bk-date-block { flex:1; }
.bk-date-lbl {
  font-size:9px; letter-spacing:.14em; text-transform:uppercase;
  color:var(--muted); margin-bottom:3px; font-family:var(--font-body);
}
.bk-date-val {
  font-size:13px; color:var(--text); font-weight:500;
  font-family:var(--font-body);
}
.bk-date-sep {
  width:28px; height:.5px; background:var(--border);
  flex-shrink:0; position:relative;
}
.bk-date-sep::after {
  content:''; position:absolute; right:-4px; top:-3px;
  border:3px solid transparent; border-left-color:var(--muted);
}
.bk-nights {
  font-size:10px; letter-spacing:.06em;
  color:var(--muted); white-space:nowrap;
  font-family:var(--font-body);
}

/* amount + actions — pinned to bottom */
.bk-card-bottom {
  margin-top:auto;
  display:flex; align-items:flex-end;
  justify-content:space-between;
  gap:14px; flex-wrap:wrap;
  padding-top:16px;
  border-top:1px solid rgba(255,255,255,.05);
}

/* price — mirrors .sl-price */
.bk-pbase { font-size:11px; color:var(--muted); margin-bottom:3px; font-family:var(--font-body); }
.bk-price { display:flex; align-items:baseline; gap:2px; }
.bk-pcur  { font-size:14px; color:var(--blue); font-weight:500; }
.bk-pval  {
  font-family:var(--font-heading);
  font-size:26px; font-weight:300; color:var(--text);
}
.bk-punit { font-size:11px; color:var(--muted); margin-left:3px; font-family:var(--font-body); }
.bk-ptax  { font-size:10px; color:var(--muted); margin-top:3px; font-family:var(--font-body); }

/* action buttons */
.bk-actions { display:flex; align-items:center; gap:8px; flex-shrink:0; }

/* "View listing" — mirrors .sl-book-btn */
.bk-btn-view {
  display:inline-flex; align-items:center; gap:6px;
  padding:9px 18px;
  background:rgba(59,130,246,.1);
  border:1px solid rgba(59,130,246,.25); border-radius:999px;
  font-size:11px; letter-spacing:.05em;
  color:var(--blue); font-weight:500; white-space:nowrap;
  font-family:var(--font-body);
  transition:background .2s, border-color .2s, color .2s,
             transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
}
.bk-btn-view:hover {
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  border-color:transparent; color:#fff;
  transform:scale(1.05);
  box-shadow:0 4px 16px rgba(59,130,246,.35);
}

/* "Cancel" */
.bk-btn-cancel {
  display:inline-flex; align-items:center; gap:6px;
  padding:9px 18px;
  background:rgba(239,68,68,.06);
  border:1px solid rgba(239,68,68,.2); border-radius:999px;
  font-size:11px; letter-spacing:.05em;
  color:rgba(239,68,68,.65); font-weight:500; white-space:nowrap;
  font-family:var(--font-body); cursor:pointer;
  transition:background .2s, border-color .2s, color .2s,
             transform .18s cubic-bezier(.34,1.56,.64,1);
}
.bk-btn-cancel:hover {
  background:rgba(239,68,68,.14);
  border-color:rgba(239,68,68,.5);
  color:#f87171; transform:scale(1.05);
}

/* ── EMPTY STATE — mirrors .sl-empty ── */
.bk-empty {
  display:flex; flex-direction:column;
  align-items:center; padding:90px 20px; text-align:center;
  background:var(--s2);
  border:1px solid rgba(255,255,255,.04);
  border-radius:20px;
  animation:bk-scaleIn .5s .1s cubic-bezier(.22,1,.36,1) both;
}
.bk-empty-icon {
  width:64px; height:64px; border-radius:50%;
  background:rgba(59,130,246,.08);
  border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  color:var(--blue); margin-bottom:20px;
}
.bk-empty-icon svg { width:26px; height:26px; }
.bk-empty-title {
  font-family:var(--font-heading);
  font-size:30px; font-weight:300; color:var(--text); margin:0 0 10px;
}
.bk-empty-text {
  font-size:14px; color:var(--muted);
  margin:0 0 28px; max-width:340px; line-height:1.7;
  font-family:var(--font-body);
}
/* CTA — mirrors .sl-btn-primary */
.bk-empty-btn {
  display:inline-flex; align-items:center; gap:9px;
  padding:14px 32px;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#fff; border-radius:999px;
  font-size:13px; font-weight:600; font-family:var(--font-body);
  transition:transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.bk-empty-btn:hover {
  color:#fff; transform:translateY(-3px);
  box-shadow:0 10px 30px rgba(59,130,246,.4);
  filter:brightness(1.08);
}

/* ══ RESPONSIVE ══════════════════════════════════════════
   ≥ 701px  side-by-side (220px img | body)
   ≤ 700px  stacked      (img top, body below)
   ≤ 480px  compact
   ≤ 360px  very small
═══════════════════════════════════════════════════════ */

@media (max-width:700px) {
  .bk-page { padding:32px 14px 72px; }

  /* stack vertically */
  .bk-card {
    grid-template-columns:1fr;
    grid-template-rows:190px auto;
    min-height:0;
  }
  /* bottom-to-top gradient when stacked */
  .bk-card-img-ov {
    background:linear-gradient(to bottom,transparent 35%,rgba(22,22,31,.8));
  }
  .bk-card-body { padding:18px 18px 20px; }

  /* stats wrap to 2-col */
  .bk-stats { flex-wrap:wrap; border-radius:14px; }
  .bk-stat {
    flex:1 1 calc(50% - 1px);
    border-bottom:1px solid var(--border);
  }
  /* last stat spans full row if odd count */
  .bk-stat:last-child:nth-child(odd) {
    flex:1 1 100%;
    border-right:none;
  }
  .bk-stat:nth-child(even) { border-right:none; }
  /* remove bottom border on last row */
  .bk-stat:nth-last-child(-n+2):not(:nth-child(odd):last-child) {
    border-bottom:none;
  }

  /* bottom row: stack amount above buttons */
  .bk-card-bottom { flex-direction:column; align-items:flex-start; gap:14px; }
  .bk-actions { width:100%; }
  .bk-btn-view,
  .bk-btn-cancel { flex:1; justify-content:center; }
}

@media (max-width:480px) {
  .bk-page { padding:24px 12px 60px; }
  .bk-card { grid-template-rows:160px auto; }
  .bk-card-body { padding:14px 14px 16px; }
  .bk-card-listing { font-size:17px; margin-bottom:4px; }
  .bk-card-location { font-size:10px; margin-bottom:12px; }
  .bk-dates { padding:9px 12px; gap:8px; margin-bottom:12px; }
  .bk-date-val { font-size:12px; }
  .bk-pval { font-size:22px; }
  .bk-stat { padding:16px 14px; }
  .bk-stat-val { font-size:22px; }
  .bk-title { letter-spacing:-.01em; }
  .bk-sec-hd { margin-bottom:16px; }
}

@media (max-width:360px) {
  .bk-card { grid-template-rows:140px auto; }
  .bk-btn-view, .bk-btn-cancel { font-size:10px; padding:8px 12px; }
  .bk-title { font-size:26px; }
  /* single column stats */
  .bk-stat { flex:1 1 100%; border-right:none; }
}

@media (prefers-reduced-motion:reduce) {
  .bk-head, .bk-stats, .bk-card, .bk-empty { animation:none !important; }
  .bk-card-img img { transition:none !important; }
  .bk-title em { animation:none; }
}
</style>


<!-- decorative grid — same layer used in hero -->
<div class="bk-grid-bg" aria-hidden="true"></div>

<div class="bk-page">
  <div class="bk-inner">

    <!-- ══ HEADER ══════════════════════════════════════════ -->
    <div class="bk-head">
      <div class="bk-eyebrow">Account</div>
      <h1 class="bk-title">My <em>bookings</em></h1>
      <p class="bk-sub">All your stays — past, present and upcoming.</p>
    </div>

    <% if (bookings.length > 0) { %>

      <%
        const paid       = bookings.filter(b => b.isPaid).length;
        const pending    = bookings.filter(b => !b.isPaid).length;
        const totalSpent = bookings
          .filter(b => b.isPaid)
          .reduce((sum, b) => sum + (b.totalAmount || 0), 0);
      %>

      <!-- ══ STATS BAR ══════════════════════════════════════ -->
      <div class="bk-stats">
        <div class="bk-stat">
          <div class="bk-stat-val"><span><%= bookings.length %></span></div>
          <div class="bk-stat-lbl">Total bookings</div>
        </div>
        <div class="bk-stat">
          <div class="bk-stat-val"><span><%= paid %></span></div>
          <div class="bk-stat-lbl">Confirmed stays</div>
        </div>
        <div class="bk-stat">
          <div class="bk-stat-val">
            <span>₹<%= totalSpent.toLocaleString('en-IN') %></span>
          </div>
          <div class="bk-stat-lbl">Total spent · incl. GST</div>
        </div>
      </div>

      <!-- ══ LIST HEADER ════════════════════════════════════ -->
      <div class="bk-sec-hd">
        <div>
          <div class="bk-sec-tag">Your stays</div>
          <div class="bk-sec-title">Booking <em>history</em></div>
        </div>
        <span class="bk-count">
          <strong><%= bookings.length %></strong>
          booking<%= bookings.length !== 1 ? 's' : '' %>
        </span>
      </div>

      <div class="bk-sep"></div>

      <!-- ══ CARDS ══════════════════════════════════════════ -->
      <div class="bk-list">
        <% bookings.forEach(function(booking, i) {
          const nights = Math.ceil(
            (new Date(booking.endDate) - new Date(booking.startDate)) / (1000*60*60*24)
          );
          const base   = booking.totalAmount ? Math.round(booking.totalAmount / 1.18) : 0;
          const gst    = booking.totalAmount ? booking.totalAmount - base : 0;
          const status = booking.isPaid ? 'paid' : 'pending';
          const fmt    = d => new Date(d).toLocaleDateString('en-IN', {
            day:'numeric', month:'short', year:'numeric'
          });
        %>

        <div class="bk-card" style="animation-delay:<%= i * 0.07 %>s">

          <!-- image -->
          <div class="bk-card-img">
            <% if (booking.listing && booking.listing.image && booking.listing.image.url) { %>
              <img src="<%= booking.listing.image.url %>"
                   alt="<%= booking.listing.title %>" loading="lazy">
            <% } else { %>
              <div class="bk-img-placeholder">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none"
                     stroke="rgba(107,114,128,.4)" stroke-width="1.5" stroke-linecap="round">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            <% } %>
            <div class="bk-card-img-ov"></div>
            <span class="bk-status <%= status %>">
              <%= status === 'paid' ? '✓ Confirmed' : '⏳ Pending' %>
            </span>
          </div>

          <!-- body -->
          <div class="bk-card-body">

            <div class="bk-card-listing">
              <%= booking.listing ? booking.listing.title : 'Listing unavailable' %>
            </div>

            <div class="bk-card-location">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <%= booking.listing
                  ? booking.listing.location + ', ' + booking.listing.country
                  : '—' %>
            </div>

            <!-- dates -->
            <div class="bk-dates">
              <div class="bk-date-block">
                <div class="bk-date-lbl">Check-in</div>
                <div class="bk-date-val"><%= fmt(booking.startDate) %></div>
              </div>
              <div class="bk-date-sep"></div>
              <div class="bk-date-block">
                <div class="bk-date-lbl">Check-out</div>
                <div class="bk-date-val"><%= fmt(booking.endDate) %></div>
              </div>
              <div class="bk-nights">
                <%= nights %> night<%= nights !== 1 ? 's' : '' %>
              </div>
            </div>

            <!-- price + actions -->
            <div class="bk-card-bottom">
              <div>
                <div class="bk-pbase">
                  ₹<%= base.toLocaleString('en-IN') %> base
                  + ₹<%= gst.toLocaleString('en-IN') %> GST
                </div>
                <div class="bk-price">
                  <span class="bk-pcur">₹</span>
                  <span class="bk-pval">
                    <%= (booking.totalAmount || 0).toLocaleString('en-IN') %>
                  </span>
                  <span class="bk-punit">total</span>
                </div>
                <div class="bk-ptax">18% GST included</div>
              </div>

              <div class="bk-actions">
                <% if (booking.listing) { %>
                  <a href="/listings/<%= booking.listing._id %>" class="bk-btn-view">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" width="12" height="12">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                      <circle cx="12" cy="12" r="3"/>
                    </svg>
                    View listing
                  </a>
                <% } %>

                <% if (!booking.isPaid) { %>
                  <form action="/listings/booking/<%= booking._id %>?_method=DELETE"
                        method="POST"
                        style="margin:0;display:contents"
                        onsubmit="return confirm('Cancel this booking?')">
                    <button type="submit" class="bk-btn-cancel">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                           stroke-width="2" stroke-linecap="round" width="11" height="11">
                        <line x1="18" y1="6"  x2="6"  y2="18"/>
                        <line x1="6"  y1="6"  x2="18" y2="18"/>
                      </svg>
                      Cancel
                    </button>
                  </form>
                <% } %>
              </div>
            </div>

          </div><!-- /.bk-card-body -->
        </div><!-- /.bk-card -->
        <% }); %>
      </div><!-- /.bk-list -->

    <% } else { %>

      <!-- ══ EMPTY STATE ════════════════════════════════════ -->
      <div class="bk-empty">
        <div class="bk-empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" stroke-linecap="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8"  y1="2" x2="8"  y2="6"/>
            <line x1="3"  y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h4 class="bk-empty-title">No bookings yet</h4>
        <p class="bk-empty-text">
          You haven't booked any stays yet. Explore curated properties worldwide.
        </p>
        <a href="/listings" class="bk-empty-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" width="15" height="15">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          Explore stays
        </a>
      </div>

    <% } %>

  </div><!-- /.bk-inner -->
</div><!-- /.bk-page -->
