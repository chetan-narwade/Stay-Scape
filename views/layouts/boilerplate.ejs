<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0A0A0F" />

  <title>StayScape — Discover your perfect escape</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Fonts: Inter + Fraunces (normal, weight 400 only) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400&family=Fraunces:opsz,wght@9..144,400&display=swap" rel="stylesheet" />

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Leaflet JS (must be before page scripts) -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <style>
    /* ═══════════════════════════════════════
       STAYSCAPE DESIGN TOKENS
    ═══════════════════════════════════════ */
    :root {
      --bg:         #0A0A0F;
      --s1:         #111118;
      --s2:         #16161F;
      --s3:         #1C1C28;
      --blue:       #3B82F6;
      --cyan:       #06B6D4;
      --text:       #F0F4FF;
      --muted:      #9CA3B0;
      --border:     rgba(59, 130, 246, 0.15);
      --danger:     #EF4444;
      --success:    #10B981;
      --glow-blue:  rgba(59, 130, 246, 0.25);
      --glow-cyan:  rgba(6, 182, 212, 0.2);

      --font-body:    'Inter', sans-serif;
      --font-heading: 'Fraunces', serif;

      --radius-sm:  8px;
      --radius-md:  12px;
      --radius-lg:  20px;
      --radius-xl:  28px;

      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.4);
      --shadow-glow: 0 0 32px var(--glow-blue);
    }

    /* ═══════════════════════════════════════
       BOOTSTRAP DARK OVERRIDES
    ═══════════════════════════════════════ */
    body {
      background-color: var(--bg) !important;
      color: var(--text) !important;
      font-family: var(--font-body) !important;
      font-style: normal !important;
      font-weight: 400 !important;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      font-style: normal;
      font-weight: 400;
      color: var(--text);
    }

    a {
      color: var(--blue);
      text-decoration: none;
      transition: color var(--transition);
    }

    a:hover {
      color: var(--cyan);
    }

    /* Bootstrap container override */
    .container,
    .container-fluid,
    .container-lg,
    .container-xl {
      --bs-gutter-x: 1.5rem;
    }

    /* Bootstrap card override */
    .card {
      background-color: var(--s2) !important;
      border: 1px solid var(--border) !important;
      color: var(--text) !important;
      border-radius: var(--radius-lg) !important;
    }

    /* Bootstrap form overrides */
    .form-control,
    .form-select {
      background-color: var(--s2) !important;
      border: 1px solid var(--border) !important;
      color: var(--text) !important;
      border-radius: var(--radius-md) !important;
      transition: border-color var(--transition), box-shadow var(--transition);
    }

    .form-control:focus,
    .form-select:focus {
      background-color: var(--s3) !important;
      border-color: var(--blue) !important;
      box-shadow: 0 0 0 3px var(--glow-blue) !important;
      color: var(--text) !important;
    }

    .form-control::placeholder {
      color: var(--muted) !important;
    }

    .form-label {
      color: var(--muted);
      font-size: 0.875rem;
      font-weight: 400;
      margin-bottom: 6px;
    }

    /* Bootstrap button overrides */
    .btn-primary {
      background: linear-gradient(135deg, var(--blue), var(--cyan)) !important;
      border: none !important;
      color: #fff !important;
      font-weight: 400 !important;
      font-style: normal !important;
      border-radius: var(--radius-md) !important;
      transition: transform var(--transition), box-shadow var(--transition) !important;
    }

    .btn-primary:hover {
      transform: scale(1.02);
      box-shadow: 0 8px 24px var(--glow-blue) !important;
    }

    .btn-outline-primary {
      border: 1px solid var(--blue) !important;
      color: var(--blue) !important;
      background: transparent !important;
      border-radius: var(--radius-md) !important;
      font-weight: 400 !important;
      font-style: normal !important;
      transition: all var(--transition) !important;
    }

    .btn-outline-primary:hover {
      background: var(--glow-blue) !important;
      color: var(--text) !important;
    }

    .btn-danger {
      background-color: var(--danger) !important;
      border: none !important;
      border-radius: var(--radius-md) !important;
      font-weight: 400 !important;
      font-style: normal !important;
    }

    /* Bootstrap alert overrides */
    .alert-success {
      background-color: rgba(16, 185, 129, 0.12) !important;
      border: 1px solid rgba(16, 185, 129, 0.3) !important;
      color: #6ee7b7 !important;
      border-radius: var(--radius-md) !important;
    }

    .alert-danger,
    .alert-warning {
      background-color: rgba(239, 68, 68, 0.12) !important;
      border: 1px solid rgba(239, 68, 68, 0.3) !important;
      color: #fca5a5 !important;
      border-radius: var(--radius-md) !important;
    }

    .alert-info {
      background-color: rgba(59, 130, 246, 0.12) !important;
      border: 1px solid var(--border) !important;
      color: #93c5fd !important;
      border-radius: var(--radius-md) !important;
    }

    /* Bootstrap navbar override */
    .navbar {
      background-color: rgba(10, 10, 15, 0.85) !important;
      backdrop-filter: blur(20px) !important;
      -webkit-backdrop-filter: blur(20px) !important;
      border-bottom: 1px solid var(--border) !important;
    }

    /* Bootstrap modal overrides */
    .modal-content {
      background-color: var(--s2) !important;
      border: 1px solid var(--border) !important;
      border-radius: var(--radius-xl) !important;
      color: var(--text) !important;
    }

    .modal-header,
    .modal-footer {
      border-color: var(--border) !important;
    }

    /* Bootstrap badge */
    .badge {
      border-radius: var(--radius-sm) !important;
      font-weight: 400 !important;
    }

    /* Bootstrap dropdown */
    .dropdown-menu {
      background-color: var(--s2) !important;
      border: 1px solid var(--border) !important;
      border-radius: var(--radius-md) !important;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5) !important;
    }

    .dropdown-item {
      color: var(--text) !important;
      transition: background var(--transition) !important;
      border-radius: var(--radius-sm) !important;
    }

    .dropdown-item:hover,
    .dropdown-item:focus {
      background-color: var(--s3) !important;
      color: var(--text) !important;
    }

    /* Bootstrap nav tabs */
    .nav-tabs {
      border-bottom-color: var(--border) !important;
    }

    .nav-tabs .nav-link {
      color: var(--muted) !important;
      border: none !important;
      border-bottom: 2px solid transparent !important;
      border-radius: 0 !important;
      transition: all var(--transition) !important;
    }

    .nav-tabs .nav-link:hover {
      color: var(--text) !important;
      border-bottom-color: var(--border) !important;
    }

    .nav-tabs .nav-link.active {
      background: transparent !important;
      color: var(--blue) !important;
      border-bottom-color: var(--blue) !important;
    }

    /* Bootstrap pagination */
    .pagination .page-link {
      background-color: var(--s2) !important;
      border-color: var(--border) !important;
      color: var(--text) !important;
    }

    .pagination .page-link:hover {
      background-color: var(--s3) !important;
    }

    .pagination .page-item.active .page-link {
      background-color: var(--blue) !important;
      border-color: var(--blue) !important;
    }

    /* ═══════════════════════════════════════
       SCROLLBAR
    ═══════════════════════════════════════ */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--s1); }
    ::-webkit-scrollbar-thumb { background: var(--s3); border-radius: 999px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--blue); }

    /* ═══════════════════════════════════════
       FLASH CONTAINER (fixed top-right)
    ═══════════════════════════════════════ */
    .flash-container {
      position: fixed;
      top: 80px;
      right: 16px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 360px;
      width: calc(100% - 32px);
      pointer-events: none;
    }

    /* ═══════════════════════════════════════
       PAGE LAYOUT
    ═══════════════════════════════════════ */
    .page-wrapper {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .main-content {
      flex: 1;
    }

    /* ═══════════════════════════════════════
       SELECTION & FOCUS
    ═══════════════════════════════════════ */
    ::selection {
      background: var(--glow-blue);
      color: var(--text);
    }

    :focus-visible {
      outline: 2px solid var(--blue);
      outline-offset: 3px;
      border-radius: var(--radius-sm);
    }

    /* ═══════════════════════════════════════
       REDUCED MOTION
    ═══════════════════════════════════════ */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* ═══════════════════════════════════════
       MOBILE SCROLLBAR HIDE
    ═══════════════════════════════════════ */
    @media (max-width: 640px) {
      ::-webkit-scrollbar { display: none; }
      * { scrollbar-width: none; }
    }
  </style>
</head>

<body>
  <div class="page-wrapper">

    <%- include("../includes/navbar.ejs") %>

    <div class="flash-container">
      <%- include("../includes/flash.ejs") %>
    </div>

    <main class="main-content">
      <div class="container">
        <%- body %>
      </div>
    </main>

    <%- include("../includes/footer.ejs") %>

  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>