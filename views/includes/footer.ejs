<%# ============================================================
    StayScape — Premium Footer
    - Matches navbar dark luxury aesthetic (blue + cyan)
    - All links point to real routes
    - Fully responsive mobile-first
    ============================================================ %>

<footer class="sf-footer">

  <!-- Decorative top border beam -->
  <div class="sf-beam"></div>

  <div class="sf-inner">

    <!-- ═══ TOP SECTION ═══ -->
    <div class="sf-top">

      <!-- Brand col -->
      <div class="sf-col sf-col--brand">
        <a class="sf-brand" href="/">
          <span class="sf-brand-mark">
            <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 2L25 8.5V19.5L14 26L3 19.5V8.5L14 2Z" fill="#3B82F6" opacity="0.18"/>
              <path d="M14 2L25 8.5V19.5L14 26L3 19.5V8.5L14 2Z" stroke="#3B82F6" stroke-width="1.2"/>
              <path d="M9 16.5C9 13.46 11.24 11 14 11C16.76 11 19 13.46 19 16.5" stroke="#06B6D4" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="14" cy="10" r="1.8" fill="#3B82F6"/>
            </svg>
          </span>
          <span class="sf-brand-text">Stay<em>Scape</em></span>
        </a>

        <p class="sf-tagline">
          Discover extraordinary places to stay and craft travel memories that last a lifetime.
        </p>

        <!-- Social icons -->
        <div class="sf-socials">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="sf-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="sf-social" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://x.com" target="_blank" rel="noopener noreferrer" class="sf-social" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="sf-social" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Support col -->
      <div class="sf-col">
        <h6 class="sf-col-title">Support</h6>
        <ul class="sf-links">
          <li><a href="/chat/chatbot">Help Center</a></li>
          <li><a href="/safety">Safety Information</a></li>
          <li><a href="/cancellation-policy">Cancellation Options</a></li>
          <li><a href="/report">Report a Concern</a></li>
        </ul>
      </div>

      <!-- Hosting col -->
      <div class="sf-col">
        <h6 class="sf-col-title">Hosting</h6>
        <ul class="sf-links">
          <li><a href="/listings/new">Host with Us</a></li>
          <li><a href="/host-protection">Host Protection</a></li>
          <li><a href="/community">Community Forum</a></li>
          <li><a href="/hosting-resources">Hosting Resources</a></li>
        </ul>
      </div>

      <!-- Company col -->
      <div class="sf-col">
        <h6 class="sf-col-title">Company</h6>
        <ul class="sf-links">
          <li><a href="/about">About Us</a></li>
          <li><a href="/careers">Careers</a></li>
          <li><a href="/press">Press</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

    </div>
    <!-- ═══ END TOP ═══ -->

    <!-- Separator -->
    <div class="sf-sep"></div>

    <!-- ═══ BOTTOM SECTION ═══ -->
    <div class="sf-bottom">

      <div class="sf-bottom-left">
        <span class="sf-copy">© 2026 StayScape Private Limited. All rights reserved.</span>
        <div class="sf-legal">
          <a href="/privacy">Privacy</a>
          <span class="sf-dot"></span>
          <a href="/terms">Terms</a>
          <span class="sf-dot"></span>
          <a href="/sitemap">Sitemap</a>
          <span class="sf-dot"></span>
          <a href="/cookies">Cookies</a>
        </div>
      </div>

      <div class="sf-bottom-right">
        <div class="sf-lang" role="button" tabindex="0" aria-label="Change language">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="14" height="14">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
          </svg>
          English
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="11" height="11">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
        <div class="sf-currency" role="button" tabindex="0" aria-label="Change currency">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="14" height="14">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
          INR
        </div>
      </div>

    </div>
    <!-- ═══ END BOTTOM ═══ -->

  </div>
</footer>


<style>
/* ============================================================
   FOOTER VARIABLES — matches navbar blue/cyan palette
   ============================================================ */
.sf-footer {
  --sf-bg:        #0A0A0F;
  --sf-surface:   #111118;
  --sf-blue:      #3B82F6;
  --sf-cyan:      #06B6D4;
  --sf-blue-lt:   #60A5FA;
  --sf-blue-dim:  rgba(59,130,246,0.12);
  --sf-text:      #F0F4FF;
  --sf-muted:     #4B5260;
  --sf-muted-lt:  #9CA3B0;
  --sf-border:    rgba(59,130,246,0.15);
  --sf-border-h:  rgba(59,130,246,0.4);
  --sf-font:      'Inter', system-ui, sans-serif;
  --sf-shadow:    0 0 0 1px rgba(59,130,246,0.1);
}

/* ============================================================
   KEYFRAMES
   ============================================================ */
@keyframes sf-beam-pulse {
  0%, 100% { opacity: 0.5; background-position: 0% center; }
  50%       { opacity: 1;   background-position: 100% center; }
}

/* ============================================================
   FOOTER SHELL
   ============================================================ */
.sf-footer {
  background: var(--sf-bg);
  font-family: var(--sf-font);
  position: relative;
  overflow: hidden;
}

/* Subtle radial glow texture */
.sf-footer::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 10% 60%, rgba(59,130,246,0.04) 0%, transparent 55%),
    radial-gradient(circle at 90% 20%, rgba(6,182,212,0.03) 0%, transparent 50%);
  pointer-events: none;
}

/* Animated blue-cyan beam on top */
.sf-beam {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(59,130,246,0.2) 20%,
    var(--sf-blue) 45%,
    var(--sf-cyan) 55%,
    rgba(6,182,212,0.2) 80%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: sf-beam-pulse 4s ease-in-out infinite;
}

.sf-inner {
  max-width: 1380px;
  margin: 0 auto;
  padding: 0 28px;
  position: relative;
  z-index: 1;
}

/* ============================================================
   TOP GRID
   ============================================================ */
.sf-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding: 60px 0 52px;
}

/* ── BRAND COLUMN ── */
.sf-brand {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  text-decoration: none;
  margin-bottom: 18px;
  transition: opacity 0.2s;
}
.sf-brand:hover { opacity: 0.82; }
.sf-brand-mark svg {
  width: 28px; height: 28px; display: block;
  transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
}
.sf-brand:hover .sf-brand-mark svg { transform: rotate(15deg) scale(1.08); }
.sf-brand-text {
  font-family: var(--sf-font);
  font-size: 22px;
  font-weight: 700;
  color: var(--sf-text);
  letter-spacing: 0.01em;
}
.sf-brand-text em {
  font-style: normal;
  color: var(--sf-blue);
}

.sf-tagline {
  font-size: 13px;
  line-height: 1.75;
  color: var(--sf-muted-lt);
  margin-bottom: 28px;
  max-width: 260px;
  font-weight: 400;
}

/* ── SOCIAL ICONS ── */
.sf-socials {
  display: flex;
  gap: 10px;
}
.sf-social {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 1px solid var(--sf-border);
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  color: var(--sf-muted-lt);
  text-decoration: none;
  transition: color 0.2s, border-color 0.2s, background 0.2s,
              transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
}
.sf-social svg { width: 15px; height: 15px; display: block; }
.sf-social:hover {
  color: var(--sf-blue);
  border-color: var(--sf-blue);
  background: var(--sf-blue-dim);
  transform: translateY(-3px) scale(1.08);
  box-shadow: 0 6px 18px rgba(59,130,246,0.25);
}
.sf-social:active { transform: scale(0.94); }

/* ── LINK COLUMNS ── */
.sf-col-title {
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--sf-blue);
  font-weight: 600;
  margin: 0 0 20px 0;
  font-family: var(--sf-font);
  position: relative;
  padding-bottom: 12px;
}
.sf-col-title::after {
  content: '';
  position: absolute;
  left: 0; bottom: 0;
  width: 20px; height: 1px;
  background: linear-gradient(90deg, var(--sf-blue), var(--sf-cyan));
  opacity: 0.6;
  transition: width 0.3s cubic-bezier(.4,0,.2,1);
}
.sf-col:hover .sf-col-title::after { width: 40px; }

.sf-links {
  list-style: none;
  margin: 0; padding: 0;
  display: flex; flex-direction: column; gap: 2px;
}
.sf-links li a {
  display: inline-flex;
  align-items: center;
  color: var(--sf-muted-lt);
  font-size: 13px;
  font-weight: 400;
  text-decoration: none;
  padding: 6px 0;
  position: relative;
  overflow: hidden;
  transition: color 0.2s, padding-left 0.2s cubic-bezier(.4,0,.2,1);
}
/* Arrow slides in on hover */
.sf-links li a::before {
  content: '→';
  position: absolute; left: -16px;
  font-size: 11px;
  color: var(--sf-cyan);
  transition: left 0.22s cubic-bezier(.4,0,.2,1), opacity 0.2s;
  opacity: 0;
}
/* Underline grows on hover */
.sf-links li a::after {
  content: '';
  position: absolute; left: 0; bottom: 3px;
  width: 0; height: 1px;
  background: linear-gradient(90deg, var(--sf-blue), var(--sf-cyan));
  opacity: 0.5;
  transition: width 0.25s cubic-bezier(.4,0,.2,1);
}
.sf-links li a:hover {
  color: var(--sf-text);
  padding-left: 20px;
}
.sf-links li a:hover::before { left: 0; opacity: 1; }
.sf-links li a:hover::after  { width: calc(100% - 20px); }

/* ============================================================
   SEPARATOR
   ============================================================ */
.sf-sep {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent,
    var(--sf-border) 20%,
    var(--sf-border) 80%,
    transparent
  );
}

/* ============================================================
   BOTTOM BAR
   ============================================================ */
.sf-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 0 32px;
  gap: 20px;
  flex-wrap: wrap;
}

.sf-bottom-left {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sf-copy {
  font-size: 12px;
  color: var(--sf-muted);
  font-weight: 400;
  letter-spacing: 0.03em;
}

.sf-legal {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.sf-legal a {
  font-size: 12px;
  color: var(--sf-muted-lt);
  text-decoration: none;
  transition: color 0.18s;
  position: relative;
}
.sf-legal a::after {
  content: '';
  position: absolute; left: 0; bottom: -1px;
  width: 0; height: 1px;
  background: linear-gradient(90deg, var(--sf-blue), var(--sf-cyan));
  transition: width 0.22s cubic-bezier(.4,0,.2,1);
}
.sf-legal a:hover { color: var(--sf-text); }
.sf-legal a:hover::after { width: 100%; }

.sf-dot {
  width: 2px; height: 2px;
  border-radius: 50%;
  background: var(--sf-muted);
  display: inline-block;
  flex-shrink: 0;
}

/* Language & currency pills */
.sf-bottom-right {
  display: flex;
  align-items: center;
  gap: 8px;
}
.sf-lang, .sf-currency {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--sf-border);
  background: transparent;
  color: var(--sf-muted-lt);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  font-family: var(--sf-font);
  user-select: none;
  transition: color 0.2s, border-color 0.2s, background 0.2s,
              transform 0.18s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
}
.sf-lang svg:last-child {
  transition: transform 0.2s cubic-bezier(.34,1.56,.64,1);
}
.sf-lang:hover, .sf-currency:hover {
  color: var(--sf-blue);
  border-color: var(--sf-blue);
  background: var(--sf-blue-dim);
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(59,130,246,0.15);
}
.sf-lang:hover svg:last-child { transform: rotate(180deg); }
.sf-lang:focus-visible, .sf-currency:focus-visible {
  outline: 2px solid var(--sf-blue);
  outline-offset: 3px;
}

/* ============================================================
   RESPONSIVE — TABLET (≤ 900px)
   ============================================================ */
@media (max-width: 900px) {
  .sf-top {
    grid-template-columns: 1fr 1fr;
    gap: 36px 40px;
    padding: 48px 0 40px;
  }
  .sf-col--brand { grid-column: 1 / -1; }
  .sf-tagline { max-width: 100%; }
}

/* ============================================================
   RESPONSIVE — MOBILE (≤ 600px)
   ============================================================ */
@media (max-width: 600px) {
  .sf-inner { padding: 0 20px; }
  .sf-top {
    grid-template-columns: 1fr 1fr;
    gap: 28px 24px;
    padding: 40px 0 32px;
  }
  .sf-col--brand { grid-column: 1 / -1; }
  .sf-brand-text { font-size: 20px; }
  .sf-tagline { font-size: 13px; margin-bottom: 20px; }
  .sf-col-title { margin-bottom: 14px; }
  .sf-links li a { font-size: 13px; padding: 5px 0; }
  .sf-bottom {
    flex-direction: column;
    align-items: flex-start;
    padding: 20px 0 28px;
    gap: 16px;
  }
  .sf-bottom-right { width: 100%; justify-content: flex-start; }
  .sf-legal { gap: 8px; }
}

/* ============================================================
   RESPONSIVE — SMALL MOBILE (≤ 380px)
   ============================================================ */
@media (max-width: 380px) {
  .sf-top { grid-template-columns: 1fr; }
  .sf-col--brand { grid-column: 1; }
  .sf-bottom-right { flex-wrap: wrap; }
}
</style>
