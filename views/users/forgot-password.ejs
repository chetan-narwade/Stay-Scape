<% layout("/layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   FORGOT PASSWORD — StayScape blue/cyan dark system
   Tokens from boilerplate:
     --blue #3B82F6  --cyan #06B6D4  --bg #0A0A0F
     --s1 #111118    --s2 #16161F    --s3 #1E1E28
     --text #F0F4FF  --muted #6B7280 --border rgba(255,255,255,.07)
     --glow-blue rgba(59,130,246,.08)
     --font-heading  --font-body 'Inter'
     --danger #F87171  --success #4ADE80
═══════════════════════════════════════════════════════════ */

/* ── KEYFRAMES ── */
@keyframes fp-fadeUp {
  from { opacity:0; transform:translateY(24px); }
  to   { opacity:1; transform:translateY(0);    }
}
@keyframes fp-floatOrb {
  0%,100% { transform:translateY(0);   }
  50%     { transform:translateY(-16px); }
}
@keyframes fp-spin    { to { transform:rotate(360deg); } }
@keyframes fp-slideIn {
  from { opacity:0; transform:translateY(6px); }
  to   { opacity:1; transform:translateY(0);   }
}
@keyframes fp-beam {
  0%  { opacity:0; transform:translateX(-100%); }
  20% { opacity:1; }
  80% { opacity:1; }
  100%{ opacity:0; transform:translateX(100%);  }
}
@keyframes fp-shimmer {
  0%   { background-position:200% center; }
  100% { background-position:-200% center; }
}
@keyframes fp-checkBounce {
  0%  { transform:scale(0);   }
  60% { transform:scale(1.2); }
  100%{ transform:scale(1);   }
}

/* ── PAGE ── */
.fp-page {
  min-height:100vh;
  display:flex; align-items:center; justify-content:center;
  padding:24px 20px;
  position:relative; overflow:hidden;
  background:var(--bg);
}

/* decorative glows */
.fp-orb {
  position:fixed; border-radius:50%; pointer-events:none; z-index:0;
}
.fp-orb-1 {
  top:-140px; right:-100px; width:480px; height:480px;
  background:radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 60%);
  animation:fp-floatOrb 8s ease-in-out infinite;
}
.fp-orb-2 {
  bottom:-80px; left:-60px; width:360px; height:360px;
  background:radial-gradient(circle,rgba(6,182,212,.04) 0%,transparent 60%);
  animation:fp-floatOrb 11s ease-in-out 2s infinite;
}

/* dot-grid */
.fp-grid {
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(59,130,246,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(59,130,246,.025) 1px,transparent 1px);
  background-size:80px 80px;
}

/* ── CARD ── */
.fp-card {
  position:relative; z-index:1;
  width:100%; max-width:420px;
  background:var(--s2);
  border:1px solid var(--border);
  border-radius:28px; overflow:hidden;
  animation:fp-fadeUp .6s cubic-bezier(.22,1,.36,1) both;
  box-shadow:0 40px 80px rgba(0,0,0,.55), 0 0 0 1px rgba(59,130,246,.05);
}

/* top beam — mirrors .sl-hero-beam */
.fp-card::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:1px; z-index:2;
  background:linear-gradient(90deg,transparent 0%,var(--blue) 45%,var(--cyan) 55%,transparent 100%);
  animation:fp-beam 5s ease-in-out 1s both;
}

/* ── HEADER ── */
.fp-head {
  padding:36px 36px 28px; text-align:center;
  background:var(--s1);
  border-bottom:1px solid var(--border);
  position:relative; overflow:hidden;
}
.fp-head::after {
  content:'';
  position:absolute; top:-40px; right:-40px;
  width:160px; height:160px; border-radius:50%;
  background:radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 65%);
  pointer-events:none;
}

/* logo — matches navbar brand */
.fp-logo {
  display:inline-flex; align-items:center; gap:10px; margin-bottom:20px;
}
.fp-logo-icon {
  width:42px; height:42px; border-radius:50%;
  background:rgba(59,130,246,.1);
  border:1px solid rgba(59,130,246,.25);
  display:flex; align-items:center; justify-content:center;
}
.fp-logo-icon svg { width:22px; height:22px; display:block; }
.fp-logo-text {
  font-family:var(--font-body);
  font-size:21px; font-weight:700; color:var(--text); letter-spacing:.01em;
}
.fp-logo-text em { font-style:normal; color:var(--blue); }

/* title with shimmer italic */
.fp-title {
  font-family:var(--font-heading);
  font-size:clamp(22px,5vw,30px);
  font-weight:300; color:var(--text);
  line-height:1.1; margin-bottom:6px;
  letter-spacing:-.02em;
}
.fp-title em {
  font-style:italic; font-weight:300;
  background:linear-gradient(105deg,var(--blue) 25%,var(--cyan) 50%,var(--blue) 75%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  background-clip:text;
  animation:fp-shimmer 4s linear infinite;
}
.fp-sub {
  font-size:13px; color:var(--muted);
  font-weight:400; font-family:var(--font-body);
}

/* ── STEP INDICATORS ── */
.fp-steps {
  display:flex; align-items:center; justify-content:center; margin-top:22px;
}
.fp-step { display:flex; flex-direction:column; align-items:center; gap:5px; }
.fp-step-circle {
  width:30px; height:30px; border-radius:50%;
  background:var(--s3); border:1px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  font-size:12px; color:var(--muted); font-weight:500;
  font-family:var(--font-body);
  transition:all .35s cubic-bezier(.34,1.56,.64,1);
}
.fp-step.active .fp-step-circle {
  background:rgba(59,130,246,.12);
  border-color:var(--blue); color:var(--blue);
  box-shadow:0 0 0 4px rgba(59,130,246,.12);
}
.fp-step.done .fp-step-circle {
  background:rgba(74,222,128,.1);
  border-color:rgba(74,222,128,.35); color:var(--success);
}
.fp-step-lbl {
  font-size:9px; letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted); font-family:var(--font-body); transition:color .3s;
}
.fp-step.active .fp-step-lbl { color:var(--blue); }
.fp-step.done   .fp-step-lbl { color:rgba(74,222,128,.7); }
.fp-step-line {
  width:52px; height:1px;
  background:var(--border);
  margin:0 6px; margin-bottom:18px; transition:background .4s;
}
.fp-step-line.done {
  background:linear-gradient(90deg,rgba(74,222,128,.35),rgba(59,130,246,.35));
}

/* ── BODY ── */
.fp-body { padding:30px 36px 34px; }
.fp-panel { display:none; }
.fp-panel.active { display:block; animation:fp-slideIn .3s ease both; }

/* ── ALERT ── */
.fp-alert {
  display:none; align-items:center; gap:8px;
  padding:11px 14px; border-radius:10px;
  font-size:12px; margin-bottom:18px;
  font-family:var(--font-body);
  animation:fp-slideIn .25s ease both;
}
.fp-alert.show { display:flex; }
.fp-alert.err {
  background:rgba(248,113,113,.08);
  border:1px solid rgba(248,113,113,.25); color:var(--danger);
}
.fp-alert.ok {
  background:rgba(74,222,128,.07);
  border:1px solid rgba(74,222,128,.2); color:var(--success);
}
.fp-alert svg { width:13px; height:13px; flex-shrink:0; }

/* ── FIELDS ── */
.fp-field { margin-bottom:16px; }
.fp-lbl {
  font-size:11px; letter-spacing:.1em; text-transform:uppercase;
  color:var(--muted); margin-bottom:7px; display:block;
  font-family:var(--font-body);
}

/* input wrap — mirrors navbar search bar style */
.fp-input-wrap {
  background:rgba(255,255,255,.04);
  border:1px solid var(--border);
  border-radius:14px;
  display:flex; align-items:center; overflow:hidden;
  transition:border-color .22s, box-shadow .22s, background .22s;
}
.fp-input-wrap:hover {
  border-color:rgba(59,130,246,.3);
  background:rgba(255,255,255,.05);
}
.fp-input-wrap:focus-within {
  border-color:var(--blue);
  box-shadow:0 0 0 3px rgba(59,130,246,.12);
  background:rgba(255,255,255,.05);
}
.fp-input-wrap:focus-within .fp-icon { color:var(--blue); }

.fp-icon {
  width:48px; display:flex; align-items:center; justify-content:center;
  color:var(--muted); flex-shrink:0; transition:color .2s;
}
.fp-icon svg { width:15px; height:15px; }

.fp-input {
  flex:1; background:transparent; border:none; outline:none;
  padding:15px 14px 15px 0;
  font-size:14px; color:var(--text); font-family:var(--font-body);
}
.fp-input::placeholder { color:var(--muted); }

.fp-eye {
  width:46px; display:flex; align-items:center; justify-content:center;
  color:var(--muted); cursor:pointer; flex-shrink:0; transition:color .2s;
}
.fp-eye svg { width:16px; height:16px; }
.fp-eye:hover { color:var(--blue); }

/* OTP large input */
.fp-otp-big {
  text-align:center; letter-spacing:12px;
  font-size:26px; font-family:var(--font-heading); font-weight:300;
}

/* ── PASSWORD STRENGTH ── */
.fp-strength { margin-top:8px; display:none; }
.fp-strength.show { display:block; }
.fp-strength-bar { display:flex; gap:4px; margin-bottom:4px; }
.fp-strength-seg {
  flex:1; height:3px; border-radius:999px;
  background:rgba(255,255,255,.08); transition:background .3s;
}
.fp-strength-lbl {
  font-size:10px; color:var(--muted);
  letter-spacing:.06em; font-family:var(--font-body);
}

/* ── BUTTON — mirrors .sl-btn-primary ── */
.fp-btn {
  width:100%; padding:16px 0;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#fff; border:none; border-radius:999px;
  font-size:14px; font-weight:600; letter-spacing:.04em;
  font-family:var(--font-body); cursor:pointer; margin-top:8px;
  display:flex; align-items:center; justify-content:center; gap:8px;
  transition:transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.fp-btn:hover {
  transform:translateY(-3px);
  box-shadow:0 12px 32px rgba(59,130,246,.4);
  filter:brightness(1.08);
}
.fp-btn:active  { transform:scale(.97); box-shadow:none; }
.fp-btn:disabled {
  opacity:.5; cursor:not-allowed;
  transform:none; box-shadow:none; filter:none;
}

/* ── RESEND ── */
.fp-resend {
  text-align:center; margin-top:12px;
  font-size:12px; color:var(--muted); font-family:var(--font-body);
}
.fp-link {
  color:var(--blue); cursor:pointer; transition:color .2s; font-family:var(--font-body);
}
.fp-link:hover { color:var(--cyan); }

/* OTP email display */
.fp-otp-email {
  text-align:center; font-size:14px;
  color:var(--blue); font-weight:500; margin-bottom:20px;
  font-family:var(--font-body);
}

/* ── SUCCESS STATE ── */
.fp-success-icon {
  width:72px; height:72px; border-radius:50%;
  background:rgba(74,222,128,.1);
  border:1px solid rgba(74,222,128,.3);
  display:flex; align-items:center; justify-content:center;
  margin:0 auto 20px;
  animation:fp-checkBounce .5s cubic-bezier(.34,1.56,.64,1) both;
}
.fp-success-icon svg { width:32px; height:32px; color:var(--success); }

/* success CTA — mirrors .sl-btn-primary */
.fp-success-cta {
  display:inline-flex; align-items:center; gap:8px;
  padding:14px 32px;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#fff; border-radius:999px;
  font-size:14px; font-weight:600; font-family:var(--font-body);
  transition:transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.fp-success-cta:hover {
  color:#fff; transform:translateY(-3px);
  box-shadow:0 10px 30px rgba(59,130,246,.4);
  filter:brightness(1.08);
}

/* ── FOOTER LINK ── */
.fp-footer {
  text-align:center; margin-top:20px;
  font-size:13px; color:var(--muted); font-family:var(--font-body);
}
.fp-footer a {
  color:var(--blue); font-weight:600;
  border-bottom:1px solid rgba(59,130,246,.25);
  padding-bottom:1px; transition:color .2s, border-color .2s;
}
.fp-footer a:hover { color:var(--cyan); border-color:var(--cyan); }

/* ── TRUST BAR — mirrors .sl-trust-ribbon ── */
.fp-trust {
  display:flex; align-items:center; justify-content:center; gap:18px;
  padding:14px 36px 18px;
  border-top:1px solid var(--border);
  flex-wrap:wrap;
  background:var(--s1);
}
.fp-trust-item {
  display:flex; align-items:center; gap:5px;
  font-size:10px; color:var(--muted); letter-spacing:.06em;
  font-family:var(--font-body);
}
.fp-trust-item svg { width:12px; height:12px; color:var(--cyan); }

/* ── RESPONSIVE ── */
@media (max-width:480px) {
  .fp-page { padding:0; }
  .fp-card {
    border-radius:0; min-height:100vh;
    border:none; max-width:100%;
    box-shadow:none; animation:none;
  }
  .fp-head { padding:28px 20px 22px; }
  .fp-body { padding:24px 20px 28px; }
  .fp-trust { padding:14px 20px 18px; }
}

@media (prefers-reduced-motion:reduce) {
  .fp-orb-1, .fp-orb-2 { animation:none; }
  .fp-card::before      { animation:none; }
  .fp-title em          { animation:none; }
  .fp-card              { animation:none; }
}
</style>


<div class="fp-page">
  <div class="fp-orb fp-orb-1" aria-hidden="true"></div>
  <div class="fp-orb fp-orb-2" aria-hidden="true"></div>
  <div class="fp-grid"         aria-hidden="true"></div>

  <div class="fp-card">

    <!-- ══ HEADER ════════════════════════════════════════ -->
    <div class="fp-head">
      <div class="fp-logo">
        <div class="fp-logo-icon">
          <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 2L25 8.5V19.5L14 26L3 19.5V8.5L14 2Z" fill="#3B82F6" opacity="0.18"/>
            <path d="M14 2L25 8.5V19.5L14 26L3 19.5V8.5L14 2Z" stroke="#3B82F6" stroke-width="1.2"/>
            <path d="M9 16.5C9 13.46 11.24 11 14 11C16.76 11 19 13.46 19 16.5"
                  stroke="#06B6D4" stroke-width="1.4" stroke-linecap="round"/>
            <circle cx="14" cy="10" r="1.8" fill="#3B82F6"/>
          </svg>
        </div>
        <span class="fp-logo-text">Stay<em>Scape</em></span>
      </div>
      <h1 class="fp-title" id="fpTitle">Reset your <em>password</em></h1>
      <p class="fp-sub"    id="fpSub">Enter your email to receive a verification code</p>

      <!-- step indicators -->
      <div class="fp-steps">
        <div class="fp-step active" id="step1">
          <div class="fp-step-circle">1</div>
          <span class="fp-step-lbl">Email</span>
        </div>
        <div class="fp-step-line" id="line1"></div>
        <div class="fp-step" id="step2">
          <div class="fp-step-circle">2</div>
          <span class="fp-step-lbl">Verify</span>
        </div>
        <div class="fp-step-line" id="line2"></div>
        <div class="fp-step" id="step3">
          <div class="fp-step-circle">3</div>
          <span class="fp-step-lbl">Reset</span>
        </div>
      </div>
    </div>

    <!-- ══ BODY ═══════════════════════════════════════════ -->
    <div class="fp-body">

      <!-- shared alert -->
      <div class="fp-alert" id="fpAlert">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <circle cx="12" cy="16" r=".5" fill="currentColor" stroke="none"/>
        </svg>
        <span id="fpAlertTxt"></span>
      </div>

      <!-- ══ STEP 1: EMAIL ══ -->
      <div class="fp-panel active" id="panel1">
        <div class="fp-field">
          <label class="fp-lbl">Email address</label>
          <div class="fp-input-wrap">
            <span class="fp-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.8" stroke-linecap="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input class="fp-input" type="email" id="fp-email"
                   placeholder="your@email.com" autocomplete="email">
          </div>
        </div>

        <button class="fp-btn" id="btn1" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" width="15" height="15">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
          Send Verification Code
        </button>

        <p class="fp-footer">Remember your password? <a href="/login">Sign in</a></p>
      </div>

      <!-- ══ STEP 2: OTP ══ -->
      <div class="fp-panel" id="panel2">
        <p style="text-align:center;font-size:13px;color:var(--muted);margin-bottom:5px;font-family:var(--font-body);">
          Code sent to
        </p>
        <p class="fp-otp-email" id="fpEmailDisplay"></p>

        <div class="fp-field">
          <label class="fp-lbl">Verification code</label>
          <div class="fp-input-wrap">
            <span class="fp-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.8" stroke-linecap="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </span>
            <input class="fp-input fp-otp-big" type="text" id="fp-otp"
                   placeholder="• • • • • •" maxlength="6"
                   inputmode="numeric" autocomplete="one-time-code">
          </div>
        </div>

        <button class="fp-btn" id="btn2" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" width="15" height="15">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Verify Code
        </button>

        <div class="fp-resend">
          Didn't receive it?
          <span class="fp-link" id="resendBtn">Resend</span>
          <span id="resendTimer" style="display:none;color:var(--muted)"></span>
        </div>

        <p style="text-align:center;margin-top:14px;font-size:11px;color:var(--muted);font-family:var(--font-body);">
          Wrong email?
          <span class="fp-link" id="backBtn1">Go back</span>
        </p>
      </div>

      <!-- ══ STEP 3: NEW PASSWORD ══ -->
      <div class="fp-panel" id="panel3">

        <div class="fp-field">
          <label class="fp-lbl">New password</label>
          <div class="fp-input-wrap">
            <span class="fp-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.8" stroke-linecap="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </span>
            <input class="fp-input" type="password" id="fp-password"
                   placeholder="Create new password" autocomplete="new-password">
            <span class="fp-eye" id="eyeToggle1" role="button" aria-label="Toggle password">
              <svg id="eyeIcon1" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </span>
          </div>
          <!-- strength meter -->
          <div class="fp-strength" id="strengthMeter">
            <div class="fp-strength-bar">
              <div class="fp-strength-seg" id="seg1"></div>
              <div class="fp-strength-seg" id="seg2"></div>
              <div class="fp-strength-seg" id="seg3"></div>
              <div class="fp-strength-seg" id="seg4"></div>
            </div>
            <span class="fp-strength-lbl" id="strengthLbl"></span>
          </div>
        </div>

        <div class="fp-field">
          <label class="fp-lbl">Confirm password</label>
          <div class="fp-input-wrap">
            <span class="fp-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.8" stroke-linecap="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </span>
            <input class="fp-input" type="password" id="fp-confirm"
                   placeholder="Confirm new password" autocomplete="new-password">
            <span class="fp-eye" id="eyeToggle2" role="button" aria-label="Toggle confirm password">
              <svg id="eyeIcon2" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </span>
          </div>
        </div>

        <button class="fp-btn" id="btn3" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" width="15" height="15">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Reset Password
        </button>
      </div>

      <!-- ══ STEP 4: SUCCESS ══ -->
      <div class="fp-panel" id="panel4">
        <div style="text-align:center;padding:10px 0 20px;">
          <div class="fp-success-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h2 style="font-family:var(--font-heading);font-size:26px;font-weight:300;color:var(--text);margin-bottom:8px;letter-spacing:-.02em;">
            Password <em style="font-style:italic;color:var(--cyan)">reset!</em>
          </h2>
          <p style="font-size:13px;color:var(--muted);margin-bottom:28px;line-height:1.7;font-family:var(--font-body);">
            Your password has been updated successfully.<br>
            You can now sign in with your new password.
          </p>
          <a href="/login" class="fp-success-cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" width="15" height="15">
              <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/>
              <polyline points="10 17 15 12 10 7"/>
              <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Sign in now
          </a>
        </div>
      </div>

    </div><!-- /.fp-body -->

    <!-- ══ TRUST BAR ══════════════════════════════════════ -->
    <div class="fp-trust">
      <div class="fp-trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        SSL secured
      </div>
      <div class="fp-trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="9 12 11.5 14.5 15.5 9.5"/>
        </svg>
        Trusted platform
      </div>
    </div>

  </div><!-- /.fp-card -->
</div><!-- /.fp-page -->


<script>
(function () {
  'use strict';

  /* ── State ── */
  var currentEmail   = '';
  var verifiedOtp    = '';
  var resendInterval = null;

  /* ── Alert ── */
  var alertBox = document.getElementById('fpAlert');
  var alertTxt = document.getElementById('fpAlertTxt');
  function showAlert(msg, type) {
    alertTxt.textContent = msg;
    alertBox.className = 'fp-alert show ' + (type || 'err');
  }
  function hideAlert() { alertBox.classList.remove('show'); }

  /* ── Spinner HTML (reused) ── */
  var spinnerHtml =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"' +
    ' stroke-linecap="round" width="15" height="15"' +
    ' style="animation:fp-spin .8s linear infinite"><path d="M21 12a9 9 0 11-3.2-6.9"/></svg>';

  /* ── Step navigation ── */
  var titles = [
    'Reset your <em>password</em>',
    'Verify your <em>email</em>',
    'New <em>password</em>',
    'All <em>done!</em>'
  ];
  var subs = [
    'Enter your email to receive a verification code',
    'Enter the 6-digit code sent to your inbox',
    'Choose a strong new password',
    'Your account is secured'
  ];

  function goStep(n) {
    [1,2,3,4].forEach(function (i) {
      var panel = document.getElementById('panel'+i);
      if (panel) panel.classList.toggle('active', i === n);
    });
    [1,2,3].forEach(function (i) {
      var s      = document.getElementById('step'+i);
      if (!s) return;
      var circle = s.querySelector('.fp-step-circle');
      s.classList.remove('active','done');
      if (i < n) {
        s.classList.add('done');
        circle.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor"' +
          ' stroke-width="2.5" stroke-linecap="round" width="12" height="12">' +
          '<polyline points="20 6 9 17 4 12"/></svg>';
      } else {
        if (i === n) s.classList.add('active');
        circle.textContent = i;
      }
    });
    [1,2].forEach(function (i) {
      var l = document.getElementById('line'+i);
      if (l) l.classList.toggle('done', i < n);
    });
    document.getElementById('fpTitle').innerHTML = titles[n-1];
    document.getElementById('fpSub').textContent = subs[n-1];
    hideAlert();
  }

  /* ── Resend timer ── */
  function startResendTimer(seconds) {
    var rBtn   = document.getElementById('resendBtn');
    var rTimer = document.getElementById('resendTimer');
    var rem = seconds;
    rBtn.style.display   = 'none';
    rTimer.style.display = 'inline';
    clearInterval(resendInterval);
    resendInterval = setInterval(function () {
      rem--;
      rTimer.textContent = 'Resend in ' + rem + 's';
      if (rem <= 0) {
        clearInterval(resendInterval);
        rBtn.style.display   = 'inline';
        rTimer.style.display = 'none';
      }
    }, 1000);
  }

  /* ══ STEP 1: Send OTP ══ */
  var btn1    = document.getElementById('btn1');
  var btn1Def =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"' +
    ' stroke-linecap="round" width="15" height="15"><line x1="22" y1="2" x2="11" y2="13"/>' +
    '<polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>Send Verification Code';

  btn1.addEventListener('click', async function () {
    var email = document.getElementById('fp-email').value.trim();
    if (!email) { showAlert('Please enter your email address'); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showAlert('Please enter a valid email'); return;
    }

    btn1.disabled  = true;
    btn1.innerHTML = spinnerHtml + 'Sending\u2026';

    try {
      var res  = await fetch('/forgot-password', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ email:email })
      });
      var data = await res.json();

      if (data.success) {
        currentEmail = email;
        document.getElementById('fpEmailDisplay').textContent = email;
        goStep(2);
        startResendTimer(60);
      } else {
        showAlert(data.message || 'Failed to send code');
        btn1.disabled  = false;
        btn1.innerHTML = btn1Def;
      }
    } catch (e) {
      showAlert('Something went wrong. Please try again.');
      btn1.disabled  = false;
      btn1.innerHTML = btn1Def;
    }
  });

  /* ══ STEP 2: Verify OTP ══ */
  var btn2    = document.getElementById('btn2');
  var btn2Def =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"' +
    ' stroke-linecap="round" width="15" height="15"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' +
    '</svg>Verify Code';

  async function verifyCode() {
    var otp = document.getElementById('fp-otp').value.trim();
    if (otp.length !== 6) { showAlert('Please enter the 6-digit code'); return; }

    btn2.disabled  = true;
    btn2.innerHTML = spinnerHtml + 'Verifying\u2026';

    /* Store OTP locally; real verification happens at /reset-password */
    verifiedOtp = otp;
    showAlert('Code accepted! Set your new password.', 'ok');
    setTimeout(function () { goStep(3); }, 800);
  }

  btn2.addEventListener('click', verifyCode);
  document.getElementById('fp-otp').addEventListener('input', function () {
    if (this.value.length === 6) verifyCode();
  });

  /* Resend */
  document.getElementById('resendBtn').addEventListener('click', async function () {
    this.style.display = 'none';
    try {
      var res  = await fetch('/forgot-password', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ email:currentEmail })
      });
      var data = await res.json();
      if (data.success) {
        showAlert('New code sent!', 'ok');
        document.getElementById('fp-otp').value = '';
        startResendTimer(60);
      } else {
        showAlert(data.message || 'Failed to resend');
        this.style.display = 'inline';
      }
    } catch (e) {
      showAlert('Failed to resend');
      this.style.display = 'inline';
    }
  });

  /* Back */
  document.getElementById('backBtn1').addEventListener('click', function () {
    clearInterval(resendInterval);
    document.getElementById('fp-otp').value = '';
    goStep(1);
    btn1.disabled  = false;
    btn1.innerHTML = btn1Def;
  });

  /* ══ STEP 3: Reset Password ══ */
  var btn3    = document.getElementById('btn3');
  var btn3Def =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"' +
    ' stroke-linecap="round" width="15" height="15"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' +
    '</svg>Reset Password';

  /* Strength meter */
  var COLORS = ['rgba(248,113,113,.7)','#FBBF24','#34D399','#4ADE80'];
  var LABELS = ['Weak','Fair','Good','Strong'];
  function getStrength(v) {
    if (!v) return 0;
    var s = 0;
    if (v.length >= 8)           s++;
    if (/[A-Z]/.test(v))         s++;
    if (/[0-9]/.test(v))         s++;
    if (/[^A-Za-z0-9]/.test(v))  s++;
    return Math.min(4, Math.max(v.length >= 8 ? 1 : 0, s));
  }

  document.getElementById('fp-password').addEventListener('input', function () {
    var meter = document.getElementById('strengthMeter');
    var lbl   = document.getElementById('strengthLbl');
    if (!this.value) { meter.classList.remove('show'); return; }
    meter.classList.add('show');
    var s = getStrength(this.value);
    [1,2,3,4].forEach(function (i) {
      document.getElementById('seg'+i).style.background =
        i <= s ? COLORS[s-1] : 'rgba(255,255,255,.08)';
    });
    lbl.textContent = s > 0 ? LABELS[s-1] + ' password' : 'Too short';
    lbl.style.color = s > 0 ? COLORS[s-1] : 'var(--muted)';
  });

  /* Eye toggles */
  function setupEye(toggleId, iconId, inputId) {
    var tog  = document.getElementById(toggleId);
    var inp  = document.getElementById(inputId);
    var icon = document.getElementById(iconId);
    var open = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    var off  = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>' +
               '<path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>' +
               '<line x1="1" y1="1" x2="23" y2="23"/>';
    tog.addEventListener('click', function () {
      var showing = inp.type === 'text';
      inp.type = showing ? 'password' : 'text';
      icon.innerHTML = showing ? open : off;
    });
  }
  setupEye('eyeToggle1', 'eyeIcon1', 'fp-password');
  setupEye('eyeToggle2', 'eyeIcon2', 'fp-confirm');

  btn3.addEventListener('click', async function () {
    var password = document.getElementById('fp-password').value;
    var confirm  = document.getElementById('fp-confirm').value;

    if (password.length < 8)          { showAlert('Password must be at least 8 characters'); return; }
    if (!/[A-Z]/.test(password))      { showAlert('Password must contain at least one uppercase letter'); return; }
    if (!/[0-9]/.test(password))      { showAlert('Password must contain at least one number'); return; }
    if (!/[^A-Za-z0-9]/.test(password)){ showAlert('Password must contain at least one special character'); return; }
    if (password !== confirm)          { showAlert('Passwords do not match'); return; }

    btn3.disabled  = true;
    btn3.innerHTML = spinnerHtml + 'Resetting\u2026';

    try {
      var res  = await fetch('/reset-password', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ email:currentEmail, otp:verifiedOtp, password:password })
      });
      var data = await res.json();

      if (data.success) {
        goStep(4);
      } else {
        showAlert(data.message || 'Failed to reset password');
        btn3.disabled  = false;
        btn3.innerHTML = btn3Def;
      }
    } catch (e) {
      showAlert('Something went wrong. Please try again.');
      btn3.disabled  = false;
      btn3.innerHTML = btn3Def;
    }
  });

})();
</script>
