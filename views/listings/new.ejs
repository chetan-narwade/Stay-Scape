<% layout("/layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   NEW LISTING PAGE — blue/cyan palette, Inter font
═══════════════════════════════════════════════════════════ */

@keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
@keyframes spin   { to{transform:rotate(360deg)} }

/* ── PAGE ── */
.np-page {
  min-height: 100vh;
  display: flex; align-items: flex-start; justify-content: center;
  padding: 48px 20px 80px;
  position: relative; overflow: hidden;
}
.np-page::before {
  content: ''; position: fixed; top: -160px; right: -100px;
  width: 480px; height: 480px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.06) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}
.np-page::after {
  content: ''; position: fixed; bottom: -100px; left: -80px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(6,182,212,.04) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}

/* ── CARD ── */
.np-card {
  position: relative; z-index: 1;
  width: 100%; max-width: 680px;
  background: var(--s2);
  border: 1px solid var(--border);
  border-radius: 24px; overflow: hidden;
  animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both;
  box-shadow: 0 28px 70px rgba(0,0,0,.45);
}

/* ── HEADER ── */
.np-head {
  padding: 34px 38px 28px;
  background: var(--s1);
  border-bottom: 1px solid var(--border);
  position: relative; overflow: hidden;
}
.np-head::before {
  content: ''; position: absolute; top: -80px; right: -60px;
  width: 240px; height: 240px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.07) 0%, transparent 65%);
  pointer-events: none;
}
.np-head::after {
  content: ''; position: absolute; bottom: -40px; left: -40px;
  width: 160px; height: 160px; border-radius: 50%;
  background: radial-gradient(circle, rgba(6,182,212,.04) 0%, transparent 65%);
  pointer-events: none;
}

.np-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--blue); font-weight: 600; margin-bottom: 10px;
}
.np-eyebrow::before {
  content: ''; display: block; width: 20px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}
.np-head-title {
  font-family: var(--font-heading);
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 300; color: var(--text); line-height: 1.1;
  position: relative; z-index: 1;
}
.np-head-title em { font-style: italic; color: var(--cyan); }
.np-head-sub {
  font-size: 13px; color: var(--muted);
  margin-top: 8px; position: relative; z-index: 1;
}

/* progress bar */
.np-progress {
  display: flex; gap: 0; margin-top: 22px; position: relative; z-index: 1;
}
.np-prog-step {
  flex: 1; height: 3px;
  background: rgba(255,255,255,.07);
  transition: background .4s;
}
.np-prog-step:first-child { border-radius: 999px 0 0 999px; }
.np-prog-step:last-child  { border-radius: 0 999px 999px 0; }
.np-prog-step.done   { background: var(--blue); }
.np-prog-step.active { background: linear-gradient(90deg, var(--blue), var(--cyan)); }
.np-prog-labels {
  display: flex; justify-content: space-between; margin-top: 6px;
}
.np-prog-lbl {
  font-size: 9px; letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); transition: color .3s; flex: 1; text-align: center;
}
.np-prog-lbl.active { color: var(--blue); }
.np-prog-lbl.done   { color: rgba(59,130,246,.5); }

/* ── FORM BODY ── */
.np-body { padding: 28px 38px 10px; }

/* section label */
.np-sec {
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--blue); font-weight: 600;
  display: flex; align-items: center; gap: 8px;
  margin: 24px 0 16px;
}
.np-sec:first-child { margin-top: 0; }
.np-sec::before {
  content: ''; display: block; width: 16px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}
.np-sec::after { content: ''; flex: 1; height: 1px; background: var(--border); }

/* field wrapper */
.np-field { margin-bottom: 16px; }
.np-lbl {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); font-weight: 500; margin-bottom: 7px;
}
.np-lbl-req { font-size: 9px; letter-spacing: .06em; text-transform: uppercase; color: rgba(239,68,68,.6); }
.np-lbl-opt { font-size: 9px; letter-spacing: .06em; text-transform: uppercase; color: rgba(156,163,176,.5); }

/* inputs */
.np-input, .np-textarea, .np-select {
  width: 100%; background: var(--s3);
  border: 1px solid var(--border); border-radius: 10px;
  padding: 12px 15px; font-size: 14px; color: var(--text);
  outline: none;
  transition: border-color .22s, box-shadow .22s, background .22s;
  -webkit-appearance: none;
}
.np-input::placeholder, .np-textarea::placeholder { color: var(--muted); }
.np-input:focus, .np-textarea:focus, .np-select:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px var(--glow-blue);
  background: rgba(28,28,40,.9);
}
.np-input:hover:not(:focus),
.np-textarea:hover:not(:focus),
.np-select:hover:not(:focus) { border-color: rgba(59,130,246,.3); }
.np-textarea { resize: vertical; min-height: 110px; line-height: 1.7; }
.np-select option { background: var(--s2); color: var(--text); }

/* grid helpers */
.np-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.np-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* price input */
.np-price-wrap { position: relative; }
.np-price-pre {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  font-size: 16px; font-weight: 700; color: var(--blue);
  pointer-events: none; z-index: 1;
}
.np-price-inp { padding-left: 30px; }

/* char count */
.np-char { font-size: 10px; color: var(--muted); text-align: right; margin-top: 4px; }
.np-char.warn { color: #FBBF24; }
.np-char.over { color: var(--danger); }

/* ── CATEGORY CARDS ── */
.np-cats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}
.np-cat-opt { position: relative; }
.np-cat-opt input[type=radio] { position: absolute; opacity: 0; width: 0; height: 0; }
.np-cat-lbl {
  display: flex; flex-direction: column; align-items: center; gap: 7px;
  padding: 14px 8px;
  background: var(--s3); border: 1px solid var(--border); border-radius: 12px;
  cursor: pointer; text-align: center;
  transition: border-color .2s, background .2s, transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
}
.np-cat-lbl:hover {
  border-color: rgba(59,130,246,.3);
  background: rgba(28,28,40,.9);
  transform: translateY(-2px);
}
.np-cat-icon {
  width: 36px; height: 36px; border-radius: 9px;
  background: var(--s2); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--muted); transition: background .2s, border-color .2s, color .2s;
}
.np-cat-icon svg { width: 16px; height: 16px; }
.np-cat-name {
  font-size: 11px; color: var(--muted);
  letter-spacing: .04em; transition: color .2s;
}
.np-cat-opt input:checked + .np-cat-lbl {
  border-color: var(--blue);
  background: rgba(59,130,246,.08);
  transform: translateY(-2px);
  box-shadow: 0 0 0 2px rgba(59,130,246,.15);
}
.np-cat-opt input:checked + .np-cat-lbl .np-cat-icon {
  background: rgba(59,130,246,.1);
  border-color: rgba(59,130,246,.3);
  color: var(--blue);
}
.np-cat-opt input:checked + .np-cat-lbl .np-cat-name { color: var(--blue); font-weight: 600; }

/* ── AMENITY CHECKBOXES ── */
.np-amenities {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.np-amen-opt { position: relative; }
.np-amen-opt input[type=checkbox] { position: absolute; opacity: 0; width: 0; height: 0; }
.np-amen-lbl {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 12px;
  background: var(--s3); border: 1px solid var(--border); border-radius: 10px;
  cursor: pointer; font-size: 12px; color: var(--muted); letter-spacing: .04em;
  transition: border-color .18s, background .18s, color .18s;
  min-height: 44px;
}
.np-amen-lbl svg { width: 13px; height: 13px; color: var(--muted); flex-shrink: 0; transition: color .18s; }
.np-amen-lbl:hover { border-color: rgba(59,130,246,.3); color: var(--text); }
.np-amen-opt input:checked + .np-amen-lbl {
  border-color: var(--blue);
  background: rgba(59,130,246,.08);
  color: var(--blue);
}
.np-amen-opt input:checked + .np-amen-lbl svg { color: var(--blue); }
/* checkmark */
.np-amen-check {
  width: 16px; height: 16px; border-radius: 4px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.04);
  margin-left: auto; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all .18s;
}
.np-amen-check svg { width: 10px; height: 10px; color: var(--blue); display: none; }
.np-amen-opt input:checked + .np-amen-lbl .np-amen-check {
  background: rgba(59,130,246,.1);
  border-color: var(--blue);
}
.np-amen-opt input:checked + .np-amen-lbl .np-amen-check svg { display: block; }

/* ── COUNTER INPUTS ── */
.np-counter-wrap {
  display: flex; align-items: center;
  background: var(--s3); border: 1px solid var(--border);
  border-radius: 10px; overflow: hidden;
  transition: border-color .22s;
}
.np-counter-wrap:focus-within { border-color: var(--blue); box-shadow: 0 0 0 3px var(--glow-blue); }
.np-counter-btn {
  width: 44px; height: 46px; background: transparent; border: none;
  color: var(--muted); font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .18s, color .18s; flex-shrink: 0;
}
.np-counter-btn:hover { background: rgba(59,130,246,.08); color: var(--blue); }
.np-counter-inp {
  flex: 1; background: transparent; border: none; outline: none;
  text-align: center; font-size: 16px; font-weight: 700;
  color: var(--text); width: 100%; min-width: 0;
}
.np-counter-inp::-webkit-outer-spin-button,
.np-counter-inp::-webkit-inner-spin-button { -webkit-appearance: none; }
.np-counter-sep { width: 1px; height: 28px; background: var(--border); }

/* ── UPLOAD ZONE ── */
.np-upload {
  position: relative;
  border: 1px dashed rgba(59,130,246,.25); border-radius: 10px;
  background: var(--s3); padding: 28px 20px; text-align: center;
  cursor: pointer; transition: border-color .22s, background .22s;
}
.np-upload:hover, .np-upload.drag {
  border-color: var(--blue);
  background: rgba(59,130,246,.06);
}
.np-upload input[type=file] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer;
  width: 100%; height: 100%;
}
.np-upload-icon {
  width: 44px; height: 44px; border-radius: 12px;
  background: rgba(59,130,246,.08);
  border: 1px solid rgba(59,130,246,.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--blue); margin: 0 auto 12px;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1);
}
.np-upload:hover .np-upload-icon,
.np-upload.drag  .np-upload-icon { transform: scale(1.1) translateY(-2px); }
.np-upload-icon svg { width: 20px; height: 20px; }
.np-upload-title { font-size: 14px; color: var(--text); font-weight: 600; margin-bottom: 4px; }
.np-upload-sub   { font-size: 11px; color: var(--muted); }
.np-upload-chosen {
  display: none; margin-top: 10px; font-size: 12px; color: var(--success);
  align-items: center; justify-content: center; gap: 6px;
}
.np-upload-chosen svg { width: 14px; height: 14px; }
.np-img-preview {
  display: none; margin-top: 14px; border-radius: 10px;
  overflow: hidden; border: 1px solid var(--border); height: 180px;
}
.np-img-preview img { width: 100%; height: 100%; object-fit: cover; }

/* ── FOOTER ACTIONS ── */
.np-footer {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 22px 38px 30px;
  border-top: 1px solid var(--border); flex-wrap: wrap;
}
.np-cancel {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 11px 22px; background: transparent;
  border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
  font-size: 13px; color: var(--muted); cursor: pointer; text-decoration: none;
  transition: border-color .2s, color .2s, transform .2s cubic-bezier(.34,1.56,.64,1);
}
.np-cancel:hover {
  border-color: rgba(239,68,68,.35);
  color: var(--danger); transform: translateY(-1px);
}
.np-submit {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 32px;
  background: linear-gradient(135deg, var(--blue), var(--cyan));
  color: #fff; border: none; border-radius: 999px;
  font-size: 14px; font-weight: 600; letter-spacing: .02em;
  cursor: pointer; position: relative; overflow: hidden;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.np-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59,130,246,.35);
  filter: brightness(1.08);
}
.np-submit:active { transform: scale(.97); }
.np-submit:disabled { opacity: .5; cursor: not-allowed; transform: none; box-shadow: none; }

/* ── VALIDATION GLOW ── */
.np-input.valid, .np-textarea.valid {
  border-color: rgba(16,185,129,.4);
}
.np-input.invalid, .np-textarea.invalid {
  border-color: rgba(239,68,68,.4);
  box-shadow: 0 0 0 3px rgba(239,68,68,.08);
}

/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════ */

/* ── TABLET 768px ── */
@media (max-width: 768px) {
  .np-cats { grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .np-amenities { grid-template-columns: repeat(2, 1fr); }
  .np-row3 { grid-template-columns: 1fr 1fr; }
  .np-row3 .np-field:last-child { grid-column: span 2; }
}

/* ── MOBILE 640px ── */
@media (max-width: 640px) {
  .np-page { padding: 0 0 60px; }

  .np-card {
    border-radius: 0;
    border-left: none; border-right: none; border-top: none;
    max-width: 100%;
  }

  .np-head { padding: 24px 18px 20px; }
  .np-head-title { font-size: 24px; }
  .np-head-sub { font-size: 12px; }

  .np-body { padding: 20px 16px 8px; }

  .np-footer {
    padding: 16px 16px 24px;
    flex-direction: column;
  }
  .np-cancel, .np-submit {
    width: 100%; justify-content: center;
  }

  /* category: 4-col stays but tighter */
  .np-cats { grid-template-columns: repeat(4, 1fr); gap: 6px; }
  .np-cat-lbl { padding: 10px 4px; gap: 5px; }
  .np-cat-icon { width: 28px; height: 28px; border-radius: 7px; }
  .np-cat-icon svg { width: 14px; height: 14px; }
  .np-cat-name { font-size: 9px; }

  /* counters: single column */
  .np-row2 { grid-template-columns: 1fr; }
  .np-row3 { grid-template-columns: 1fr; }
  .np-row3 .np-field:last-child { grid-column: span 1; }

  /* amenities: 2-col */
  .np-amenities { grid-template-columns: 1fr 1fr; }
  .np-amen-lbl { font-size: 11px; padding: 9px 10px; gap: 6px; }

  /* inputs */
  .np-input, .np-textarea, .np-select { font-size: 16px; } /* prevent zoom on iOS */
  .np-counter-btn { width: 40px; height: 44px; }
  .np-counter-inp { font-size: 15px; }

  /* upload */
  .np-upload { padding: 22px 16px; }
  .np-upload-title { font-size: 13px; }
  .np-img-preview { height: 150px; }

  /* progress labels — shorter */
  .np-prog-lbl { font-size: 8px; letter-spacing: .05em; }
}

/* ── SMALL MOBILE 380px ── */
@media (max-width: 380px) {
  .np-head { padding: 20px 14px 18px; }
  .np-body { padding: 18px 14px 8px; }
  .np-footer { padding: 14px 14px 22px; }

  /* 2-col categories on tiny screens */
  .np-cats { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .np-cat-lbl { padding: 12px 8px; gap: 6px; }
  .np-cat-icon { width: 32px; height: 32px; }
  .np-cat-icon svg { width: 15px; height: 15px; }
  .np-cat-name { font-size: 10px; }

  /* amenities: 1-col on very small */
  .np-amenities { grid-template-columns: 1fr; }

  .np-prog-lbl { display: none; } /* hide labels on tiny, keep bars */
}
</style>


<div class="np-page">
<div class="np-card">

  <!-- ── HEADER ── -->
  <div class="np-head">
    <div class="np-eyebrow">Host your space</div>
    <h1 class="np-head-title">Create a new <em>listing</em></h1>
    <p class="np-head-sub">Share your property with travellers from around the world.</p>
    <div style="margin-top:22px;position:relative;z-index:1;">
      <div class="np-progress">
        <div class="np-prog-step done"></div>
        <div class="np-prog-step done"></div>
        <div class="np-prog-step active"></div>
        <div class="np-prog-step"></div>
        <div class="np-prog-step"></div>
      </div>
      <div class="np-prog-labels">
        <span class="np-prog-lbl done">Basics</span>
        <span class="np-prog-lbl done">Type</span>
        <span class="np-prog-lbl active">Details</span>
        <span class="np-prog-lbl">Pricing</span>
        <span class="np-prog-lbl">Photo</span>
      </div>
    </div>
  </div>

  <!-- ── FORM ── -->
  <form action="/listings" method="POST" enctype="multipart/form-data"
    novalidate id="newListingForm">

    <div class="np-body">

      <!-- ── SECTION 1: BASIC INFO ── -->
      <div class="np-sec">Basic information</div>

      <div class="np-field">
        <div class="np-lbl">Title <span class="np-lbl-req">Required</span></div>
        <input class="np-input" type="text" name="listing[title]" id="np-title"
          placeholder="e.g. Cosy Sea-View Villa in Goa"
          required maxlength="80" autocomplete="off">
        <div class="np-char" id="titleChar">0 / 80</div>
      </div>

      <div class="np-field">
        <div class="np-lbl">Description <span class="np-lbl-req">Required</span></div>
        <textarea class="np-textarea" name="listing[description]" id="np-desc"
          placeholder="Describe what makes your place special — amenities, surroundings, house rules…"
          required maxlength="800" rows="5"></textarea>
        <div class="np-char" id="descChar">0 / 800</div>
      </div>

      <!-- ── SECTION 2: PROPERTY TYPE ── -->
      <div class="np-sec">Property type</div>

      <div class="np-field">
        <input type="hidden" name="listing[category]" id="np-cat-val" value="">
        <div class="np-cats" id="catGrid">

          <div class="np-cat-opt">
            <input type="radio" name="_catUI" id="cat-villa" value="villa">
            <label class="np-cat-lbl" for="cat-villa">
              <div class="np-cat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                  <path d="M9 21V12h6v9"/>
                </svg>
              </div>
              <span class="np-cat-name">Villa</span>
            </label>
          </div>

          <div class="np-cat-opt">
            <input type="radio" name="_catUI" id="cat-flat" value="flat">
            <label class="np-cat-lbl" for="cat-flat">
              <div class="np-cat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <rect x="2" y="3" width="20" height="18" rx="2"/>
                  <path d="M8 3v18M16 3v18M2 9h20M2 15h20"/>
                </svg>
              </div>
              <span class="np-cat-name">Flat</span>
            </label>
          </div>

          <div class="np-cat-opt">
            <input type="radio" name="_catUI" id="cat-room" value="room">
            <label class="np-cat-lbl" for="cat-room">
              <div class="np-cat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <path d="M3 7h18v13H3z"/>
                  <path d="M3 7V4h18v3"/>
                  <path d="M9 13h6"/>
                </svg>
              </div>
              <span class="np-cat-name">Room</span>
            </label>
          </div>

          <div class="np-cat-opt">
            <input type="radio" name="_catUI" id="cat-hostel" value="hostel">
            <label class="np-cat-lbl" for="cat-hostel">
              <div class="np-cat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                  <path d="M3 21V7l9-4 9 4v14"/>
                  <path d="M12 21V11M7 21v-5h10v5"/>
                </svg>
              </div>
              <span class="np-cat-name">Hostel</span>
            </label>
          </div>

          <div class="np-cat-opt">
            <input type="radio" name="_catUI" id="cat-beach" value="beachfront">
            <label class="np-cat-lbl" for="cat-beach">
              <div class="np-cat-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
