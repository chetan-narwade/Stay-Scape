<script>
(function () {
  'use strict';

  /* ── char counters ── */
  function charCounter(id, ctId, max) {
    var el = document.getElementById(id);
    var ct = document.getElementById(ctId);
    if (!el || !ct) return;
    function upd() {
      var n = el.value.length;
      ct.textContent = n + ' / ' + max;
      ct.className = 'np-char' + (n > max ? ' over' : n > max * .85 ? ' warn' : '');
    }
    el.addEventListener('input', upd); upd();
  }
  charCounter('np-title', 'titleChar', 80);
  charCounter('np-desc',  'descChar',  800);

  /* ── category radio → hidden input ── */
  var catVal = document.getElementById('np-cat-val');
  document.querySelectorAll('input[name="_catUI"]').forEach(function (r) {
    r.addEventListener('change', function () {
      if (catVal) catVal.value = this.value;
    });
  });

  /* ── counter buttons ── */
  document.querySelectorAll('.np-counter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = document.getElementById(this.dataset.target);
      if (!inp) return;
      var op  = this.dataset.op;
      var min = Number(inp.min || 0);
      var max = Number(inp.max || 99);
      var v   = Number(inp.value) || 0;
      v = op === 'inc' ? Math.min(v + 1, max) : Math.max(v - 1, min);
      inp.value = v;
    });
  });

  /* ── file upload + drag & drop ── */
  var fileInput = document.getElementById('npFile');
  var fileNameEl = document.getElementById('npFileName');
  var fileText  = document.getElementById('npFileText');
  var uploadBox = document.getElementById('npUpload');
  var preview   = document.getElementById('npPreview');
  var previewImg = document.getElementById('npPreviewImg');

  function handleFile(file) {
    if (!file) return;
    fileText.textContent = file.name;
    fileNameEl.style.display = 'flex';
    uploadBox.style.borderColor = 'var(--blue)';
    uploadBox.style.background   = 'rgba(59,130,246,.06)';
    var reader = new FileReader();
    reader.onload = function (e) {
      previewImg.src = e.target.result;
      preview.style.display = 'block';
    };
    reader.readAsDataURL(file);
  }

  if (fileInput) {
    fileInput.addEventListener('change', function () {
      if (this.files && this.files[0]) handleFile(this.files[0]);
    });
  }
  if (uploadBox) {
    uploadBox.addEventListener('dragover', function (e) {
      e.preventDefault(); this.classList.add('drag');
    });
    ['dragleave', 'dragend'].forEach(function (ev) {
      uploadBox.addEventListener(ev, function () { this.classList.remove('drag'); });
    });
    uploadBox.addEventListener('drop', function (e) {
      e.preventDefault(); this.classList.remove('drag');
      var f = e.dataTransfer.files[0];
      if (f) { fileInput.files = e.dataTransfer.files; handleFile(f); }
    });
  }

  /* ── submit — spinner + validation ── */
  var form   = document.getElementById('newListingForm');
  var submit = document.getElementById('npSubmit');
  if (form) {
    form.addEventListener('submit', function (e) {
      if (!form.checkValidity()) {
        e.preventDefault(); e.stopPropagation();
        var first = form.querySelector(':invalid');
        if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
        /* shake invalid fields */
        form.querySelectorAll(':invalid').forEach(function (el) {
          el.classList.add('invalid');
          setTimeout(function () { el.classList.remove('invalid'); }, 1500);
        });
        return;
      }
      if (submit) {
        submit.disabled = true;
        submit.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="14" height="14" style="animation:spin .8s linear infinite"><path d="M21 12a9 9 0 11-3.2-6.9"/></svg>'
          + 'Publishing…';
      }
    });
  }

  /* ── inline validation on blur ── */
  document.querySelectorAll('.np-input, .np-textarea').forEach(function (inp) {
    inp.addEventListener('blur', function () {
      if (!this.required) return;
      if (this.value.trim()) {
        this.classList.remove('invalid'); this.classList.add('valid');
      } else {
        this.classList.remove('valid'); this.classList.add('invalid');
      }
    });
    inp.addEventListener('focus', function () {
      this.classList.remove('valid', 'invalid');
      this.style.borderColor = '';
    });
  });

})();
</script>
