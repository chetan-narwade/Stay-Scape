<% layout("/layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   EDIT LISTING PAGE — blue/cyan palette, Inter font
═══════════════════════════════════════════════════════════ */

@keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

/* ── PAGE ── */
.ep-page {
  min-height: 100vh;
  display: flex; align-items: flex-start; justify-content: center;
  padding: 48px 20px 80px;
  position: relative; overflow: hidden;
}
.ep-page::before {
  content: ''; position: fixed; top: -160px; right: -100px;
  width: 480px; height: 480px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.06) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}
.ep-page::after {
  content: ''; position: fixed; bottom: -100px; left: -80px;
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle, rgba(6,182,212,.04) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}

/* ── CARD ── */
.ep-card {
  position: relative; z-index: 1;
  width: 100%; max-width: 680px;
  background: var(--s2);
  border: 1px solid var(--border);
  border-radius: 22px; overflow: hidden;
  animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both;
  box-shadow: 0 28px 70px rgba(0,0,0,.45);
}

/* ── HEADER ── */
.ep-head {
  padding: 32px 36px 28px;
  border-bottom: 1px solid var(--border);
  background: var(--s1);
  position: relative; overflow: hidden;
}
.ep-head::before {
  content: ''; position: absolute; top: -60px; right: -40px;
  width: 200px; height: 200px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.07) 0%, transparent 65%);
  pointer-events: none;
}
.ep-head::after {
  content: ''; position: absolute; bottom: -40px; left: -40px;
  width: 160px; height: 160px; border-radius: 50%;
  background: radial-gradient(circle, rgba(6,182,212,.04) 0%, transparent 65%);
  pointer-events: none;
}
.ep-head-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--blue); font-weight: 600; margin-bottom: 10px;
  position: relative; z-index: 1;
}
.ep-head-eyebrow::before {
  content: ''; display: block; width: 20px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}
.ep-head-title {
  font-family: var(--font-heading);
  font-size: clamp(24px, 4vw, 34px);
  font-weight: 300; color: var(--text); line-height: 1.1;
  position: relative; z-index: 1;
}
.ep-head-title em { font-style: italic; color: var(--cyan); }
.ep-head-sub {
  font-size: 13px; color: var(--muted);
  margin-top: 8px; position: relative; z-index: 1;
}

/* ── CURRENT IMAGE PREVIEW ── */
.ep-img-preview {
  position: relative; width: 100%; height: 220px;
  overflow: hidden; background: var(--s3);
  border-bottom: 1px solid var(--border);
}
.ep-img-preview img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .5s ease;
}
.ep-img-preview:hover img { transform: scale(1.03); }
.ep-img-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(10,10,15,.5) 0%, transparent 50%);
}
.ep-img-label {
  position: absolute; bottom: 14px; left: 16px; z-index: 2;
  display: flex; align-items: center; gap: 6px;
  font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
  color: rgba(240,244,255,.7);
}
.ep-img-label svg { width: 12px; height: 12px; flex-shrink: 0; }
.ep-img-change-hint {
  position: absolute; bottom: 14px; right: 16px; z-index: 2;
  padding: 4px 12px;
  background: rgba(10,10,15,.75);
  border: 1px solid rgba(59,130,246,.3); border-radius: 999px;
  font-size: 10px; letter-spacing: .06em; color: var(--blue); font-weight: 500;
}

/* ── FORM BODY ── */
.ep-body { padding: 28px 36px 10px; display: flex; flex-direction: column; gap: 6px; }

/* section label */
.ep-sec {
  font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--blue); font-weight: 600;
  margin-top: 20px; margin-bottom: 12px;
  display: flex; align-items: center; gap: 8px;
}
.ep-sec:first-child { margin-top: 0; }
.ep-sec::before {
  content: ''; flex: none; display: block; width: 16px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}
.ep-sec::after { content: ''; flex: 1; height: 1px; background: var(--border); }

/* field */
.ep-field { margin-bottom: 16px; }
.ep-label {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); font-weight: 500; margin-bottom: 7px;
}

/* inputs */
.ep-input, .ep-textarea, .ep-select {
  width: 100%; background: var(--s3);
  border: 1px solid var(--border); border-radius: 10px;
  padding: 12px 15px; font-size: 14px; color: var(--text);
  outline: none;
  transition: border-color .22s, box-shadow .22s, background .22s;
  -webkit-appearance: none;
}
.ep-input::placeholder, .ep-textarea::placeholder { color: var(--muted); }
.ep-input:focus, .ep-textarea:focus, .ep-select:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px var(--glow-blue);
  background: rgba(28,28,40,.8);
}
.ep-input:hover:not(:focus),
.ep-textarea:hover:not(:focus),
.ep-select:hover:not(:focus) { border-color: rgba(59,130,246,.3); }
.ep-textarea { resize: vertical; line-height: 1.7; min-height: 110px; }
.ep-select option { background: var(--s2); color: var(--text); }

/* price */
.ep-price-wrap { position: relative; }
.ep-price-prefix {
  position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
  font-size: 16px; font-weight: 700; color: var(--blue);
  pointer-events: none; z-index: 1;
}
.ep-price-input { padding-left: 32px; }

/* grid helpers */
.ep-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.ep-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* char counter */
.ep-char { font-size: 10px; color: var(--muted); text-align: right; margin-top: 4px; }
.ep-char.warn { color: #FBBF24; }
.ep-char.over { color: var(--danger); }

/* ── CATEGORY CARDS ── */
.ep-cats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.ep-cat-opt { position: relative; }
.ep-cat-opt input[type=radio] { position: absolute; opacity: 0; width: 0; height: 0; }
.ep-cat-lbl {
  display: flex; flex-direction: column; align-items: center; gap: 7px;
  padding: 14px 8px;
  background: var(--s3); border: 1px solid var(--border); border-radius: 12px;
  cursor: pointer; text-align: center;
  transition: border-color .2s, background .2s, transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
}
.ep-cat-lbl:hover {
  border-color: rgba(59,130,246,.3);
  background: rgba(28,28,40,.9);
  transform: translateY(-2px);
}
.ep-cat-icon {
  width: 34px; height: 34px; border-radius: 9px;
  background: var(--s2); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  color: var(--muted); transition: background .2s, border-color .2s, color .2s;
}
.ep-cat-icon svg { width: 15px; height: 15px; }
.ep-cat-name { font-size: 10px; color: var(--muted); letter-spacing: .04em; transition: color .2s; }
.ep-cat-opt input:checked + .ep-cat-lbl {
  border-color: var(--blue);
  background: rgba(59,130,246,.08);
  transform: translateY(-2px);
  box-shadow: 0 0 0 2px rgba(59,130,246,.15);
}
.ep-cat-opt input:checked + .ep-cat-lbl .ep-cat-icon {
  background: rgba(59,130,246,.1);
  border-color: rgba(59,130,246,.3);
  color: var(--blue);
}
.ep-cat-opt input:checked + .ep-cat-lbl .ep-cat-name { color: var(--blue); font-weight: 600; }

/* ── COUNTER INPUTS ── */
.ep-counter-wrap {
  display: flex; align-items: center;
  background: var(--s3); border: 1px solid var(--border);
  border-radius: 10px; overflow: hidden; transition: border-color .22s;
}
.ep-counter-wrap:focus-within {
  border-color: var(--blue); box-shadow: 0 0 0 3px var(--glow-blue);
}
.ep-counter-btn {
  width: 44px; height: 46px; background: transparent; border: none;
  color: var(--muted); font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .18s, color .18s; flex-shrink: 0;
}
.ep-counter-btn:hover { background: rgba(59,130,246,.08); color: var(--blue); }
.ep-counter-inp {
  flex: 1; background: transparent; border: none; outline: none;
  text-align: center; font-size: 16px; font-weight: 700;
  color: var(--text); min-width: 0;
}
.ep-counter-inp::-webkit-outer-spin-button,
.ep-counter-inp::-webkit-inner-spin-button { -webkit-appearance: none; }
.ep-counter-sep { width: 1px; height: 28px; background: var(--border); }

/* ── AMENITY CHECKBOXES ── */
.ep-amenities { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.ep-amen-opt { position: relative; }
.ep-amen-opt input[type=checkbox] { position: absolute; opacity: 0; width: 0; height: 0; }
.ep-amen-lbl {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 12px;
  background: var(--s3); border: 1px solid var(--border); border-radius: 10px;
  cursor: pointer; font-size: 12px; color: var(--muted); letter-spacing: .04em;
  transition: border-color .18s, background .18s, color .18s;
  min-height: 44px;
}
.ep-amen-lbl svg { width: 13px; height: 13px; color: var(--muted); flex-shrink: 0; transition: color .18s; }
.ep-amen-lbl:hover { border-color: rgba(59,130,246,.3); color: var(--text); }
.ep-amen-opt input:checked + .ep-amen-lbl {
  border-color: var(--blue); background: rgba(59,130,246,.08); color: var(--blue);
}
.ep-amen-opt input:checked + .ep-amen-lbl svg { color: var(--blue); }
.ep-amen-check {
  width: 16px; height: 16px; border-radius: 4px;
  border: 1px solid var(--border); background: rgba(255,255,255,.04);
  margin-left: auto; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; transition: all .18s;
}
.ep-amen-check svg { width: 10px; height: 10px; color: var(--blue); display: none; }
.ep-amen-opt input:checked + .ep-amen-lbl .ep-amen-check {
  background: rgba(59,130,246,.1); border-color: var(--blue);
}
.ep-amen-opt input:checked + .ep-amen-lbl .ep-amen-check svg { display: block; }

/* ── UPLOAD ZONE ── */
.ep-upload {
  position: relative;
  border: 1px dashed rgba(59,130,246,.25); border-radius: 10px;
  background: var(--s3); padding: 24px 20px; text-align: center;
  cursor: pointer; transition: border-color .22s, background .22s;
}
.ep-upload:hover { border-color: var(--blue); background: rgba(59,130,246,.06); }
.ep-upload input[type=file] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.ep-upload-icon {
  width: 40px; height: 40px; border-radius: 12px;
  background: rgba(59,130,246,.08); border: 1px solid rgba(59,130,246,.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--blue); margin: 0 auto 12px;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1);
}
.ep-upload:hover .ep-upload-icon { transform: scale(1.1) translateY(-2px); }
.ep-upload-icon svg { width: 18px; height: 18px; }
.ep-upload-title { font-size: 13px; color: var(--text); font-weight: 600; margin-bottom: 4px; }
.ep-upload-sub   { font-size: 11px; color: var(--muted); }
.ep-upload-chosen {
  font-size: 12px; color: var(--success);
  margin-top: 8px; display: none;
  align-items: center; justify-content: center; gap: 6px;
}
.ep-upload-chosen svg { width: 13px; height: 13px; }
.ep-img-new-preview {
  display: none; margin-top: 12px; border-radius: 10px;
  overflow: hidden; border: 1px solid var(--border); height: 160px;
}
.ep-img-new-preview img { width: 100%; height: 100%; object-fit: cover; }

/* ── FOOTER ── */
.ep-footer {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 20px 36px 28px;
  border-top: 1px solid var(--border); flex-wrap: wrap;
}
.ep-cancel {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 11px 22px; background: transparent;
  border: 1px solid rgba(255,255,255,.1); border-radius: 999px;
  font-size: 13px; color: var(--muted); cursor: pointer; text-decoration: none;
  transition: border-color .2s, color .2s, transform .2s cubic-bezier(.34,1.56,.64,1);
}
.ep-cancel:hover {
  border-color: rgba(239,68,68,.35); color: var(--danger); transform: translateY(-1px);
}
.ep-submit {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 30px;
  background: linear-gradient(135deg, var(--blue), var(--cyan));
  color: #fff; border: none; border-radius: 999px;
  font-size: 14px; font-weight: 600; letter-spacing: .02em;
  cursor: pointer;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.ep-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59,130,246,.35);
  filter: brightness(1.08);
}
.ep-submit:active { transform: scale(.97); }

/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════ */

/* ── TABLET 768px ── */
@media (max-width: 768px) {
  .ep-amenities { grid-template-columns: repeat(2, 1fr); }
  .ep-row-3 { grid-template-columns: 1fr 1fr; }
  .ep-row-3 .ep-field:last-child { grid-column: span 2; }
}

/* ── MOBILE 640px ── */
@media (max-width: 640px) {
  .ep-page { padding: 0 0 60px; }

  .ep-card {
    border-radius: 0;
    border-left: none; border-right: none; border-top: none;
    max-width: 100%;
  }

  .ep-head { padding: 24px 18px 20px; }
  .ep-head-title { font-size: 22px; }
  .ep-head-sub { font-size: 12px; }

  .ep-img-preview { height: 180px; }

  .ep-body { padding: 20px 16px 10px; }

  .ep-footer {
    padding: 16px 16px 24px;
    flex-direction: column;
  }
  .ep-cancel, .ep-submit { width: 100%; justify-content: center; }

  /* categories: stay 4-col but tighter */
  .ep-cats { grid-template-columns: repeat(4, 1fr); gap: 6px; }
  .ep-cat-lbl { padding: 10px 4px; gap: 5px; }
  .ep-cat-icon { width: 28px; height: 28px; border-radius: 7px; }
  .ep-cat-icon svg { width: 13px; height: 13px; }
  .ep-cat-name { font-size: 9px; }

  /* counters: single column */
  .ep-row-2 { grid-template-columns: 1fr; }
  .ep-row-3 { grid-template-columns: 1fr; }
  .ep-row-3 .ep-field:last-child { grid-column: span 1; }

  /* amenities: 2-col */
  .ep-amenities { grid-template-columns: 1fr 1fr; }
  .ep-amen-lbl { font-size: 11px; padding: 9px 10px; gap: 6px; }

  /* prevent iOS zoom on inputs */
  .ep-input, .ep-textarea, .ep-select { font-size: 16px; }
  .ep-counter-btn { width: 40px; height: 44px; }
  .ep-counter-inp { font-size: 15px; }
}

/* ── SMALL MOBILE 380px ── */
@media (max-width: 380px) {
  .ep-head { padding: 20px 14px 18px; }
  .ep-body { padding: 18px 14px 8px; }
  .ep-footer { padding: 14px 14px 22px; }

  /* 2-col categories */
  .ep-cats { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .ep-cat-lbl { padding: 12px 8px; gap: 6px; }
  .ep-cat-icon { width: 30px; height: 30px; }
  .ep-cat-icon svg { width: 14px; height: 14px; }
  .ep-cat-name { font-size: 10px; }

  /* 1-col amenities */
  .ep-amenities { grid-template-columns: 1fr; }
}
</style>


<div class="ep-page">
<div class="ep-card">

  <!-- ── HEADER ── -->
  <div class="ep-head">
    <div class="ep-head-eyebrow">Manage listing</div>
    <h1 class="ep-head-title">Edit your <em>listing</em></h1>
    <p class="ep-head-sub">Update your property details — changes go live immediately.</p>
  </div>

  <!-- ── CURRENT IMAGE PREVIEW ── -->
  <% if(listing.image && listing.image.url){ %>
    <div class="ep-img-preview">
      <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
      <div class="ep-img-overlay"></div>
      <div class="ep-img-label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        Current photo
      </div>
      <span class="ep-img-change-hint">Change below ↓</span>
    </div>
  <% } %>

  <!-- ── FORM ── -->
  <form action="/listings/<%= listing._id %>?_method=PUT"
    method="POST" enctype="multipart/form-data" id="editForm">

    <div class="ep-body">

      <!-- ── BASIC INFO ── -->
      <div class="ep-sec">Basic information</div>

      <div class="ep-field">
        <label class="ep-label" for="ef-title">Title</label>
        <input class="ep-input" id="ef-title" type="text"
          name="listing[title]" value="<%= listing.title %>"
          required maxlength="80" placeholder="Give your listing a great name"
          autocomplete="off">
      </div>

      <div class="ep-field">
        <label class="ep-label" for="ef-desc">Description</label>
        <textarea class="ep-textarea" id="ef-desc"
          name="listing[description]" rows="4"
          required maxlength="800"
          placeholder="Describe what makes your place special…"><%= listing.description %></textarea>
        <div class="ep-char" id="descChar">0 / 800</div>
      </div>

      <!-- ── PROPERTY TYPE ── -->
      <div class="ep-sec">Property type</div>

      <input type="hidden" name="listing[category]" id="ep-cat-val"
        value="<%= listing.category || '' %>">

      <div class="ep-cats">

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-villa" value="villa"
            <%= listing.category === 'villa' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-villa">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
                <path d="M9 21V12h6v9"/>
              </svg>
            </div>
            <span class="ep-cat-name">Villa</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-flat" value="flat"
            <%= listing.category === 'flat' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-flat">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <rect x="2" y="3" width="20" height="18" rx="2"/>
                <path d="M8 3v18M16 3v18M2 9h20M2 15h20"/>
              </svg>
            </div>
            <span class="ep-cat-name">Flat</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-room" value="room"
            <%= listing.category === 'room' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-room">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M3 7h18v13H3z"/>
                <path d="M3 7V4h18v3"/>
                <path d="M9 13h6"/>
              </svg>
            </div>
            <span class="ep-cat-name">Room</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-hostel" value="hostel"
            <%= listing.category === 'hostel' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-hostel">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M3 21V7l9-4 9 4v14"/>
                <path d="M12 21V11M7 21v-5h10v5"/>
              </svg>
            </div>
            <span class="ep-cat-name">Hostel</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-beach" value="beachfront"
            <%= listing.category === 'beachfront' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-beach">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M2 18c2-2 4 2 6 0s4-2 6 0 4 2 6 0"/>
                <path d="M12 4a4 4 0 014 4c0 3-4 6-4 6S8 11 8 8a4 4 0 014-4z"/>
              </svg>
            </div>
            <span class="ep-cat-name">Beach</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-mtn" value="mountain"
            <%= listing.category === 'mountain' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-mtn">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M8 21L3 9l5-3 4 6 4-6 5 3-5 12z"/>
              </svg>
            </div>
            <span class="ep-cat-name">Mountain</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-island" value="island"
            <%= listing.category === 'island' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-island">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15 15 0 010 20"/>
              </svg>
            </div>
            <span class="ep-cat-name">Island</span>
          </label>
        </div>

        <div class="ep-cat-opt">
          <input type="radio" name="_catUI" id="ec-farm" value="farm"
            <%= listing.category === 'farm' ? 'checked' : '' %>>
          <label class="ep-cat-lbl" for="ec-farm">
            <div class="ep-cat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <path d="M2 20h20M4 20V10l8-6 8 6v10"/>
                <path d="M10 20v-6h4v6"/>
              </svg>
            </div>
            <span class="ep-cat-name">Farm</span>
          </label>
        </div>

      </div>

      <!-- ── SPACE DETAILS ── -->
      <div class="ep-sec">Space details</div>

      <div class="ep-row-3">
        <div class="ep-field" style="margin-bottom:0">
          <div class="ep-label">Bedrooms</div>
          <div class="ep-counter-wrap">
            <button type="button" class="ep-counter-btn" data-target="ep-bedrooms" data-op="dec">−</button>
            <div class="ep-counter-sep"></div>
            <input class="ep-counter-inp" type="number" name="listing[bedrooms]"
              id="ep-bedrooms" value="<%= listing.bedrooms || 1 %>"
              min="0" max="50" required readonly>
            <div class="ep-counter-sep"></div>
            <button type="button" class="ep-counter-btn" data-target="ep-bedrooms" data-op="inc">+</button>
          </div>
        </div>

        <div class="ep-field" style="margin-bottom:0">
          <div class="ep-label">Bathrooms</div>
          <div class="ep-counter-wrap">
            <button type="button" class="ep-counter-btn" data-target="ep-bathrooms" data-op="dec">−</button>
            <div class="ep-counter-sep"></div>
            <input class="ep-counter-inp" type="number" name="listing[bathrooms]"
              id="ep-bathrooms" value="<%= listing.bathrooms || 1 %>"
              min="0" max="50" required readonly>
            <div class="ep-counter-sep"></div>
            <button type="button" class="ep-counter-btn" data-target="ep-bathrooms" data-op="inc">+</button>
          </div>
        </div>

        <div class="ep-field" style="margin-bottom:0">
          <div class="ep-label">Max guests</div>
          <div class="ep-counter-wrap">
            <button type="button" class="ep-counter-btn" data-target="ep-guests" data-op="dec">−</button>
            <div class="ep-counter-sep"></div>
            <input class="ep-counter-inp" type="number" name="listing[maxGuests]"
              id="ep-guests" value="<%= listing.maxGuests || 2 %>"
              min="1" max="50" required readonly>
            <div class="ep-counter-sep"></div>
            <button type="button" class="ep-counter-btn" data-target="ep-guests" data-op="inc">+</button>
          </div>
        </div>
      </div>

      <!-- ── AMENITIES ── -->
      <div class="ep-sec">Amenities</div>

      <%
        var allAmenities = [
          { val: 'Wi-Fi',            id: 'wifi' },
          { val: 'Pool',             id: 'pool' },
          { val: 'Air conditioning', id: 'ac' },
          { val: 'Kitchen',          id: 'kitchen' },
          { val: 'Parking',          id: 'parking' },
          { val: 'TV',               id: 'tv' },
          { val: 'Gym',              id: 'gym' },
          { val: 'Pet friendly',     id: 'pets' },
          { val: 'Breakfast',        id: 'breakfast' }
        ];
        var currentAmenities = listing.amenities || [];
      %>

      <div class="ep-amenities">

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-wifi" value="Wi-Fi"
            <%= currentAmenities.includes('Wi-Fi') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-wifi">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/>
              <path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/>
            </svg>
            Wi-Fi
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-pool" value="Pool"
            <%= currentAmenities.includes('Pool') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-pool">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M2 12c1.5-2 3 2 4.5 0s3-2 4.5 0 3 2 4.5 0 3-2 4.5 0"/>
              <path d="M2 18c1.5-2 3 2 4.5 0s3-2 4.5 0 3 2 4.5 0 3-2 4.5 0"/><path d="M9 4l3 4 3-4"/>
            </svg>
            Pool
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-ac" value="Air conditioning"
            <%= currentAmenities.includes('Air conditioning') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-ac">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <rect x="2" y="6" width="20" height="10" rx="2"/>
              <path d="M8 16v2M12 16v2M16 16v2M8 6V4M12 6V4M16 6V4"/>
            </svg>
            AC
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-kitchen" value="Kitchen"
            <%= currentAmenities.includes('Kitchen') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-kitchen">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M6 2v6a3 3 0 006 0V2"/><path d="M18 2v20M3 14h18"/>
            </svg>
            Kitchen
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-parking" value="Parking"
            <%= currentAmenities.includes('Parking') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-parking">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M9 8h4a2 2 0 010 4H9v4"/><path d="M9 8v8"/>
            </svg>
            Parking
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-tv" value="TV"
            <%= currentAmenities.includes('TV') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-tv">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <rect x="2" y="7" width="20" height="13" rx="2"/><path d="M8 3l4 4 4-4"/>
            </svg>
            TV
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-gym" value="Gym"
            <%= currentAmenities.includes('Gym') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-gym">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M6.5 6.5h11M6.5 17.5h11M3 10h3v4H3zM18 10h3v4h-3zM6.5 12h11"/>
            </svg>
            Gym
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-pets" value="Pet friendly"
            <%= currentAmenities.includes('Pet friendly') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-pets">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <circle cx="4.5" cy="9.5" r="2.5"/><circle cx="9" cy="5.5" r="2.5"/>
              <circle cx="15" cy="5.5" r="2.5"/><circle cx="19.5" cy="9.5" r="2.5"/>
              <path d="M12 14c-4 0-7 1.5-7 5s3 5 7 5 7-2 7-5-3-5-7-5z"/>
            </svg>
            Pet friendly
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

        <div class="ep-amen-opt">
          <input type="checkbox" name="listing[amenities][]" id="ea-breakfast" value="Breakfast"
            <%= currentAmenities.includes('Breakfast') ? 'checked' : '' %>>
          <label class="ep-amen-lbl" for="ea-breakfast">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M18 8h1a4 4 0 010 8h-1"/>
              <path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            Breakfast
            <div class="ep-amen-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          </label>
        </div>

      </div>

      <!-- ── PRICING ── -->
      <div class="ep-sec">Pricing</div>

      <div class="ep-field">
        <label class="ep-label" for="ef-price">Price per night (₹)</label>
        <div class="ep-price-wrap">
          <span class="ep-price-prefix">₹</span>
          <input class="ep-input ep-price-input" id="ef-price" type="number"
            name="listing[price]" value="<%= listing.price %>"
            required min="0" placeholder="0">
        </div>
      </div>

      <!-- ── LOCATION ── -->
      <div class="ep-sec">Location</div>

      <div class="ep-row-2">
        <div class="ep-field" style="margin-bottom:0">
          <label class="ep-label" for="ef-loc">City / area</label>
          <input class="ep-input" id="ef-loc" type="text"
            name="listing[location]" value="<%= listing.location %>"
            required placeholder="e.g. Goa" autocomplete="off">
        </div>
        <div class="ep-field" style="margin-bottom:0">
          <label class="ep-label" for="ef-country">Country</label>
          <input class="ep-input" id="ef-country" type="text"
            name="listing[country]" value="<%= listing.country %>"
            required placeholder="e.g. India" autocomplete="off">
        </div>
      </div>

      <!-- ── PHOTO ── -->
      <div class="ep-sec" style="margin-top:24px;">Update photo</div>

      <div class="ep-field">
        <div class="ep-upload" id="epUpload">
          <input type="file" name="listing[image]" accept="image/*" id="epFileInput">
          <div class="ep-upload-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
          <div class="ep-upload-title">Drop a new photo here</div>
          <div class="ep-upload-sub">or tap to browse · JPG, PNG, WEBP · max 5 MB</div>
          <div class="ep-upload-chosen" id="epFileName">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span id="epFileText"></span>
          </div>
        </div>
        <div class="ep-img-new-preview" id="epNewPreview">
          <img id="epNewPreviewImg" src="" alt="New preview">
        </div>
      </div>

    </div><!-- /.ep-body -->

    <!-- ── FOOTER ── -->
    <div class="ep-footer">
      <a href="/listings/<%= listing._id %>" class="ep-cancel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" width="13" height="13">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Cancel
      </a>
      <button type="submit" class="ep-submit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" width="14" height="14">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Save changes
      </button>
    </div>

  </form>
</div>
</div>


<script>
(function () {
  'use strict';

  /* ── char counter ── */
  var desc    = document.getElementById('ef-desc');
  var counter = document.getElementById('descChar');
  var MAX     = 800;
  function updateCount() {
    if (!desc || !counter) return;
    var len = desc.value.length;
    counter.textContent = len + ' / ' + MAX;
    counter.className = 'ep-char' + (len > MAX ? ' over' : len > MAX * .85 ? ' warn' : '');
  }
  if (desc) { desc.addEventListener('input', updateCount); updateCount(); }

  /* ── category radio → hidden input ── */
  var catVal = document.getElementById('ep-cat-val');
  document.querySelectorAll('input[name="_catUI"]').forEach(function (r) {
    r.addEventListener('change', function () {
      if (catVal) catVal.value = this.value;
    });
  });

  /* ── counter buttons ── */
  document.querySelectorAll('.ep-counter-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var inp = document.getElementById(this.dataset.target);
      if (!inp) return;
      var min = Number(inp.min || 0);
      var max = Number(inp.max || 99);
      var v   = Number(inp.value) || 0;
      v = this.dataset.op === 'inc' ? Math.min(v + 1, max) : Math.max(v - 1, min);
      inp.value = v;
    });
  });

  /* ── file upload + preview ── */
  var fileInput     = document.getElementById('epFileInput');
  var fileNameEl    = document.getElementById('epFileName');
  var fileText      = document.getElementById('epFileText');
  var uploadBox     = document.getElementById('epUpload');
  var newPreview    = document.getElementById('epNewPreview');
  var newPreviewImg = document.getElementById('epNewPreviewImg');

  function handleFile(file) {
    if (!file) return;
    if (fileText) fileText.textContent = file.name;
    if (fileNameEl) fileNameEl.style.display = 'flex';
    uploadBox.style.borderColor = 'var(--blue)';
    uploadBox.style.background  = 'rgba(59,130,246,.06)';
    var reader = new FileReader();
    reader.onload = function (e) {
      if (newPreviewImg) newPreviewImg.src = e.target.result;
      if (newPreview) newPreview.style.display = 'block';
    };
    reader.readAsDataURL(file);
  }

  if (fileInput) {
    fileInput.addEventListener('change', function () {
      if (this.files && this.files[0]) handleFile(this.files[0]);
    });
  }
  if (uploadBox) {
    uploadBox.addEventListener('dragover', function (e) {
      e.preventDefault(); this.classList.add('drag');
      this.style.borderColor = 'var(--blue)';
      this.style.background  = 'rgba(59,130,246,.06)';
    });
    ['dragleave', 'dragend'].forEach(function (ev) {
      uploadBox.addEventListener(ev, function () {
        this.classList.remove('drag');
        this.style.borderColor = '';
        this.style.background  = '';
      });
    });
    uploadBox.addEventListener('drop', function (e) {
      e.preventDefault(); this.classList.remove('drag');
      var f = e.dataTransfer.files[0];
      if (f) { fileInput.files = e.dataTransfer.files; handleFile(f); }
    });
  }

})();
</script>
