<script>
(function () {
  'use strict';

  /* ── TAX TOGGLE ── */
  var toggle = document.getElementById('taxToggle');
  if (toggle) {
    toggle.addEventListener('change', function () {
      document.querySelectorAll('.sl-pval').forEach(function (el) {
        var base = Number(el.dataset.base || 0);
        if (!base) return;
        el.textContent = (toggle.checked
          ? Math.round(base * 1.18)
          : base
        ).toLocaleString('en-IN');
      });
      document.querySelectorAll('.sl-ptax').forEach(function (t) {
        t.textContent = toggle.checked ? 'GST included' : '+ 18% GST applicable';
      });
    });
  }

  /* ── STAGGERED CARD ANIMATION ── */
  document.querySelectorAll('.sl-card').forEach(function (card, i) {
    card.style.animationDelay = (i * 0.06) + 's';
  });

})();
</script>
