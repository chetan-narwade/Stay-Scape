<!-- ════════════════════════════════════════════════════════
     LISTINGS GRID
════════════════════════════════════════════════════════ -->
<div class="sl-section">

  <div class="sl-sec-hd">
    <div>
      <div class="sl-sec-tag">Featured stays</div>
      <div class="sl-sec-title">Curated for <em>you</em></div>
    </div>
    <a href="/listings" class="sl-sec-link">View all stays →</a>
  </div>

  <!-- count + tax toggle -->
  <div class="sl-grid-meta">
    <span class="sl-count">
      <strong><%= allListings.length %></strong> stay<%= allListings.length !== 1 ? 's' : '' %> found
    </span>
    <div class="sl-tax-toggle">
      <label class="sl-tog" for="taxToggle">
        <input type="checkbox" id="taxToggle">
        <span class="sl-tog-slider"></span>
      </label>
      <label class="sl-tog-lbl" for="taxToggle">Include 18% GST</label>
    </div>
  </div>

  <% if(allListings && allListings.length > 0){ %>
    <div class="sl-grid">
      <% allListings.forEach(function(listing, index){ %>
        <% if(!listing || !listing._id) return; %>

        <a href="/listings/<%= listing._id %>"
          class="sl-card <%= index === 0 ? 'feat' : '' %>"
          style="animation-delay:<%= (index * 0.06) %>s">

          <!-- image -->
          <div class="sl-card-img">
            <img
              src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600' %>"
              alt="<%= listing.title %>" loading="lazy">
            <div class="sl-card-img-ov"></div>

            <!-- badge -->
            <div class="sl-card-top">
              <% if(index === 0){ %>
                <span class="sl-badge"><%= listing.category || 'Featured' %></span>
              <% } else if(index === 1){ %>
                <span class="sl-badge-new">New</span>
              <% } else if(index === 2){ %>
                <span class="sl-badge-hot">Popular</span>
              <% } else if(listing.category){ %>
                <span class="sl-badge"><%= listing.category %></span>
              <% } %>
            </div>

            <!-- rating overlay -->
            <div class="sl-card-img-meta">
              <% if(listing.reviews && listing.reviews.length > 0){ %>
                <% const avg = listing.reviews.reduce(function(s,r){ return s + (r.rating||0); }, 0) / listing.reviews.length; %>
                <% const full = Math.round(avg); %>
                <div class="sl-stars">
                  <% for(let s = 0; s < 5; s++){ %>
                    <svg viewBox="0 0 24 24" fill="<%= s < full ? '#3B82F6' : 'rgba(59,130,246,0.2)' %>">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  <% } %>
                </div>
                <span class="sl-reviews"><%= avg.toFixed(1) %> · <%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %></span>
              <% } %>
            </div>
          </div>

          <!-- body -->
          <div class="sl-card-body">
            <div class="sl-card-loc">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <%= listing.location %><% if(listing.country){ %>, <%= listing.country %><% } %>
            </div>

            <div class="sl-card-title"><%= listing.title %></div>

            <div class="sl-card-tags">
              <% if(listing.amenities && listing.amenities.length){ %>
                <% listing.amenities.slice(0, 3).forEach(function(a){ %>
                  <span class="sl-tag"><%= a %></span>
                <% }) %>
              <% } else { %>
                <% if(listing.bedrooms){ %><span class="sl-tag"><%= listing.bedrooms %> beds</span><% } %>
                <% if(listing.bathrooms){ %><span class="sl-tag"><%= listing.bathrooms %> baths</span><% } %>
                <% if(listing.category){ %><span class="sl-tag"><%= listing.category %></span><% } %>
              <% } %>
            </div>

            <div class="sl-card-footer">
              <div class="sl-price-wrap">
                <div class="sl-price">
                  <span class="sl-pcur">₹</span>
                  <span class="sl-pval" data-base="<%= listing.price %>">
                    <%= listing.price.toLocaleString('en-IN') %>
                  </span>
                  <span class="sl-punit">/ night</span>
                </div>
                <div class="sl-ptax">+ 18% GST applicable</div>
              </div>
              <span class="sl-book-btn">
                Book now
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" width="11" height="11">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>

        </a>
      <% }) %>
    </div>

  <% } else { %>
    <div class="sl-empty">
      <div class="sl-empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </div>
      <h4 class="sl-empty-title">No stays found</h4>
      <p class="sl-empty-text">Try adjusting your filters or exploring a different destination.</p>
      <a href="/listings" class="sl-empty-btn">Clear filters</a>
    </div>
  <% } %>

</div>


<div class="sl-sep"></div>


