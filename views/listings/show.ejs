<% layout("layouts/boilerplate") %>

<style>
/* ═══════════════════════════════════════════════════════════
   SHOW PAGE — blue/cyan palette, Inter font throughout
═══════════════════════════════════════════════════════════ */

@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
@keyframes float  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

/* ── PAGE WRAPPER ── */
.sp-page {
  max-width: 1080px;
  margin: 0 auto;
  padding: 32px 28px 80px;
}

/* ══ HERO IMAGE ═════════════════════════════════════════════ */
.sp-hero {
  position: relative; width: 100%;
  height: 500px; border-radius: 20px;
  overflow: hidden; border: 1px solid var(--border);
  margin-bottom: 36px;
  animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both;
}
.sp-hero img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .7s ease;
}
.sp-hero:hover img { transform: scale(1.04); }
.sp-hero-ov {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(10,10,15,.6) 0%, rgba(10,10,15,.08) 50%, transparent 75%);
}

/* category badge */
.sp-hero-cat {
  position: absolute; top: 18px; left: 18px; z-index: 3;
  padding: 5px 14px;
  background: rgba(10,10,15,.75);
  border: 1px solid rgba(59,130,246,.3); border-radius: 999px;
  font-size: 11px; letter-spacing: .08em; text-transform: capitalize;
  color: var(--blue); font-weight: 500;
  backdrop-filter: blur(8px);
}

/* wishlist button */
.sp-hero-wish {
  position: absolute; top: 18px; right: 18px; z-index: 3;
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(10,10,15,.72);
  border: 1px solid rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; backdrop-filter: blur(8px);
  transition: all .22s cubic-bezier(.34,1.56,.64,1);
}
.sp-hero-wish svg { width: 16px; height: 16px; }
.sp-hero-wish:hover {
  background: rgba(239,68,68,.18);
  border-color: rgba(239,68,68,.4);
  transform: scale(1.12);
}

/* price chip */
.sp-hero-price {
  position: absolute; bottom: 20px; right: 20px; z-index: 3;
  background: rgba(10,10,15,.82);
  border: 1px solid var(--border); border-radius: 14px;
  padding: 12px 18px; backdrop-filter: blur(14px); text-align: right;
}
.sp-hero-price-num {
  font-size: 28px; font-weight: 700; color: var(--text); line-height: 1;
}
.sp-hero-price-sub { font-size: 11px; color: var(--muted); margin-top: 3px; }

/* ══ TWO-COL LAYOUT ═════════════════════════════════════════ */
.sp-cols {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 32px; align-items: start;
  margin-bottom: 44px;
}
.sp-left {
  display: flex; flex-direction: column; gap: 24px;
  animation: fadeUp .55s .1s cubic-bezier(.22,1,.36,1) both;
}
.sp-right {
  display: flex; flex-direction: column; gap: 20px;
  animation: fadeUp .55s .2s cubic-bezier(.22,1,.36,1) both;
}

/* ── EYEBROW ── */
.sp-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--blue); font-weight: 600;
}
.sp-eyebrow::before {
  content: ''; display: block; width: 20px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}

/* title + location */
.sp-title {
  font-family: var(--font-heading);
  font-size: clamp(24px, 4vw, 40px);
  font-weight: 300; color: var(--text); line-height: 1.1;
  margin: 8px 0 10px;
}
.sp-loc {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--muted);
}
.sp-loc svg { width: 13px; height: 13px; color: var(--cyan); flex-shrink: 0; }

/* ── STATS BAR ── */
.sp-stats {
  display: flex; border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden; background: var(--s2);
}
.sp-stat {
  flex: 1; padding: 15px 10px;
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  border-right: 1px solid var(--border); transition: background .2s;
}
.sp-stat:last-child { border-right: none; }
.sp-stat:hover { background: var(--s3); }
.sp-stat-n { font-size: 20px; font-weight: 700; color: var(--text); line-height: 1; }
.sp-stat-l { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); text-align: center; }

/* ── CONTENT CARDS ── */
.sp-card {
  background: var(--s2);
  border: 1px solid var(--border);
  border-radius: 16px; padding: 22px 24px;
}
.sp-card-h {
  font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 12px;
}
.sp-card-txt {
  font-size: 14px; color: var(--muted); line-height: 1.8;
}

/* ── OWNER BUTTONS ── */
.sp-owner-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.sp-obtn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 22px; border-radius: 999px;
  font-size: 13px; font-weight: 500; letter-spacing: .02em;
  border: 1px solid; cursor: pointer;
  transition: all .2s cubic-bezier(.34,1.56,.64,1); background: transparent;
}
.sp-obtn-edit {
  border-color: rgba(59,130,246,.3); color: var(--blue);
}
.sp-obtn-edit:hover {
  background: rgba(59,130,246,.1); border-color: var(--blue); transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(59,130,246,.2);
}
.sp-obtn-del {
  border-color: rgba(239,68,68,.3); color: var(--danger);
}
.sp-obtn-del:hover {
  background: rgba(239,68,68,.1); border-color: var(--danger); transform: translateY(-1px);
}

/* ── REVIEWS ── */
.sp-reviews { display: flex; flex-direction: column; gap: 12px; }
.sp-rv {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 12px; padding: 18px 20px;
  transition: border-color .2s, transform .22s;
}
.sp-rv:hover { border-color: rgba(59,130,246,.3); transform: translateY(-2px); }
.sp-rv-head {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 10px; gap: 10px;
}
.sp-rv-author { display: flex; align-items: center; gap: 10px; min-width: 0; }
.sp-rv-av {
  width: 34px; height: 34px; border-radius: 50%;
  background: rgba(59,130,246,.1);
  border: 1px solid rgba(59,130,246,.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700; color: var(--blue); flex-shrink: 0;
}
.sp-rv-name {
  font-size: 13px; font-weight: 600; color: var(--text);
  margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sp-rv-stars { display: flex; gap: 2px; }
.sp-rv-stars svg { width: 11px; height: 11px; }
.sp-rv-txt { font-size: 13px; color: var(--muted); line-height: 1.75; }
.sp-rv-del {
  background: transparent; border: 1px solid rgba(239,68,68,.25);
  border-radius: 999px; padding: 4px 12px; font-size: 11px;
  color: var(--danger); cursor: pointer; flex-shrink: 0;
  transition: all .18s;
}
.sp-rv-del:hover { background: rgba(239,68,68,.1); border-color: var(--danger); }

/* no reviews */
.sp-no-rv {
  display: flex; flex-direction: column; align-items: center;
  padding: 30px 20px; text-align: center;
}
.sp-no-rv svg { width: 34px; height: 34px; color: var(--muted); margin-bottom: 10px; animation: float 3s ease-in-out infinite; }
.sp-no-rv p { font-size: 13px; color: var(--muted); }

/* ── REVIEW FORM ── */
.sp-flbl {
  font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
  color: var(--blue); font-weight: 600; margin-bottom: 8px; display: block;
}
.sp-finp, .sp-fta {
  width: 100%; background: var(--s3);
  border: 1px solid var(--border); border-radius: 10px;
  padding: 11px 14px; font-size: 13px; color: var(--text);
  outline: none;
  transition: border-color .2s, box-shadow .2s; -webkit-appearance: none;
}
.sp-finp:focus, .sp-fta:focus {
  border-color: var(--blue); box-shadow: 0 0 0 3px var(--glow-blue);
}
.sp-finp::placeholder, .sp-fta::placeholder { color: var(--muted); }
.sp-fta { resize: none; line-height: 1.7; }
.sp-fg { margin-bottom: 16px; }

/* star picker */
.sp-stars-pick {
  display: flex; flex-direction: row-reverse; gap: 4px; margin-bottom: 4px;
}
.sp-stars-pick input { display: none; }
.sp-stars-pick label {
  font-size: 26px; color: var(--muted); cursor: pointer;
  transition: color .15s, transform .18s cubic-bezier(.34,1.56,.64,1);
}
.sp-stars-pick input:checked ~ label,
.sp-stars-pick label:hover,
.sp-stars-pick label:hover ~ label { color: var(--blue); }
.sp-stars-pick label:hover { transform: scale(1.22); }

/* submit button */
.sp-sbtn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; padding: 13px 0;
  background: linear-gradient(135deg, var(--blue), var(--cyan));
  color: #fff; border: none; border-radius: 999px;
  font-size: 14px; font-weight: 600; cursor: pointer;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.sp-sbtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59,130,246,.35);
  filter: brightness(1.08);
}
.sp-sbtn:active { transform: scale(.98); }

/* ══ RIGHT SIDEBAR ══════════════════════════════════════════ */
.sp-book {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 16px; padding: 24px;
  position: sticky; top: 80px;
}
.sp-book-price {
  display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px;
}
.sp-book-price-n {
  font-size: 36px; font-weight: 700; color: var(--text); line-height: 1;
}
.sp-book-price-u { font-size: 13px; color: var(--muted); }
.sp-book-tax { font-size: 11px; color: var(--muted); margin-bottom: 20px; }

/* book button */
.sp-book-btn {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; padding: 14px 0;
  background: linear-gradient(135deg, var(--blue), var(--cyan));
  color: #fff; border: none; border-radius: 999px;
  font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none;
  transition: transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s, filter .2s;
}
.sp-book-btn:hover {
  color: #fff; transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(59,130,246,.35); filter: brightness(1.08);
}

.sp-book-sep { height: 1px; background: var(--border); margin: 18px 0; }

.sp-book-feat {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; color: var(--muted); padding: 5px 0;
}
.sp-book-feat svg { width: 14px; height: 14px; color: var(--cyan); flex-shrink: 0; }

/* ══ BOOKED DATES CARD ══════════════════════════════════════ */
.sp-booked {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 16px; padding: 20px 22px;
}
.sp-booked-hd {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--blue); font-weight: 600; margin-bottom: 16px;
}
.sp-booked-hd svg { width: 13px; height: 13px; color: var(--blue); }
.sp-booked-count {
  background: rgba(59,130,246,.1);
  border: 1px solid rgba(59,130,246,.25);
  border-radius: 999px; padding: 2px 8px;
  font-size: 10px; color: var(--blue); margin-left: auto;
}
.sp-booked-list { display: flex; flex-direction: column; gap: 10px; }

/* booking item */
.sp-bk-item {
  background: var(--s3); border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden;
  transition: border-color .2s, transform .22s cubic-bezier(.34,1.56,.64,1);
}
.sp-bk-item:hover { border-color: rgba(59,130,246,.3); transform: translateY(-2px); }

.sp-bk-dates {
  display: flex; align-items: center;
  padding: 14px 14px 10px; gap: 6px;
}
.sp-bk-date-box {
  display: flex; flex-direction: column; align-items: center;
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 8px 10px; min-width: 52px; text-align: center;
  transition: border-color .2s;
}
.sp-bk-item:hover .sp-bk-date-box { border-color: rgba(59,130,246,.2); }
.sp-bk-date-box--end {
  background: rgba(59,130,246,.06);
  border-color: rgba(59,130,246,.18);
}
.sp-bk-month { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--blue); }
.sp-bk-day   { font-size: 26px; font-weight: 700; color: var(--text); line-height: 1.1; }
.sp-bk-year  { font-size: 9px; color: var(--muted); margin-top: 1px; }

.sp-bk-mid {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px;
}
.sp-bk-line {
  width: 100%; height: 1px;
  background: linear-gradient(90deg, var(--border), rgba(59,130,246,.3), var(--border));
}
.sp-bk-nights {
  font-size: 10px; letter-spacing: .06em; text-transform: uppercase;
  color: var(--blue); background: rgba(59,130,246,.08);
  border: 1px solid rgba(59,130,246,.2); border-radius: 999px;
  padding: 2px 9px; white-space: nowrap;
}
.sp-bk-arr { width: 11px; height: 11px; color: var(--muted); }

.sp-bk-footer {
  display: flex; align-items: center; justify-content: space-between;
  gap: 8px; padding: 8px 14px 12px;
  border-top: 1px solid var(--border);
}
.sp-bk-guest {
  display: flex; align-items: center; gap: 5px;
  font-size: 11px; color: var(--muted);
}
.sp-cancel {
  background: transparent; border: 1px solid rgba(239,68,68,.22);
  border-radius: 999px; padding: 4px 12px; font-size: 11px;
  color: var(--danger); cursor: pointer;
  display: inline-flex; align-items: center; gap: 4px;
  transition: all .18s;
}
.sp-cancel:hover { background: rgba(239,68,68,.1); border-color: var(--danger); }

/* no bookings */
.sp-no-book-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 22px 16px; text-align: center;
}
.sp-no-book-icon {
  width: 44px; height: 44px; border-radius: 12px;
  background: rgba(59,130,246,.08);
  border: 1px solid rgba(59,130,246,.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--blue); margin-bottom: 12px;
}
.sp-no-book-icon svg { width: 20px; height: 20px; }
.sp-no-book-txt { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.sp-no-book-sub { font-size: 11px; color: var(--muted); }

/* ══ MAP ═════════════════════════════════════════════════════ */
.sp-map-section { margin-bottom: 60px; }
.sp-map-hd {
  display: flex; align-items: center; gap: 8px;
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--blue); font-weight: 600; margin-bottom: 14px;
}
.sp-map-hd::before {
  content: ''; display: block; width: 20px; height: 1px;
  background: linear-gradient(90deg, var(--blue), var(--cyan));
}
.sp-map-hd svg { width: 14px; height: 14px; }
.sp-map-sub { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
#sp-map {
  width: 100%; height: 400px; border-radius: 18px;
  overflow: hidden; border: 1px solid var(--border); background: var(--s2);
}

/* ══ RESPONSIVE — 860px ═════════════════════════════════════ */
@media (max-width: 860px) {
  .sp-cols { grid-template-columns: 1fr; gap: 0; }
  /* on tablet/mobile right sidebar goes BELOW left content */
  .sp-right { order: 2; margin-top: 24px; }
  .sp-left  { order: 1; }
  .sp-book  { position: static; }
  /* on tablet/mobile the sticky booking card becomes an inline strip */
  .sp-book  { border-radius: 14px; }
}

/* ══ RESPONSIVE — 640px ═════════════════════════════════════ */
@media (max-width: 640px) {
  .sp-page { padding: 0 0 60px; }

  /* hero — full width no border radius */
  .sp-hero {
    height: 240px;
    border-radius: 0;
    border-left: none; border-right: none;
    margin-bottom: 0;
  }

  /* wishlist moves out of hero on mobile — shown below hero as a row */
  .sp-hero-wish-wrap { display: none; }
  .sp-mobile-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 0;
    gap: 10px;
  }
  .sp-mobile-wish {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--s2);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px; font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: border-color .2s, color .2s, background .2s;
  }
  .sp-mobile-wish svg { width: 14px; height: 14px; flex-shrink: 0; }
  .sp-mobile-wish.wishlisted {
    color: var(--danger);
    border-color: rgba(239,68,68,.3);
    background: rgba(239,68,68,.06);
  }
  .sp-mobile-wish.wishlisted svg { fill: var(--danger); stroke: var(--danger); }
  .sp-mobile-share {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--s2);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px; font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: border-color .2s, color .2s;
  }
  .sp-mobile-share svg { width: 14px; height: 14px; }

  /* mobile price bar — shown between hero and title */
  .sp-mobile-price-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: var(--s1);
    border-bottom: 1px solid var(--border);
  }
  .sp-mobile-price-bar .price-num {
    font-size: 26px; font-weight: 700; color: var(--text); line-height: 1;
  }
  .sp-mobile-price-bar .price-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .sp-mobile-book-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 11px 22px;
    background: linear-gradient(135deg, var(--blue), var(--cyan));
    color: #fff; border: none; border-radius: 999px;
    font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none;
    white-space: nowrap;
    transition: transform .2s, box-shadow .2s, filter .2s;
  }
  .sp-mobile-book-btn:hover {
    color: #fff; transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(59,130,246,.35); filter: brightness(1.08);
  }

  /* hide hero price chip + hero wishlist on mobile */
  .sp-hero-price   { display: none; }
  .sp-hero-wish-wrap { display: none; }

  /* main content padding */
  .sp-left  { padding: 0 16px; gap: 20px; margin-top: 20px; }
  .sp-right { padding: 0 16px; margin-top: 0; }

  /* hide desktop booking card on mobile — we show mobile-price-bar instead */
  .sp-book { display: none; }

  /* booked dates card stays visible — just smaller */
  .sp-booked { border-radius: 12px; }

  /* title */
  .sp-title { font-size: 22px; }
  .sp-cols  { gap: 0; }

  /* stats */
  .sp-stats { border-radius: 10px; }
  .sp-stat  { padding: 12px 7px; }
  .sp-stat-n{ font-size: 17px; }
  .sp-stat-l{ font-size: 9px; }

  /* cards */
  .sp-card  { padding: 16px 15px; border-radius: 12px; }
  .sp-card-h{ font-size: 14px; }

  /* reviews */
  .sp-rv    { padding: 13px 14px; }
  .sp-rv-head { flex-wrap: wrap; }

  /* booked date item */
  .sp-bk-day { font-size: 20px; }
  .sp-bk-date-box { padding: 6px 8px; min-width: 44px; }
  .sp-bk-footer { flex-direction: column; align-items: flex-start; gap: 8px; }

  /* map */
  .sp-map-section { padding: 0 16px; }
  #sp-map { height: 260px; border-radius: 12px; }
}

/* ══ RESPONSIVE — 380px ═════════════════════════════════════ */
@media (max-width: 380px) {
  .sp-hero { height: 200px; }
  .sp-owner-btns { flex-direction: column; }
  .sp-obtn { width: 100%; justify-content: center; }
  .sp-bk-dates { padding: 10px 10px 8px; gap: 4px; }
  .sp-mobile-price-bar .price-num { font-size: 22px; }
  .sp-mobile-book-btn { padding: 10px 16px; font-size: 12px; }
}

/* desktop hides mobile-only elements */
@media (min-width: 641px) {
  .sp-mobile-actions   { display: none; }
  .sp-mobile-price-bar { display: none; }
  .sp-mobile-book-btn  { display: none; }
}
</style>


<div class="sp-page">

  <!-- ════════ HERO ════════ -->
  <div class="sp-hero">
    <img
      src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200' %>"
      alt="<%= listing.title %>">
    <div class="sp-hero-ov"></div>

    <% if(listing.category){ %>
      <span class="sp-hero-cat"><%= listing.category %></span>
    <% } %>

    <!-- wishlist button — desktop only (inside hero) -->
    <% if(currUser){ %>
      <%
        const isWishlisted = currUser.wishlist &&
          currUser.wishlist.some(function(id){
            return id.toString() === listing._id.toString();
          });
      %>
      <div class="sp-hero-wish-wrap" style="position:absolute;top:18px;right:18px;z-index:3;">
        <form action="/menu/wishlist/<%= listing._id %>" method="POST" style="margin:0;">
          <button type="submit" class="sp-hero-wish"
            title="<%= isWishlisted ? 'Remove from wishlist' : 'Save to wishlist' %>"
            style="color:<%= isWishlisted ? '#EF4444' : 'rgba(255,255,255,.7)' %>;">
            <svg viewBox="0 0 24 24"
              fill="<%= isWishlisted ? '#EF4444' : 'none' %>"
              stroke="<%= isWishlisted ? '#EF4444' : 'currentColor' %>"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </button>
        </form>
      </div>
    <% } %>

    <div class="sp-hero-price">
      <div class="sp-hero-price-num">₹<%= listing.price.toLocaleString('en-IN') %></div>
      <div class="sp-hero-price-sub">per night · + 18% GST</div>
    </div>
  </div>

  <!-- ════════ MOBILE: price bar + actions (below hero, mobile only) ════════ -->
  <div class="sp-mobile-price-bar">
    <div>
      <div class="price-num">₹<%= listing.price.toLocaleString('en-IN') %></div>
      <div class="price-sub">per night · +18% GST</div>
    </div>
    <a href="/bookings/<%= listing._id %>/book" class="sp-mobile-book-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" width="14" height="14">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Reserve
    </a>
  </div>

  <!-- mobile wishlist + share row -->
  <div class="sp-mobile-actions">
    <% if(currUser){ %>
      <%
        const isWishlistedM = currUser.wishlist &&
          currUser.wishlist.some(function(id){
            return id.toString() === listing._id.toString();
          });
      %>
      <form action="/menu/wishlist/<%= listing._id %>" method="POST" style="margin:0;">
        <button type="submit" class="sp-mobile-wish <%= isWishlistedM ? 'wishlisted' : '' %>">
          <svg viewBox="0 0 24 24"
            fill="<%= isWishlistedM ? '#EF4444' : 'none' %>"
            stroke="<%= isWishlistedM ? '#EF4444' : 'currentColor' %>"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
          </svg>
          <%= isWishlistedM ? 'Saved' : 'Save' %>
        </button>
      </form>
    <% } %>
    <button class="sp-mobile-share" onclick="if(navigator.share){navigator.share({title:'<%= listing.title %>',url:window.location.href})}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      Share
    </button>
  </div>


  <!-- ════════ TWO COLUMNS ════════ -->
  <div class="sp-cols">

    <!-- ── LEFT ── -->
    <div class="sp-left">

      <!-- title + location -->
      <div>
        <div class="sp-eyebrow" style="margin-bottom:10px;">Property details</div>
        <h1 class="sp-title"><%= listing.title %></h1>
        <div class="sp-loc">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <%= listing.location %>, <%= listing.country %>
        </div>
      </div>

      <!-- stats bar -->
      <div class="sp-stats">
        <div class="sp-stat">
          <span class="sp-stat-n">
            <% if(listing.reviews && listing.reviews.length > 0){ %>
              <%= (listing.reviews.reduce(function(s,r){ return s + (r.rating||0); }, 0) / listing.reviews.length).toFixed(1) %>★
            <% } else { %>—<% } %>
          </span>
          <span class="sp-stat-l">Rating</span>
        </div>
        <div class="sp-stat">
          <span class="sp-stat-n"><%= listing.reviews ? listing.reviews.length : 0 %></span>
          <span class="sp-stat-l">Reviews</span>
        </div>
        <div class="sp-stat">
          <span class="sp-stat-n"><%= bookings ? bookings.length : 0 %></span>
          <span class="sp-stat-l">Bookings</span>
        </div>
        <div class="sp-stat">
          <span class="sp-stat-n">4.9</span>
          <span class="sp-stat-l">Host score</span>
        </div>
      </div>

      <!-- description -->
      <div class="sp-card">
        <div class="sp-card-h">About this place</div>
        <div class="sp-card-txt"><%= listing.description %></div>
      </div>

      <!-- owner buttons -->
      <% if(currUser && listing.owner && listing.owner.equals(currUser._id)){ %>
        <div class="sp-owner-btns">
          <a href="/listings/<%= listing._id %>/edit" class="sp-obtn sp-obtn-edit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" width="13" height="13">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            Edit listing
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="margin:0;">
            <button type="submit" class="sp-obtn sp-obtn-del">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" width="13" height="13">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
              </svg>
              Delete listing
            </button>
          </form>
        </div>
      <% } %>

      <!-- reviews header -->
      <div style="display:flex;align-items:center;gap:10px;">
        <div class="sp-eyebrow" style="margin-bottom:0;">Guest reviews</div>
        <span style="background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);border-radius:999px;padding:2px 9px;font-size:10px;color:var(--blue);font-weight:600;">
          <%= listing.reviews ? listing.reviews.length : 0 %>
        </span>
      </div>

      <!-- reviews list -->
      <% if(listing.reviews && listing.reviews.length > 0){ %>
        <div class="sp-reviews">
          <% listing.reviews.forEach(function(review){ %>
            <div class="sp-rv">
              <div class="sp-rv-head">
                <div class="sp-rv-author">
                  <div class="sp-rv-av">
                    <%= review.author ? (review.author.username || review.author.name || '?')[0].toUpperCase() : '?' %>
                  </div>
                  <div>
                    <div class="sp-rv-name">
                      <%= review.author ? (review.author.username || review.author.name || 'Guest') : 'Guest' %>
                    </div>
                    <div class="sp-rv-stars">
                      <% for(var s = 0; s < 5; s++){ %>
                        <svg viewBox="0 0 24 24"
                          fill="<%= s < review.rating ? '#3B82F6' : 'rgba(59,130,246,0.18)' %>">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      <% } %>
                    </div>
                  </div>
                </div>
                <% if(currUser && review.author && review.author.equals(currUser._id)){ %>
                  <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST" style="margin:0;">
                    <button type="submit" class="sp-rv-del">Delete</button>
                  </form>
                <% } %>
              </div>
              <p class="sp-rv-txt"><%= review.comment %></p>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="sp-no-rv">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
          <p>No reviews yet — be the first to share your experience.</p>
        </div>
      <% } %>

      <!-- add review form -->
      <% if(currUser){ %>
        <div class="sp-card">
          <div class="sp-card-h">Share your experience</div>
          <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate>
            <div class="sp-fg">
              <label class="sp-flbl">
                Your rating
                <span style="color:var(--danger);font-size:9px;text-transform:uppercase;letter-spacing:.06em;margin-left:6px;">Required</span>
              </label>
              <div class="sp-stars-pick">
                <input type="radio" name="review[rating]" id="sr5" value="5" required>
                <label for="sr5">★</label>
                <input type="radio" name="review[rating]" id="sr4" value="4">
                <label for="sr4">★</label>
                <input type="radio" name="review[rating]" id="sr3" value="3">
                <label for="sr3">★</label>
                <input type="radio" name="review[rating]" id="sr2" value="2">
                <label for="sr2">★</label>
                <input type="radio" name="review[rating]" id="sr1" value="1">
                <label for="sr1">★</label>
              </div>
            </div>
            <div class="sp-fg">
              <label class="sp-flbl" for="rvComment">Your review</label>
              <textarea class="sp-fta" id="rvComment" name="review[comment]" rows="4" required
                placeholder="What made your stay special? Help other travellers plan theirs…"></textarea>
            </div>
            <button type="submit" class="sp-sbtn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" width="14" height="14">
                <path d="M22 2L11 13"/>
                <path d="M22 2L15 22 11 13 2 9l20-7z"/>
              </svg>
              Submit review
            </button>
          </form>
        </div>
      <% } %>

    </div>
    <!-- end left -->

    <!-- ── RIGHT ── -->
    <div class="sp-right">

      <!-- booking card -->
      <div class="sp-book">
        <div class="sp-book-price">
          <span class="sp-book-price-n">₹<%= listing.price.toLocaleString('en-IN') %></span>
          <span class="sp-book-price-u">/ night</span>
        </div>
        <div class="sp-book-tax">+ 18% GST applicable</div>

        <a href="/bookings/<%= listing._id %>/book" class="sp-book-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" width="15" height="15">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Reserve now
        </a>

        <div class="sp-book-sep"></div>

        <div class="sp-book-feat">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Verified property
        </div>
        <div class="sp-book-feat">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
          Free cancellation
        </div>
        <div class="sp-book-feat">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <rect x="1" y="4" width="22" height="16" rx="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
          Secure payment
        </div>
        <div class="sp-book-feat">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
          Message the host
        </div>
      </div>

      <!-- booked dates card -->
      <div class="sp-booked">
        <div class="sp-booked-hd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Booked dates
          <% if(bookings && bookings.length > 0){ %>
            <span class="sp-booked-count"><%= bookings.length %></span>
          <% } %>
        </div>

        <% if(bookings && bookings.length > 0){ %>
          <div class="sp-booked-list">
            <% bookings.forEach(function(b){
              var sd     = new Date(b.startDate);
              var ed     = new Date(b.endDate);
              var diff   = Math.round((ed - sd) / (1000 * 60 * 60 * 24));
              var isOwner = currUser && b.owner &&
                b.owner._id.toString() === currUser._id.toString();
              var months = ['Jan','Feb','Mar','Apr','May','Jun',
                            'Jul','Aug','Sep','Oct','Nov','Dec'];
            %>
              <div class="sp-bk-item">
                <div class="sp-bk-dates">
                  <div class="sp-bk-date-box">
                    <span class="sp-bk-month"><%= months[sd.getMonth()] %></span>
                    <span class="sp-bk-day"><%= sd.getDate() %></span>
                    <span class="sp-bk-year"><%= sd.getFullYear() %></span>
                  </div>
                  <div class="sp-bk-mid">
                    <div class="sp-bk-line"></div>
                    <div class="sp-bk-nights"><%= diff %> night<%= diff !== 1 ? 's' : '' %></div>
                    <svg class="sp-bk-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2" stroke-linecap="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div class="sp-bk-date-box sp-bk-date-box--end">
                    <span class="sp-bk-month"><%= months[ed.getMonth()] %></span>
                    <span class="sp-bk-day"><%= ed.getDate() %></span>
                    <span class="sp-bk-year"><%= ed.getFullYear() %></span>
                  </div>
                </div>
                <div class="sp-bk-footer">
                  <div class="sp-bk-guest">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                      stroke-linecap="round" width="11" height="11">
                      <circle cx="12" cy="8" r="4"/>
                      <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    <%= (b.owner && b.owner.username) ? b.owner.username : 'Guest booking' %>
                  </div>
                  <% if(isOwner){ %>
                    <form action="/bookings/<%= b._id %>/cancel?_method=DELETE"
                      method="POST" style="margin:0;">
                      <button type="submit" class="sp-cancel">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" width="10" height="10">
                          <line x1="18" y1="6" x2="6" y2="18"/>
                          <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                        Cancel
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="sp-no-book-wrap">
            <div class="sp-no-book-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
                <line x1="8" y1="14" x2="16" y2="14"/>
                <line x1="8" y1="18" x2="12" y2="18"/>
              </svg>
            </div>
            <p class="sp-no-book-txt">All dates available</p>
            <p class="sp-no-book-sub">No bookings yet — be the first!</p>
          </div>
        <% } %>
      </div>

    </div>
    <!-- end right -->

  </div>


  <!-- ════════ MAP ════════ -->
  <div class="sp-map-section">
    <div class="sp-map-hd">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Location
    </div>
    <p class="sp-map-sub"><%= listing.location %>, <%= listing.country %></p>
    <div id="sp-map"
      data-geometry='<%- JSON.stringify(listing.geometry || {}) %>'
      data-location="<%= listing.location %>, <%= listing.country %>"
      data-title="<%= listing.title %>">
    </div>
  </div>

</div>


<script>
(function () {
  'use strict';

  /* ── MAP ── */
  var mapEl = document.getElementById('sp-map');
  if (mapEl && typeof L !== 'undefined') {
    var lat = 20.5937, lng = 78.9629, zoom = 5, located = false;
    try {
      var geo = JSON.parse(mapEl.dataset.geometry || '{}');
      if (geo && geo.coordinates && Array.isArray(geo.coordinates) &&
          geo.coordinates.length === 2 &&
          geo.coordinates[0] !== 0 && geo.coordinates[1] !== 0) {
        lng = parseFloat(geo.coordinates[0]);
        lat = parseFloat(geo.coordinates[1]);
        zoom = 13; located = true;
      }
    } catch (e) { console.warn('Geometry parse error', e); }

    function initMap(la, ln, zm) {
      var map = L.map('sp-map', { scrollWheelZoom: false, zoomControl: true })
        .setView([la, ln], zm);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd', maxZoom: 20
      }).addTo(map);

      var pinHtml = '<div style="position:relative;width:36px;height:36px;">'
        + '<div style="width:36px;height:36px;border-radius:50% 50% 50% 0;background:#3B82F6;transform:rotate(-45deg);border:3px solid #0A0A0F;box-shadow:0 4px 16px rgba(0,0,0,.6);"></div>'
        + '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-58%);width:10px;height:10px;border-radius:50%;background:#0A0A0F;"></div>'
        + '</div>';

      var icon = L.divIcon({ className: '', html: pinHtml, iconSize: [36, 36], iconAnchor: [18, 36], popupAnchor: [0, -36] });
      var marker = L.marker([la, ln], { icon: icon }).addTo(map);

      var safeTitle = mapEl.dataset.title || '';
      var popupLoc  = mapEl.dataset.location || '';

      marker.bindPopup(
        '<div style="font-family:Inter,sans-serif;font-size:13px;color:#F0F4FF;background:#16161F;padding:10px 14px;border-radius:10px;border:1px solid rgba(59,130,246,.25);min-width:160px;line-height:1.6;">'
        + '<strong style="color:#3B82F6;display:block;margin-bottom:3px;">' + safeTitle + '</strong>'
        + popupLoc + '</div>',
        { maxWidth: 220, className: 'sp-map-popup' }
      );

      setTimeout(function () { map.invalidateSize(); }, 300);
    }

    if (located) {
      initMap(lat, lng, zoom);
    } else {
      var locStr = mapEl.dataset.location || '';
      if (locStr) {
        fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(locStr))
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data && data.length > 0) {
              lat = parseFloat(data[0].lat);
              lng = parseFloat(data[0].lon);
              zoom = 13;
            }
            initMap(lat, lng, zoom);
          })
          .catch(function () { initMap(lat, lng, zoom); });
      } else {
        initMap(lat, lng, zoom);
      }
    }

    /* popup style overrides */
    var style = document.createElement('style');
    style.textContent = '.sp-map-popup .leaflet-popup-content-wrapper{background:transparent!important;border:none!important;box-shadow:none!important;padding:0!important;}.sp-map-popup .leaflet-popup-content{margin:0!important;}.sp-map-popup .leaflet-popup-tip-container{display:none;}';
    document.head.appendChild(style);
  }

})();
</script>
