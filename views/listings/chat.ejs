<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>StayScape — Scout AI Assistant</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
  /* ═══════════════════════════════════════════════════════════
     SCOUT CHATBOT — StayScape blue/cyan dark system
     Tokens: --blue #3B82F6  --cyan #06B6D4  --bg #0A0A0F
             --s1 #111118  --s2 #16161F  --s3 #1E1E28
             --text #F0F4FF  --muted #6B7280  --border rgba(255,255,255,.07)
  ═══════════════════════════════════════════════════════════ */

  :root {
    --blue:       #3B82F6;
    --cyan:       #06B6D4;
    --blue-lt:    #60A5FA;
    --glow-blue:  rgba(59,130,246,.10);
    --bg:         #0A0A0F;
    --s1:         #111118;
    --s2:         #16161F;
    --s3:         #1E1E28;
    --s4:         #24242F;
    --text:       #F0F4FF;
    --muted:      #6B7280;
    --muted-lt:   #9CA3AF;
    --border:     rgba(255,255,255,.07);
    --border-b:   rgba(59,130,246,.2);
    --danger:     #F87171;
    --success:    #4ADE80;
    --font:       'Inter', system-ui, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    height: 100dvh; /* dynamic viewport height for mobile browsers */
    overflow: hidden;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    display: flex;
    flex-direction: column;
  }

  /* ── BG GLOWS — mirrors index hero ── */
  body::before {
    content: '';
    position: fixed; top: -180px; right: -120px;
    width: 520px; height: 520px; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,130,246,.06) 0%, transparent 60%);
    pointer-events: none; z-index: 0;
  }
  body::after {
    content: '';
    position: fixed; bottom: -80px; left: -60px;
    width: 360px; height: 360px; border-radius: 50%;
    background: radial-gradient(circle, rgba(6,182,212,.04) 0%, transparent 60%);
    pointer-events: none; z-index: 0;
  }

  /* dot-grid — matches hero */
  .cb-grid {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(59,130,246,.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,.022) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  /* ── KEYFRAMES ── */
  @keyframes cb-fadeDown {
    from { opacity:0; transform:translateY(-10px); }
    to   { opacity:1; transform:translateY(0); }
  }
  @keyframes cb-msgIn {
    from { opacity:0; transform:translateY(10px) scale(.98); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }
  @keyframes cb-beam {
    0%   { opacity:0; transform:translateX(-100%); }
    20%  { opacity:1; }
    80%  { opacity:1; }
    100% { opacity:0; transform:translateX(100%); }
  }
  @keyframes cb-dot {
    0%,80%,100% { transform:scale(0); opacity:.3; }
    40%         { transform:scale(1); opacity:1; }
  }
  @keyframes cb-pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(59,130,246,.4); }
    60%     { box-shadow: 0 0 0 6px rgba(59,130,246,.0); }
  }
  @keyframes cb-shimmer {
    0%   { background-position:200% center; }
    100% { background-position:-200% center; }
  }

  /* ══════════════════════════════════
     TOPBAR
  ══════════════════════════════════ */
  .topbar {
    flex-shrink: 0;
    position: relative; z-index: 10;
    background: rgba(17,17,24,.92);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 0 20px;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
    animation: cb-fadeDown .5s cubic-bezier(.22,1,.36,1) both;
  }

  /* beam — same as login/signup cards */
  .topbar::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--blue) 45%, var(--cyan) 55%, transparent 100%);
    animation: cb-beam 5s ease-in-out 1s both;
  }

  .topbar-brand { display: flex; align-items: center; gap: 12px; }

  /* bot avatar — mirrors navbar avatar */
  .bot-icon {
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(59,130,246,.1);
    border: 1px solid rgba(59,130,246,.25);
    display: flex; align-items: center; justify-content: center;
    color: var(--blue); position: relative; flex-shrink: 0;
    animation: cb-pulse 2.5s ease-out infinite;
    transition: transform .2s cubic-bezier(.34,1.56,.64,1);
  }
  .bot-icon:hover { transform: scale(1.08); }
  .bot-icon svg { width: 18px; height: 18px; }
  .bot-icon-online {
    position: absolute; bottom: 1px; right: 1px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--success); border: 2px solid var(--s1);
  }

  .bot-name {
    font-size: 17px; font-weight: 700; color: var(--text);
    letter-spacing: .01em;
  }
  .bot-name em { font-style: normal; color: var(--blue); }

  .bot-status {
    font-size: 11px; color: var(--muted);
    display: flex; align-items: center; gap: 5px; margin-top: 2px;
  }
  .bot-status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--success);
  }

  .topbar-right { display: flex; align-items: center; gap: 8px; }

  /* topbar icon buttons — mirrors navbar .ss-link */
  .topbar-btn {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); cursor: pointer; text-decoration: none;
    transition: background .2s, color .2s, border-color .2s,
                transform .2s cubic-bezier(.34,1.56,.64,1);
  }
  .topbar-btn svg { width: 15px; height: 15px; }
  .topbar-btn:hover {
    background: var(--glow-blue);
    border-color: rgba(59,130,246,.3);
    color: var(--blue);
    transform: scale(1.08);
  }

  /* ══════════════════════════════════
     QUICK CHIPS — mirrors .sl-cat strip
  ══════════════════════════════════ */
  .chips-strip {
    flex-shrink: 0; z-index: 9;
    background: rgba(10,10,15,.95);
    border-bottom: 1px solid var(--border);
    padding: 10px 20px;
    display: flex; gap: 8px;
    overflow-x: auto; scrollbar-width: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .chips-strip::-webkit-scrollbar { display: none; }

  .chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border); border-radius: 999px;
    font-size: 11px; font-weight: 500; color: var(--muted);
    cursor: pointer; white-space: nowrap; flex-shrink: 0;
    letter-spacing: .03em;
    transition: border-color .18s, color .18s, background .18s,
                transform .18s cubic-bezier(.34,1.56,.64,1);
  }
  .chip svg { width: 11px; height: 11px; color: var(--cyan); flex-shrink: 0; }
  .chip:hover {
    border-color: rgba(59,130,246,.4);
    color: var(--blue);
    background: var(--glow-blue);
    transform: translateY(-2px);
  }
  .chip:active { transform: scale(.95); }

  /* ══════════════════════════════════
     MESSAGES AREA
  ══════════════════════════════════ */
  .messages {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 20px 20px 12px;
    display: flex; flex-direction: column; gap: 4px;
    position: relative; z-index: 1;
    /* smooth momentum scrolling on iOS */
    -webkit-overflow-scrolling: touch;
  }
  .messages::-webkit-scrollbar { width: 4px; }
  .messages::-webkit-scrollbar-track { background: transparent; }
  .messages::-webkit-scrollbar-thumb {
    background: rgba(59,130,246,.2); border-radius: 99px;
  }
  .messages::-webkit-scrollbar-thumb:hover {
    background: rgba(59,130,246,.4);
  }

  /* ── DATE DIVIDER ── */
  .date-divider {
    display: flex; align-items: center; gap: 10px;
    margin: 8px 0;
    font-size: 10px; letter-spacing: .12em;
    color: var(--muted); text-transform: uppercase;
    font-weight: 500;
  }
  .date-divider::before, .date-divider::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  /* ── MESSAGE ROW ── */
  .msg-row {
    display: flex; gap: 10px;
    animation: cb-msgIn .3s cubic-bezier(.22,1,.36,1) both;
    max-width: 100%;
  }
  .msg-row.user { flex-direction: row-reverse; }
  /* tighter grouping for same-sender consecutive messages */
  .msg-row.bot  + .msg-row.bot  { margin-top: 1px; }
  .msg-row.user + .msg-row.user { margin-top: 1px; }
  .msg-row.bot  + .msg-row.user,
  .msg-row.user + .msg-row.bot  { margin-top: 10px; }

  /* Avatar */
  .msg-av {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    align-self: flex-end; margin-bottom: 2px;
  }
  .msg-av.bot-av {
    background: rgba(59,130,246,.1);
    border: 1px solid rgba(59,130,246,.2);
    color: var(--blue);
  }
  .msg-av.user-av {
    background: rgba(6,182,212,.1);
    border: 1px solid rgba(6,182,212,.2);
    color: var(--cyan);
  }
  .msg-av svg { width: 13px; height: 13px; }

  /* Bubble group */
  .msg-group { display: flex; flex-direction: column; gap: 2px; max-width: 74%; }
  .msg-row.user .msg-group { align-items: flex-end; }
  .msg-row.bot  .msg-group { align-items: flex-start; }

  /* Sender label */
  .msg-sender {
    font-size: 10px; letter-spacing: .08em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 2px; padding: 0 4px;
    font-weight: 500;
  }

  /* ── BUBBLE ── */
  .bubble {
    padding: 11px 15px;
    border-radius: 16px;
    font-size: 13.5px; line-height: 1.75; font-weight: 400;
    word-break: break-word; position: relative;
  }

  /* Bot bubble — mirrors .sl-card style */
  .msg-row.bot .bubble {
    background: var(--s2);
    border: 1px solid rgba(255,255,255,.06);
    color: var(--text);
    border-bottom-left-radius: 4px;
  }
  .msg-row.bot:hover .bubble {
    border-color: rgba(59,130,246,.2);
  }

  /* User bubble — blue gradient */
  .msg-row.user .bubble {
    background: linear-gradient(135deg, rgba(59,130,246,.18), rgba(6,182,212,.12));
    border: 1px solid rgba(59,130,246,.28);
    color: var(--text);
    border-bottom-right-radius: 4px;
  }

  /* Rich content inside bot bubbles */
  .msg-row.bot .bubble p   { margin: 0 0 7px; }
  .msg-row.bot .bubble p:last-child { margin-bottom: 0; }
  .msg-row.bot .bubble h3 {
    font-size: 16px; font-weight: 600; color: var(--text);
    margin: 10px 0 5px; letter-spacing: -.01em;
  }
  .msg-row.bot .bubble h4 {
    font-size: 14px; font-weight: 600; color: var(--text);
    margin: 7px 0 4px;
  }
  .msg-row.bot .bubble ul,
  .msg-row.bot .bubble ol {
    padding-left: 18px; margin: 5px 0 8px;
  }
  .msg-row.bot .bubble li {
    color: var(--muted-lt); margin: 4px 0;
    font-size: 13px; line-height: 1.65;
  }
  .msg-row.bot .bubble ul li::marker { color: var(--blue); }
  .msg-row.bot .bubble ol li::marker { color: var(--blue); font-weight: 600; }
  .bubble strong { color: var(--text); font-weight: 600; }
  .bubble em     { font-style: italic; color: var(--cyan); }
  .bubble code {
    background: rgba(59,130,246,.1);
    border: 1px solid rgba(59,130,246,.2);
    border-radius: 5px; padding: 2px 7px;
    font-size: 12px; font-family: 'Courier New', monospace;
    color: var(--blue-lt); word-break: break-all;
  }
  .bubble hr  { border: none; border-top: 1px solid var(--border); margin: 10px 0; }
  .bubble a   { color: var(--blue); text-decoration: underline; text-underline-offset: 2px; }
  .bubble a:hover { color: var(--cyan); }

  /* Timestamp */
  .msg-time {
    font-size: 10px; color: var(--muted);
    padding: 0 4px; margin-top: 2px;
  }

  /* ── TYPING INDICATOR ── */
  .typing-row {
    display: flex; gap: 10px;
    animation: cb-msgIn .25s ease both;
  }
  .typing-bubble {
    background: var(--s2);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 16px; border-bottom-left-radius: 4px;
    padding: 13px 16px;
    display: flex; gap: 5px; align-items: center;
  }
  .td {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--blue);
    animation: cb-dot 1.4s ease-in-out infinite;
  }
  .td:nth-child(1) { animation-delay: 0s; }
  .td:nth-child(2) { animation-delay: .2s; }
  .td:nth-child(3) { animation-delay: .4s; }

  /* ── EMPTY STATE — mirrors .sl-empty ── */
  .empty-state {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 14px; text-align: center; padding: 40px 20px;
    pointer-events: none; opacity: .55;
  }
  .empty-icon {
    width: 60px; height: 60px; border-radius: 50%;
    background: rgba(59,130,246,.08);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--blue);
  }
  .empty-icon svg { width: 26px; height: 26px; }
  .empty-title {
    font-size: 20px; font-weight: 300; color: var(--text);
    letter-spacing: -.01em;
  }
  .empty-sub {
    font-size: 13px; color: var(--muted);
    max-width: 260px; line-height: 1.7;
  }

  /* ══════════════════════════════════
     INPUT AREA
  ══════════════════════════════════ */
  .input-area {
    flex-shrink: 0; position: relative; z-index: 10;
    background: rgba(17,17,24,.95);
    border-top: 1px solid var(--border);
    padding: 12px 16px;
    display: flex; align-items: flex-end; gap: 10px;
    /* safe area inset for notched phones */
    padding-bottom: max(12px, env(safe-area-inset-bottom));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .input-wrap {
    flex: 1;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
    transition: border-color .22s, box-shadow .22s, background .22s;
    display: flex; align-items: flex-end;
  }
  .input-wrap:focus-within {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(59,130,246,.12);
    background: rgba(255,255,255,.05);
  }

  .chat-inp {
    flex: 1; background: transparent; border: none; outline: none;
    resize: none;
    padding: 11px 14px;
    font-size: 14px; color: var(--text); font-family: var(--font);
    line-height: 1.5; max-height: 120px;
    overflow-y: auto; scrollbar-width: none;
    /* prevent iOS zoom on focus */
    font-size: 16px;
  }
  @media (min-width:481px) {
    .chat-inp { font-size: 14px; }
  }
  .chat-inp::-webkit-scrollbar { display: none; }
  .chat-inp::placeholder { color: var(--muted); }

  /* char counter */
  .char-count {
    font-size: 10px; color: var(--muted);
    padding: 0 10px 10px; align-self: flex-end;
    flex-shrink: 0; transition: color .2s; white-space: nowrap;
  }
  .char-count.warn { color: #FBBF24; }

  /* Send button — mirrors .sl-btn-primary */
  .send-btn {
    width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, var(--blue), var(--cyan));
    border: none;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer;
    position: relative; overflow: hidden;
    transition: transform .22s cubic-bezier(.34,1.56,.64,1),
                box-shadow .2s, filter .2s, opacity .2s;
    /* keep button at bottom on multi-line input */
    align-self: flex-end;
  }
  .send-btn svg { width: 16px; height: 16px; position: relative; z-index: 1; }
  .send-btn:hover:not(:disabled) {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(59,130,246,.4);
    filter: brightness(1.08);
  }
  .send-btn:active:not(:disabled) { transform: scale(.93); }
  .send-btn:disabled { opacity: .35; cursor: not-allowed; transform: none; }

  /* ── CAPTION ── */
  .input-caption {
    text-align: center; font-size: 10px; color: var(--muted);
    padding: 6px 16px max(10px, env(safe-area-inset-bottom));
    background: var(--s1);
    letter-spacing: .04em;
    display: flex; align-items: center; justify-content: center; gap: 5px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }
  .input-caption svg { width: 10px; height: 10px; color: var(--cyan); }

  /* ══════════════════════════════════
     RESPONSIVE — TABLET 768px
  ══════════════════════════════════ */
  @media (max-width: 768px) {
    .msg-group { max-width: 80%; }
  }

  /* ══════════════════════════════════
     RESPONSIVE — MOBILE 480px
  ══════════════════════════════════ */
  @media (max-width: 480px) {
    /* topbar */
    .topbar         { padding: 0 14px; height: 58px; }
    .bot-name       { font-size: 15px; }
    .bot-status     { font-size: 10px; }
    .topbar-btn     { width: 32px; height: 32px; }
    .topbar-btn svg { width: 14px; height: 14px; }

    /* chips */
    .chips-strip    { padding: 8px 14px; gap: 6px; }
    .chip           { padding: 6px 11px; font-size: 10px; }

    /* messages */
    .messages       { padding: 14px 12px 10px; gap: 3px; }
    .msg-group      { max-width: 88%; }
    .bubble         { padding: 10px 13px; font-size: 13px; }
    .msg-row.bot .bubble li { font-size: 12px; }
    .msg-av         { width: 26px; height: 26px; }
    .msg-av svg     { width: 11px; height: 11px; }

    /* input */
    .input-area     { padding: 10px 12px; gap: 8px;
                      padding-bottom: max(10px, env(safe-area-inset-bottom)); }
    .send-btn       { width: 40px; height: 40px; }
    .send-btn svg   { width: 15px; height: 15px; }

    /* caption hidden on very small screens to save space */
    .input-caption  { display: none; }
  }

  /* ══════════════════════════════════
     RESPONSIVE — VERY SMALL 360px
  ══════════════════════════════════ */
  @media (max-width: 360px) {
    .bot-name       { font-size: 14px; }
    .bot-status     { display: none; }
    .msg-group      { max-width: 92%; }
    .bubble         { padding: 9px 12px; font-size: 12.5px; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .topbar, .msg-row, .typing-row { animation: none !important; }
    .bot-icon { animation: none !important; }
    .topbar::after { animation: none; display: none; }
  }
  </style>
</head>
<body>

<div class="cb-grid" aria-hidden="true"></div>

<!-- ══ TOPBAR ══════════════════════════════════════════════ -->
<div class="topbar">
  <div class="topbar-brand">
    <div class="bot-icon">
      <!-- Scout bot icon -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.8" stroke-linecap="round">
        <rect x="2" y="8" width="20" height="13" rx="3"/>
        <path d="M8 8V6a4 4 0 018 0v2"/>
        <circle cx="9"  cy="14.5" r="1.3" fill="currentColor" stroke="none"/>
        <circle cx="15" cy="14.5" r="1.3" fill="currentColor" stroke="none"/>
        <path d="M9 18.5h6"/>
      </svg>
      <span class="bot-icon-online"></span>
    </div>
    <div>
      <div class="bot-name">Stay<em>Scape</em> Scout</div>
      <div class="bot-status">
        <span class="bot-status-dot"></span>
        Online · Replies instantly
      </div>
    </div>
  </div>

  <div class="topbar-right">
    <div class="topbar-btn" title="Clear chat" id="clearBtn" role="button" aria-label="Clear chat">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
        <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
      </svg>
    </div>
    <a href="/listings" class="topbar-btn" title="Back to listings" aria-label="Back to listings">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
        <path d="M9 21V12h6v9"/>
      </svg>
    </a>
  </div>
</div>

<!-- ══ QUICK CHIPS ══════════════════════════════════════════ -->
<div class="chips-strip" id="chipsStrip" role="list" aria-label="Quick questions">
  <div class="chip" data-q="How do I book a property on StayScape?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <rect x="3" y="4" width="18" height="18" rx="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    How to book
  </div>
  <div class="chip" data-q="How do I list my property on StayScape?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
    </svg>
    List a property
  </div>
  <div class="chip" data-q="What is the cancellation policy?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M15 9l-6 6M9 9l6 6"/>
    </svg>
    Cancellation
  </div>
  <div class="chip" data-q="How do payments and GST work on StayScape?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <rect x="1" y="4" width="22" height="16" rx="2"/>
      <line x1="1" y1="10" x2="23" y2="10"/>
    </svg>
    Payments & GST
  </div>
  <div class="chip" data-q="Show me available villas" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/>
      <path d="M9 21V12h6v9"/>
    </svg>
    Find villas
  </div>
  <div class="chip" data-q="Is StayScape safe to use?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
    Safety & trust
  </div>
  <div class="chip" data-q="How do I view my bookings?" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    My bookings
  </div>
</div>

<!-- ══ MESSAGES ══════════════════════════════════════════════ -->
<div class="messages" id="messages" role="log" aria-live="polite" aria-label="Chat messages"></div>

<!-- ══ INPUT AREA ════════════════════════════════════════════ -->
<div class="input-area">
  <div class="input-wrap">
    <textarea
      class="chat-inp" id="chatInput"
      placeholder="Ask Scout anything about StayScape…"
      rows="1" maxlength="500"
      autocomplete="off" autocorrect="off"
      spellcheck="true"
      aria-label="Message input"></textarea>
    <span class="char-count" id="charCount" aria-live="polite"></span>
  </div>
  <button class="send-btn" id="sendBtn" disabled
          title="Send message" aria-label="Send message">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 2L11 13"/>
      <path d="M22 2L15 22 11 13 2 9l20-7z"/>
    </svg>
  </button>
</div>

<div class="input-caption">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.8" stroke-linecap="round">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
  </svg>
  Scout AI · StayScape Help Assistant · Responses may vary
</div>


<script>
(function () {
  'use strict';

  var msgsEl   = document.getElementById('messages');
  var input    = document.getElementById('chatInput');
  var sendBtn  = document.getElementById('sendBtn');
  var charEl   = document.getElementById('charCount');
  var clearBtn = document.getElementById('clearBtn');
  var MAX      = 500;
  var lastSender = null;

  /* ── SCROLL ── */
  function scrollBottom() {
    msgsEl.scrollTop = msgsEl.scrollHeight;
  }

  /* ── TIME ── */
  function nowTime() {
    return new Date().toLocaleTimeString('en-IN', {
      hour: '2-digit', minute: '2-digit'
    });
  }

  /* ── MARKDOWN → HTML ── */
  function formatText(raw) {
    if (!raw) return '';
    var lines    = raw.split('\n');
    var out      = [];
    var inList   = false;
    var listType = '';

    function closeList() {
      if (inList) {
        out.push('</' + listType + '>');
        inList = false; listType = '';
      }
    }

    function esc(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>');
    }

    lines.forEach(function (line) {
      var num    = line.match(/^(\d+)\.\s+(.*)/);
      var bullet = line.match(/^[-•*]\s+(.*)/);

      if (bullet) {
        if (!inList || listType !== 'ul') { closeList(); out.push('<ul>'); inList = true; listType = 'ul'; }
        out.push('<li>' + esc(bullet[1]) + '</li>');
      } else if (num) {
        if (!inList || listType !== 'ol') { closeList(); out.push('<ol>'); inList = true; listType = 'ol'; }
        out.push('<li>' + esc(num[2]) + '</li>');
      } else if (line.trim() === '') {
        closeList(); out.push('<br>');
      } else if (line.startsWith('### ')) {
        closeList(); out.push('<h4>' + esc(line.slice(4)) + '</h4>');
      } else if (line.startsWith('## ')) {
        closeList(); out.push('<h3>' + esc(line.slice(3)) + '</h3>');
      } else if (line.startsWith('---')) {
        closeList(); out.push('<hr>');
      } else {
        closeList(); out.push('<p>' + esc(line) + '</p>');
      }
    });

    closeList();
    return out.join('').replace(/(<br>\s*){3,}/g, '<br><br>');
  }

  /* ── TYPEWRITER EFFECT ── */
  function typewriterEffect(bubble, html) {
    var temp = document.createElement('div');
    temp.innerHTML = html;
    bubble.innerHTML = '';
    var allNodes = [];

    function walk(node, targetParent) {
      if (node.nodeType === Node.TEXT_NODE) {
        allNodes.push({ type: 'text', text: node.textContent, parent: targetParent });
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        var clone = node.cloneNode(false);
        allNodes.push({ type: 'open',  el: clone, parent: targetParent });
        Array.from(node.childNodes).forEach(function (c) { walk(c, clone); });
        allNodes.push({ type: 'close', el: clone, parent: targetParent });
      }
    }
    Array.from(temp.childNodes).forEach(function (n) { walk(n, bubble); });

    var i = 0;
    var SPEED = 10; /* ms per char — slightly faster */

    function nextNode() {
      if (i >= allNodes.length) return;
      var item = allNodes[i++];
      if (item.type === 'open') {
        item.parent.appendChild(item.el);
        nextNode();
      } else if (item.type === 'close') {
        nextNode();
      } else {
        var chars = item.text.split('');
        var ci = 0;
        var tn = document.createTextNode('');
        item.parent.appendChild(tn);
        (function typeChar() {
          if (ci < chars.length) {
            tn.textContent += chars[ci++];
            scrollBottom();
            setTimeout(typeChar, SPEED);
          } else {
            nextNode();
          }
        })();
      }
    }
    nextNode();
  }

  /* ── DATE DIVIDER ── */
  function addDateDivider() {
    var today = new Date().toLocaleDateString('en-IN', {
      weekday: 'long', day: 'numeric', month: 'long'
    });
    var div = document.createElement('div');
    div.className = 'date-divider';
    div.textContent = today;
    msgsEl.appendChild(div);
  }

  /* ── ADD MESSAGE ── */
  function addMessage(type, text, opts) {
    opts = opts || {};
    var isUser  = type === 'user';
    var showAv  = (lastSender !== type) || opts.forceAv;
    lastSender  = type;

    var row = document.createElement('div');
    row.className = 'msg-row ' + type;

    /* Avatar */
    var av = document.createElement('div');
    av.className = 'msg-av ' + (isUser ? 'user-av' : 'bot-av');
    av.style.visibility = showAv ? 'visible' : 'hidden';
    av.innerHTML = isUser
      ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>'
      : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="8" width="20" height="13" rx="3"/><path d="M8 8V6a4 4 0 018 0v2"/><circle cx="9" cy="14.5" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="14.5" r="1" fill="currentColor" stroke="none"/></svg>';

    /* Group */
    var group = document.createElement('div');
    group.className = 'msg-group';

    /* Sender label */
    if (showAv) {
      var lbl = document.createElement('div');
      lbl.className = 'msg-sender';
      lbl.textContent = isUser ? 'You' : 'Scout';
      group.appendChild(lbl);
    }

    /* Bubble */
    var bubble = document.createElement('div');
    bubble.className = 'bubble';
    if (isUser) {
      bubble.textContent = text;
      group.appendChild(bubble);
    } else {
      var html = formatText(text);
      group.appendChild(bubble);
      typewriterEffect(bubble, html);
    }

    /* Timestamp */
    var ts = document.createElement('div');
    ts.className = 'msg-time';
    ts.setAttribute('aria-label', 'Sent at ' + nowTime());
    ts.textContent = nowTime();
    group.appendChild(ts);

    if (isUser) {
      row.appendChild(group);
      row.appendChild(av);
    } else {
      row.appendChild(av);
      row.appendChild(group);
    }

    msgsEl.appendChild(row);
    scrollBottom();
    return row;
  }

  /* ── TYPING INDICATOR ── */
  var typingEl = null;
  function showTyping() {
    if (typingEl) return;
    var row = document.createElement('div');
    row.className = 'typing-row';

    var av = document.createElement('div');
    av.className = 'msg-av bot-av';
    av.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="8" width="20" height="13" rx="3"/><path d="M8 8V6a4 4 0 018 0v2"/></svg>';

    var bub = document.createElement('div');
    bub.className = 'typing-bubble';
    bub.innerHTML = '<div class="td"></div><div class="td"></div><div class="td"></div>';
    bub.setAttribute('aria-label', 'Scout is typing');

    row.appendChild(av);
    row.appendChild(bub);
    msgsEl.appendChild(row);
    typingEl = row;
    scrollBottom();
  }
  function hideTyping() {
    if (typingEl) { typingEl.remove(); typingEl = null; }
  }

  /* ── WELCOME MESSAGE ── */
  addDateDivider();
  addMessage('bot', [
    "Hello! 👋 I'm **Scout**, your StayScape AI assistant.",
    "",
    "I can help you with:",
    "- Finding and booking properties",
    "- Pricing, payments and GST",
    "- Cancellation and refund policy",
    "- Listing your property",
    "- Account and wishlist",
    "",
    "What can I help you with today?"
  ].join('\n'), { forceAv: true });

  /* ── CHIPS ── */
  document.querySelectorAll('.chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
      var q = this.dataset.q;
      if (q) send(q);
    });
  });

  /* ── SEND ── */
  async function send(text) {
    var msg = (text || input.value.replace(/\n/g, ' ')).trim();
    if (!msg || sendBtn.disabled) return;

    addMessage('user', msg);

    if (!text) {
      input.value = '';
      autoResize();
      updateCharCount('');
    }

    sendBtn.disabled = true;
    showTyping();
    lastSender = 'user';

    try {
      var res  = await fetch('/chat', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ message: msg })
      });
      var data = await res.json();
      hideTyping();
      lastSender = null;
      addMessage('bot', data.reply || "I didn't get a response — please try again.");
    } catch (err) {
      console.error('Chat error:', err);
      hideTyping();
      lastSender = null;
      addMessage('bot', "Sorry, I'm having trouble connecting. Please try again in a moment.");
    }

    sendBtn.disabled = false;
    input.focus();
  }

  /* ── INPUT HELPERS ── */
  function updateCharCount(val) {
    var n = val.length;
    if (n > MAX * 0.75) {
      charEl.textContent = (MAX - n) + ' left';
      charEl.className   = 'char-count' + (n > MAX * 0.9 ? ' warn' : '');
    } else {
      charEl.textContent = '';
      charEl.className   = 'char-count';
    }
  }

  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }

  input.addEventListener('input', function () {
    updateCharCount(this.value);
    autoResize();
    sendBtn.disabled = !this.value.trim();
  });

  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      send();
    }
  });

  sendBtn.addEventListener('click', function () { send(); });

  /* ── CLEAR ── */
  clearBtn.addEventListener('click', function () {
    /* Also call server-side clear endpoint if available */
    fetch('/chat/clear', { method: 'POST' }).catch(function () {});

    msgsEl.innerHTML = '';
    lastSender = null;
    addDateDivider();
    addMessage('bot', "Chat cleared! ✨ How can I help you?", { forceAv: true });
  });

  /* ── KEYBOARD SHORTCUT: Escape focuses input ── */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') input.focus();
  });

})();
</script>
</body>
</html>